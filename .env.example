# NEYO — environment variable reference.
# Copy this file to `.env` for local development and fill in real values.
# In production (Vercel), set these as real Project → Environment Variables
# instead — never commit a real `.env` with production secrets to git.
#
# Most third-party API keys (Africa's Talking, Google Vision, YouTube Data
# API, Cloudflare, Vercel API token, TURN/STUN) are NOT set here — they live
# in the in-app "Founder Credentials Vault" (NEYO Ops → Integration
# Credentials), encrypted at rest with NEYO_MASTER_KEK, and are read at
# runtime via readCompanySecret(). This keeps them editable without a
# redeploy and out of any .env file entirely.

# ---------------------------------------------------------------------------
# Database (Postgres — Neon in production)
# ---------------------------------------------------------------------------
# Runtime queries (every request the app makes) — this is Neon's POOLED
# connection string (goes through pgbouncer). In Vercel, this is what Neon's
# official integration sets automatically when you connect a Neon project.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"

# `prisma migrate deploy` (and only that) uses this DIRECT, non-pooled
# connection instead — pooled/pgbouncer connections cannot hold the
# session-level Postgres advisory lock Prisma's migration engine needs,
# which is the real cause of a P1002 "timed out trying to acquire a
# postgres advisory lock" error during deploy if this is missing or wrong.
# Neon's Vercel integration provides this automatically as
# POSTGRES_URL_NON_POOLING — copy that exact value here (or alias it).
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/db?sslmode=require"

# For local dev with a plain (non-pooled) Postgres instance, both variables
# can safely point at the SAME connection string.

# ---------------------------------------------------------------------------
# Security (required in every environment)
# ---------------------------------------------------------------------------
# Master Key-Encrypting-Key for envelope encryption of tenant secrets
# (A.2.7). Any base64-encoded 32-byte value. Generate a real one for
# production with: openssl rand -base64 32
NEYO_MASTER_KEK="REPLACE_WITH_A_REAL_BASE64_32_BYTE_KEY"

# ---------------------------------------------------------------------------
# App URLs
# ---------------------------------------------------------------------------
APP_BASE_URL="http://localhost:3000"
ROOT_DOMAIN="neyo.co.ke"
BASE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# M-Pesa Daraja (STK Push webhooks)
# ---------------------------------------------------------------------------
DARAJA_WEBHOOK_TOKEN="dev-webhook-token"
NEYO_DARAJA_CONSUMER_KEY=""

# ---------------------------------------------------------------------------
# Scheduled jobs (Vercel Cron calls /api/jobs/tick with this bearer token)
# ---------------------------------------------------------------------------
CRON_SECRET="dev-cron-secret"

# ---------------------------------------------------------------------------
# WebAuthn / Passkeys
# ---------------------------------------------------------------------------
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"

# ---------------------------------------------------------------------------
# Optional: SMS (Africa's Talking) — usually set via the in-app Credentials
# Vault instead; these env vars are a fallback/legacy path.
# ---------------------------------------------------------------------------
AT_API_KEY=""
AT_USERNAME=""
AT_SENDER_ID=""

# ---------------------------------------------------------------------------
# Optional: Email (Resend)
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# ---------------------------------------------------------------------------
# Optional: Object storage (Cloudflare R2 — encrypted Storage Vault)
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE=""
NEYO_ALLOW_LEGACY_DIRECT_UPLOADS="false"

# ---------------------------------------------------------------------------
# Optional: background job worker (BullMQ + Redis)
# ---------------------------------------------------------------------------
REDIS_URL=""
WORKER_ENABLED="false"

# ---------------------------------------------------------------------------
# Optional: Web Push notifications (VAPID)
# ---------------------------------------------------------------------------
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="mailto:ops@neyo.co.ke"

# ---------------------------------------------------------------------------
# Optional: WebRTC (online classes) TURN/STUN — usually set via the
# in-app Credentials Vault instead.
# ---------------------------------------------------------------------------
STUN_SERVER_URL=""
TURN_SERVER_URL=""
TURN_SERVER_USERNAME=""
TURN_SERVER_SECRET=""

# ---------------------------------------------------------------------------
# Optional: WhatsApp Business API
# ---------------------------------------------------------------------------
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v20.0"

# ---------------------------------------------------------------------------
# Optional: YouTube Data API v3 (EE.7 learning library link curation)
# ---------------------------------------------------------------------------
YOUTUBE_API_KEY=""

# ---------------------------------------------------------------------------
# Optional: observability (error tracking + logs + analytics)
# ---------------------------------------------------------------------------
SENTRY_DSN=""
BETTER_STACK_TOKEN=""
BETTER_STACK_INGEST_URL=""
LOGTAIL_TOKEN=""
LOG_LEVEL="info"
POSTHOG_KEY=""
POSTHOG_HOST=""

# ---------------------------------------------------------------------------
# Optional: hardware integrations (QR scanners, biometric devices)
# ---------------------------------------------------------------------------
HARDWARE_FEED_TOKEN=""

# ---------------------------------------------------------------------------
# Test-only
# ---------------------------------------------------------------------------
NEYO_TEST_BASE_URL="http://localhost:3000"
