node_modules
.next
out
dist
build
coverage
*.log
.DS_Store

# Prisma local dev database
prisma/dev.db
prisma/dev.db-journal

# Env files (keep .env out of git in real projects)
.env
.env.local

# Local file-storage fallback (real uploaded PDFs/photos when R2 isn't
# configured in a dev sandbox) -- these are runtime data tied to whatever
# random tenantId a given seed run happens to generate locally, not source
# code; committing them just bloats the repo with stale sandbox artifacts.
# (234 pre-existing files were already committed by a prior session before
# this rule existed -- left alone here since removing tracked history is a
# separate, larger cleanup outside this fix's scope.)
.uploads/

# Worker is generated from worker.ts.example at Docker build (A.19); never commit it
scripts/worker.ts

# Vercel link metadata
.vercel

# TypeScript incremental build cache (must never be committed —
# a stale cache can hide real type errors from `tsc --noEmit`)
*.tsbuildinfo

.github/workflows/
