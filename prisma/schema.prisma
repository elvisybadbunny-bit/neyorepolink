// ---- Leaving Certificate Vault (H.3) ---------------------------------------
model LeavingCertificate {
  id               String    @id @default(cuid())
  tenantId         String
  studentId        String    @unique
  student          Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  certificateType  String // "KCPE" | "KCSE" | "OTHER"
  certificateNo    String    @unique
  status           String    @default("STORED") // STORED | HANDED_OVER
  fileUrl          String? // scanned copy upload (optional)
  fileName         String?
  hardcopyLocation String    @default("Unspecified") // physical location of the hardcopy certificate (H.3) - MANDATORY!
  handedOverTo     String? // who physically took it (e.g. Student, Parent)
  handedOverAt     DateTime? // exact date and time of handover
  handedOverById   String? // staff who did the handover
  handedOverByName String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
}

// ---- Entrance Exam Paper Vault (H.3 / I.11) ---------------------------------
// One printable interview/entrance paper per actual class/stream, managed from
// Admissions so staff do not dig through files during new-student interviews.
model EntranceExamPaper {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId          String? // SchoolClass.id; nullable only for old migrated level-only rows
  classLevel       String // legacy/display fallback, e.g. "Form 1"
  classLabel       String // exact class display, e.g. "Form 1 East"
  title            String    @default("Entrance interview paper")
  fileUrl          String
  fileName         String
  hardcopyLocation String    @default("Admissions office file")
  uploadedById     String?
  uploadedBy       String?
  printCount       Int       @default(0)
  lastPrintedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, classId])
  @@index([tenantId, classLabel])
}

// =============================================================================
// PART EE.5 — Scanned Exam Papers (Teacher writes on paper, NEYO tidies it)
// =============================================================================

model ScannedExamPaper {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById     String
  createdByName   String
  subjectId       String
  subject         Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classId         String
  schoolClass     SchoolClass  @relation(fields: [classId], references: [id], onDelete: Cascade)
  examId          String?
  exam            Exam?        @relation(fields: [examId], references: [id], onDelete: SetNull)
  title           String
  instructions    String?
  timeAllowedMins Int          @default(120)
  totalMarks      Int          @default(100)
  status          String       @default("TIDIED") // DRAFT | TIDIED | PUBLISHED | ARCHIVED
  // JSON array of ScannedExamQuestion:
  // { id, questionNumber, prompt, questionType: "MULTIPLE_CHOICE" | "STRUCTURED" | "ESSAY", options: string[], marks: number, confidencePct: number }
  questionsJson   String       @default("[]")
  rawScanUrl      String?
  // EE.6 — privacy tier for cross-school sharing:
  // PRIVATE | SCHOOL_ONLY | PUBLIC_SHARED
  privacyTier     String       @default("SCHOOL_ONLY")
  sharingApprovalStatus   String    @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  sharingRequestedById    String?
  sharingRequestedByName  String?
  sharingRequestedAt      DateTime?
  sharingDecidedById      String?
  sharingDecidedByName    String?
  sharingDecidedAt        DateTime?
  sharingDecisionNote     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([tenantId, subjectId])
  @@index([tenantId, classId])
  @@index([tenantId, status])
  @@index([privacyTier, sharingApprovalStatus])
}

// =============================================================================
// PART J.5 — Rubrics & Evidence foundation
// =============================================================================

// A configurable rubric definition that can be attached to assessment types,
// assessment plans, or competencies. Replaces temporary rubricJson structures
// with formal database definitions without duplicating exam/CBC grading.
model Rubric {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String   @default("GENERAL") // CBC | PROJECT | PRACTICAL | PORTFOLIO | COMPETENCY | GENERAL
  isArchived  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  levels RubricLevel[]

  @@unique([tenantId, name])
  @@index([tenantId, category])
  @@index([tenantId, isArchived])
}

// One level in a configurable rubric, e.g. Level 4 (Exceeding Expectation) with
// its specific descriptor and point/percentage range.
model RubricLevel {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rubricId   String
  rubric     Rubric   @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  level      Int // e.g. 1, 2, 3, 4, 5
  code       String // e.g. EE, ME, AE, BE or ADVANCED, PROFICIENT, BASIC
  label      String // e.g. Exceeding Expectation
  descriptor String? // Detailed rubric descriptor
  points     Float? // Optional points for this level
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, rubricId, level])
  @@unique([tenantId, rubricId, code])
  @@index([tenantId, rubricId])
}

// =============================================================================
// PART J.6 — Skills Passport foundation
// =============================================================================

// One rating/evidence point in a learner's Skills Passport. Tracks skill levels
// over time across academic, competency, talent, and leadership growth areas.
model SkillsPassportEntry {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skillArea      String // Leadership | Communication | Coding | Music | Sports | Creativity | custom
  ratingLevel    Int // 1..5 stars/levels
  evidenceSource String // ASSESSMENT | CLUB | PORTFOLIO | AWARD | OBSERVATION
  sourceId       String? // optional scalar link to future club, award, or portfolio item
  narrative      String? // Qualitative growth description
  evidenceDate   String // YYYY-MM-DD
  recordedById   String
  recordedByName String
  verified       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, studentId])
  @@index([tenantId, skillArea])
  @@index([tenantId, evidenceSource])
}

// =============================================================================
// PART J.7 — Student Portfolio System foundation
// =============================================================================

// One item in a student's digital portfolio: project, video, photo, art, coding
// work, certificate, teacher observation, or community activity. Uploads must
// use the encrypted Storage Vault path (StoredFile).
model PortfolioItem {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId        String
  student          Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title            String
  category         String // PROJECT | VIDEO | PHOTO | ART | CODING | CERTIFICATE | OBSERVATION | COMMUNITY
  description      String?
  storedFileId     String? // Link to encrypted StoredFile in Storage Vault
  fileUrl          String?
  fileName         String?
  fileSizeBytes    Int? // For media size controls and storage usage warnings
  externalLink     String? // e.g., GitHub repo or external video link
  status           String    @default("SUBMITTED") // DRAFT | SUBMITTED | APPROVED | REJECTED
  approvedById     String?
  approvedByName   String?
  approvedAt       DateTime?
  visibleToParents Boolean   @default(false)

  // Optional scalar links to existing/J modules
  competencyId String?
  subjectId    String?
  clubId       String?
  awardId      String?

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, studentId])
  @@index([tenantId, category])
  @@index([tenantId, status])
}

// =============================================================================
// PART J.8 — Learning Journey Timeline milestone pinning foundation
// =============================================================================

model LearnerJourneyPin {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sourceModule   String // EXAM | ASSESSMENT | ATTENDANCE | DISCIPLINE | COMPETENCY | SKILLS | PORTFOLIO | CERTIFICATE | SYSTEM
  sourceRecordId String?
  entryId        String // stable normalized learner-journey entry id
  note           String?
  visibility     String   @default("STAFF") // STAFF | PARENT_SAFE
  pinnedById     String
  pinnedByName   String
  pinnedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, studentId, entryId])
  @@index([tenantId, studentId])
  @@index([tenantId, sourceModule])
}

// PART J.10 — Senior School Pathway Management
// =============================================================================

model Pathway {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String // e.g. "STEM", "Creative Arts & Sports", "Social Sciences"
  code        String // e.g. "STEM", "ARTS"
  description String?
  capacity    Int? // Max students allowed in this pathway per cohort
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // P.1 (2026-07-02): official KICD taxonomy tagging. A school-created CUSTOM
  // pathway leaves both null — only pathways seeded via the official KICD
  // taxonomy (or explicitly tagged by a school) carry these, so existing
  // pathway rows/behaviour are completely unaffected.
  pathwayGroup String? // STEM | SOCIAL_SCIENCES | ARTS_SPORTS | null (custom)
  trackName    String? // e.g. "Pure Sciences", "Humanities & Business Studies", "Performing Arts"
  isOfficial   Boolean @default(false) // true = seeded from the real KICD taxonomy, not school-authored

  subjectRequirements PathwaySubjectRequirement[]
  studentPreferences  StudentPathwayPreference[]

  @@unique([tenantId, code])
}

model PathwaySubjectRequirement {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pathwayId   String
  pathway     Pathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  isCore      Boolean @default(true) // Core vs Elective in this pathway
  minScorePct Int? // e.g. Requires 70% in Math to join STEM

  @@unique([tenantId, pathwayId, subjectId])
}

model StudentPathwayPreference {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  pathwayId     String
  pathway       Pathway  @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  choiceOrder   Int      @default(1) // 1st choice, 2nd choice
  teacherNotes  String? // Recommendation/Notes from teacher/counselor
  isRecommended Boolean  @default(false)
  isAllocated   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, studentId, pathwayId])
}

// PART P.4 (2026-07-02) — Kenya CBE National Assessment Milestones.
// Real EXTERNAL KNEC/KICD national assessment results (KPSEA Grade 6, KJSEA
// Grade 9, Senior Secondary Assessment Grade 12 — plus the legacy KCPE/KCSE
// still relevant for the last 8-4-4 cohorts transitioning out), DISTINCT
// from the existing internal Exam/ExamResult model (school-set CATs/exams)
// and from ExamMaterialRecord (which only tracks application/registration
// LOGISTICS, never an actual received result). A record here is entered
// once a school receives/confirms the real KNEC result for a learner.
model StudentNationalAssessment {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

