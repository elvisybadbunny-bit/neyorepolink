  // If classId and subjectId are null, it's the GLOBAL school rule.
  classId   String?
  subjectId String?

  isTraditional Boolean @default(false) // If true, ignore weights and use standard average

  // JSON array mapping Assessment types to Weights
  // e.g., [{ "sourceType": "EXAM", "sourceId": "cat1_id", "weightPct": 25 }]
  weightingsJson String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, classId, subjectId])
}

// K.5 — Master term report card: one row per student per subject per term, the
// final aggregated figure produced by the background computation engine from the
// term's exams/CATs (weighted by TermAggregationRule when present, else simple
// average). A summary row (subjectId = null) holds the student's overall term
// mean + position. Idempotent via the unique key.
model MasterReportCard {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  termId    String
  classId   String
  studentId String
  subjectId String? // null = the overall/summary row for the student that term

  finalMark      Float // 0..100 aggregated subject mark, or overall mean on the summary row
  cbcLevel       Int? // 1..4 CBC band derived from finalMark (when curriculum engine on)
  letterGrade    String? // e.g. "A", "B+" for 8-4-4 style summaries
  rank           Int? // position within the class for this subject (or overall on summary row)
  outOf          Int? // class size used for the rank
  isTraditional  Boolean @default(false) // true = simple average used (no weighting rule)
  componentsJson String  @default("[]") // JSON breakdown of the sources + weights that produced finalMark

  computedAt DateTime @default(now())

  @@unique([tenantId, termId, studentId, subjectId])
  @@index([tenantId, termId, classId])
  @@index([tenantId, studentId])
}

