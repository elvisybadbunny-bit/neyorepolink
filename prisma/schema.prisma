model NeyoIdea {
  id               String   @id @default(cuid())
  title            String
  description      String?
  status           String   @default("IDEA") // IDEA | PLANNED | BUILDING | SHIPPED | PARKED
  priority         String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  ownerName        String?
  linkedFeatureKey String?
  createdById      String
  createdByName    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, priority])
  @@index([createdAt])
}

model NeyoBuildLog {
  id             String   @id @default(cuid())
  dateKey        String   @unique // YYYY-MM-DD, one official build log per day
  title          String
  shippedSummary String // concise public/internal summary of what shipped
  details        String? // longer Markdown/plain text
