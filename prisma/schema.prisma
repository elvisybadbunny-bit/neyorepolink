// PART M.1 — NEYO Referral Engine (repaired to true full-stack 2026-07-01)
// A real, auditable credit ledger against the referring/referred school's
// OWN NEYO subscription (SubscriptionPayment), NOT their students' school
// fee invoices (those are a different business entirely — B.7). Each row is
// one earned discount credit; `appliedToPaymentId` is set the moment it is
// actually deducted off a real upcoming NEYO subscription charge.
model ReferralCredit {
  id       String @id @default(cuid())
  tenantId String // the school that OWNS this credit (either side of a referral)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  role                String // "REFERRER" | "REFERRED" — which side of the referral earned this credit
  counterpartTenantId String // the other school in the referral pair (for the audit trail)
  counterpartName     String // denormalized school name at the time the credit was earned

  discountPct      Float // e.g. 0.05 = 5%, set by NEYO Ops referral rules at the time earned
  triggerPaymentId String @unique // the SubscriptionPayment whose PAID status triggered this credit (idempotency key)

  status             String    @default("PENDING") // PENDING | APPLIED | EXPIRED
  appliedToPaymentId String? // the SubscriptionPayment this credit was actually deducted from
  appliedAmountKes   Int? // the real KES amount deducted, once applied
  appliedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([counterpartTenantId])
}

// T.2 — NEYO-Ops-Configured Discount Campaigns. A real, time-boxed,
// centrally-configured promotional rule — genuinely distinct from the
// M.1 referral system (fixed 5%, tied to a referral code) and from J.23
// feature grants (a free premium feature, not a % off the base price).
// Founder-confirmed (2026-07-08): only ONE campaign may ever be ACTIVE
// platform-wide at a time (enforced in the service layer, not just here);
// a NEW_SIGNUPS discount is a real ONE-TIME reduction applied only to a
// school's FIRST subscription payment (never a permanently-lowered
// recurring price) — the price reverts to full from the second billing
// cycle onward, exactly like the pre-existing referral-credit pattern
// already does for referred schools.
model DiscountCampaign {
  id   String @id @default(cuid())
  name String // "August New-School Promo", "December 10% Off Everyone"

  appliesTo  String // "NEW_SIGNUPS" | "ALL_ACTIVE_SCHOOLS"
  percentOff Float // e.g. 0.20 = 20%; 1.0 = one fully-free billing cycle
  code       String? @unique // optional public promo code, one school may claim it once
  maxRedemptions Int? // null = unlimited; e.g. first 100 new schools
  redemptionCount Int @default(0)
  freeMonths Int @default(0) // currently 0 or 1; represented as 100% off first payment

  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(true) // NEYO Ops can end a campaign early without deleting its real history

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([appliesTo, active])
  @@index([startDate, endDate])
}

// T.6 — Influencer/Promoter Marketing Codes. A real INDIVIDUAL (not a
// school) holds a unique code; a school using it gets a real discount, and
// the influencer separately earns their own agreed one-time commission
// per school signed (founder-confirmed 2026-07-08: one-time, mirroring the
// existing referral reward's one-time-on-first-payment trigger — never an
// ongoing recurring percentage). Founder-confirmed: an influencer code is
// MUTUALLY EXCLUSIVE with T.2's own discount campaigns — a school uses one
// or the other, never both, preventing an unintended compounded discount.
model InfluencerCode {
  id   String @id @default(cuid())
  code String @unique // e.g. "NEYO-JUMA01"

  personName  String
  personPhone String?
  personEmail String?

  discountPct   Float // real % off the school's first term when this code is used
  commissionKes Int // real flat one-time KES NEYO owes the influencer per school signed

  active Boolean @default(true) // NEYO Ops can retire a code without deleting its real earning history

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schoolsUsingCode Tenant[]
  commissions      InfluencerCommission[]

  @@index([active])
}

// T.6 — one real payable row per school an influencer brought in. NEYO owes
// the influencer this exact real amount once the referred school's first
// subscription payment lands PAID; NEYO Ops marks it PAID out (settled)
// once actually paid to the influencer, outside NEYO — this is a real,
// simple "amount owed, amount paid, when" ledger, not full payroll-grade.
model InfluencerCommission {
  id               String         @id @default(cuid())
  influencerCodeId String
  influencerCode   InfluencerCode @relation(fields: [influencerCodeId], references: [id], onDelete: Cascade)

  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schoolName String // denormalized at the time earned

  amountKes Int
  status    String    @default("OWED") // OWED | PAID
  paidAt    DateTime?
  paidNote  String? // e.g. real M-Pesa ref / bank transfer reference NEYO Ops used to pay the influencer

  createdAt DateTime @default(now())

  @@unique([influencerCodeId, tenantId]) // one real commission per school per influencer code (never double-earned)
  @@index([status])
}

// T.14 — Multi-Child Payment Splitting. A real ONE-STK-push payment that
// must land across MULTIPLE children's real open invoices needs a real
// record of exactly how it was allocated BEFORE the M-Pesa callback lands,
// so the PAID callback knows how to split the one real incoming amount —
// never a guess, always the exact real plan the parent/staff member chose
// at STK-push time. `strategy` mirrors the founder-confirmed real rounding
// rule: on SPLIT_EQUALLY, any 1-2 KES rounding remainder that doesn't
// divide evenly goes to whichever child currently has the LARGEST real
// remaining balance — computed once, stored here, never recomputed later
// with possibly-stale balances.
model FamilyPaymentSplitPlan {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  paymentId      String @unique // the real Payment (STK push) this plan describes
  initiatedById  String
  strategy       String // "ONE_CHILD" | "SPLIT_EQUALLY"
  totalAmountKes Int
  status         String @default("PENDING") // PENDING | APPLIED (applied once the real payment lands PAID)

  items     FamilyPaymentSplitItem[]
  createdAt DateTime                 @default(now())
  appliedAt DateTime?

  @@index([tenantId, status])
}

model FamilyPaymentSplitItem {
  id          String                 @id @default(cuid())
  planId      String
  plan        FamilyPaymentSplitPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  studentId   String
  studentName String // denormalized at plan-creation time
  invoiceId   String
  amountKes   Int // the exact real whole-KES amount this child's invoice receives — never a decimal

  @@index([planId])
}

// PART K.16 — KNEC Document Aggregation
// =============================================================================

model KnecExportBatch {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name   String // e.g. "2026 KCSE Candidates Batch"
  status String @default("DRAFT") // DRAFT | EXPORTED

  targetClassId  String? // The specific class/stream this targets
  documentLabels String // JSON Array of required labels e.g. ["Birth Certificate", "KNEC Registration Form"]

  // A snapshot payload containing the generated zip/pdf URL if exported
  exportUrl String?

  createdById   String
  createdByName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// =============================================================================
// PART M.5 — Bundi Handwritten Import (founder-controlled premium import path)
// =============================================================================
// A SEPARATE, gated, manual-assist path for schools with handwritten or badly
// structured paper registers — never a dependency of the standard CSV/Excel
// import engine (M.4), which must keep working with zero AI involvement.
// Access is unlock-code (or standing-approval) gated by NEYO Ops, every
// session tracks real provider/token/cost usage, and the school describes
// their own register columns before any AI mapping happens.

// One company-issued unlock code, minted by NEYO Ops. Per-session (single
// use) by default, matching the founder's chosen model; ALSO supports a
// standing per-school approval (maxUses = null = unlimited until revoked)
// for schools NEYO Ops trusts with ongoing access.
model BundiImportUnlockCode {
  id           String    @id @default(cuid())
  code         String    @unique // company-issued, shown once, e.g. "BUNDI-7F3A9C"
  tenantId     String? // null = any school may redeem (rare/manual); usually school-specific
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maxUses      Int? // null = unlimited (standing approval) — 1 = classic one-time code
  usedCount    Int       @default(0)
  expiresAt    DateTime? // null = no expiry (still bounded by maxUses)
  revokedAt    DateTime?
  note         String? // NEYO Ops internal note, e.g. "Pilot: Karibu High, June 2026"
  issuedById   String // NEYO Ops SUPER_ADMIN who minted it
  issuedByName String
  createdAt    DateTime  @default(now())

  sessions BundiImportSession[]

  @@index([tenantId])
}

// A school's own description of their register's columns/fields BEFORE any
// AI mapping happens (checklist requirement: "school can describe their own
// fields to Bundi"). One saved template per tenant PER DOMAIN (Student/Staff/
// Library each keep their own field description) — editable each session.
model BundiFieldTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // N.1 — which real NEYO import this template feeds: STUDENT | STAFF | LIBRARY.
  // Kept as a plain string (not an enum) to match this codebase's existing
  // convention for domain/status fields, and so a school can adopt a NEW
  // Bundi domain in the future without a schema migration.
  domain      String   @default("STUDENT")
  // JSON array of {label, description, mapsTo} the school wrote themselves,
  // e.g. [{label:"Adm No (old book)", description:"Written top-left of each row", mapsTo:"legacyAdmissionNo"}]
  fieldsJson  String
  updatedById String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([tenantId, domain])
}

// One handwritten-import attempt: upload -> (AI-assisted, cost-tracked)
// extraction -> school reviews/edits every row -> commit through the SAME
// commitImport() used by the standard engine (never a second, weaker write
// path). Tracks real provider/token/cost so NEYO Ops has full visibility.
model BundiImportSession {
  id           String                 @id @default(cuid())
  tenantId     String
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // N.1 (2026-07-02) — unlock codes now gate ONLY the legacy/manual "premium"
  // provider path (OPENAI_VISION/ANTHROPIC_VISION, still real but costlier).
  // "Bundi Intelligent" (local OCR + rules, escalating to the cheap Google
  // Vision API only when genuinely needed) is open to every school with NO
  // code required — per the founder's explicit "this one should not require
  // any code to unlock... make it usable" instruction, now that Ops has
  // real evidence the confidence-based pipeline keeps AI usage tiny. NULL
  // here means "no code was used" (an Intelligent session), never an
  // accidental bypass of the legacy path, which still always requires one.
  unlockCodeId String?
  unlockCode   BundiImportUnlockCode? @relation(fields: [unlockCodeId], references: [id])

  // N.1 — which real extraction path this session used: BUNDI_INTELLIGENT
  // (open, local-OCR-first, no code) or LEGACY_PROVIDER (the original
  // code-gated OpenAI/Anthropic/Google Vision-as-sole-step path).
  pipeline String @default("BUNDI_INTELLIGENT")

  // N.1 (2026-07-02) — "Bundi Intelligent" multi-domain import. Previously
  // hardcoded to students only (studentImportId was the only outcome link);
  // now a session targets exactly one of STUDENT | STAFF | LIBRARY, each
  // committing through that domain's own REAL standard import engine —
  // never a second, weaker write path, matching the original M.5 contract
  // extended across every domain instead of duplicating it per-domain.
  domain String @default("STUDENT")

  // N.1 — the school's own plain-language context for this specific batch,
  // e.g. "This is Grade 1's admission register" or "This is the Library
  // accession ledger, 2019-2021". Feeds DIRECTLY into the Bundi Intelligent
  // rules stage (e.g. pre-filtering valid class names to just Grade 1
  // streams) so the founder's "if one says this is grade one" ask is a real
  // signal the pipeline consumes, not just a label shown back to the user.
  contextNote String?

  status String @default("UPLOADED") // UPLOADED | EXTRACTING | REVIEW | COMMITTED | FAILED | CANCELLED

  fileKey   String // StoredFile key of the uploaded scan/photo (A.9, encrypted at rest)
  fileName  String
  pageCount Int    @default(1)

  // N.1 — "Bundi Intelligent" pipeline stage tracking. A session that never
  // needed AI (every field confident enough after OCR + rules) has
  // aiInvoked:false and near-zero cost — this is the real, queryable proof
  // the confidence-based cost-cutting pipeline is actually working, not
  // just a design doc.
  ocrConfidenceAvgPct Int? // average OCR confidence across all extracted cells, 0-100
  fieldsTotal         Int     @default(0)
  fieldsAiEscalated   Int     @default(0) // how many cells were actually low-confidence enough to need AI
  aiInvoked           Boolean @default(false)
  templateMatchId     String? // set when a previously-learned BundiDocumentTemplate layout was reused (skips re-detection)

  provider     String? // e.g. "openai_vision" — set once NEYO Ops configures a real provider
  model        String? // e.g. "gpt-4o" — the exact model used, for cost auditing
  promptTokens Int     @default(0)
  outputTokens Int     @default(0)
  costUsd      Float   @default(0) // real computed cost from the provider's own published rate
  costKes      Float   @default(0) // converted at the rate configured in NEYO Ops

  extractedRowsJson String? // raw AI output before school review: [{cells:[...], confidence}]
  reviewedRowsJson  String? // school-edited rows, ready for commitImport()
  errorMessage      String?

  studentImportId String? // set once committed (domain=STUDENT), links to the REAL StudentImport history row
  staffImportId   String? // set once committed (domain=STAFF), links to the REAL StaffImport history row
  libraryImportId String? // set once committed (domain=LIBRARY), links to the REAL LibraryImport history row

  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, domain])
  @@index([unlockCodeId])
}

// N.1 — "Bundi Intelligent" learned corrections. When a school fixes an
// OCR/AI mistake during review, the (domain, fieldLabel, wrongText,
// correctText) pattern is remembered so future sessions apply it as a FREE
// deterministic rule before ever reaching AI — the founder's "learn from
// corrections" cost-cutting requirement, implemented as real per-tenant
// (never cross-tenant — one school's handwriting quirks are not another's)
// stored patterns, not a vague promise.
model BundiLearnedCorrection {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain      String // STUDENT | STAFF | LIBRARY
  fieldLabel  String // the school's own column label this correction applies to
  wrongText   String // what OCR/AI produced
  correctText String // what the school corrected it to
  timesSeen   Int      @default(1) // how many times this exact correction has recurred (confidence signal)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, domain, fieldLabel, wrongText])
  @@index([tenantId, domain])
}

// N.1 — "Bundi Intelligent" template memoization. When a register's column
// LAYOUT (not its data) has been seen before for a tenant+domain, future
// scans of the same physical form skip AI-assisted table/field detection
// entirely and reuse the known field positions — the founder's "cache
// repeated work" cost-cutting requirement. A layout signature is a simple,
// real, deterministic fingerprint of the detected column count + header
// text (never an AI-generated guess), so matching is fast and free.
model BundiDocumentTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain          String // STUDENT | STAFF | LIBRARY
  layoutSignature String // deterministic fingerprint, e.g. "5col:admno|name|class|dob|guardian"
  label           String // human label the school can give it, e.g. "Grade 1 Admission Form v3"
  fieldsJson      String // the learned {label, mapsTo} column layout for this signature
  timesUsed       Int      @default(1)
  lastUsedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([tenantId, domain, layoutSignature])
  @@index([tenantId, domain])
}

// N.1 — real bulk import history for Staff, mirroring the existing
// StudentImport history model (M.1) so NEYO Ops/school leadership has the
// exact same audit trail for staff bulk imports that already existed for
// students — previously importStaffBatch() recorded only an AuditLog entry
// with no queryable import-run history of its own.
model StaffImport {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileName      String?
  source        String // "csv" | "xlsx" | "paste" | "bundi"
  totalRows     Int
  createdRows   Int
  failedRows    Int
  errorRows     String? // JSON [{row, message}] (null when none)
  createdById   String
  createdByName String
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
}

// N.1 — real bulk import history for the Library catalog (B.15). The
// Library previously had ZERO bulk-import mechanism of any kind (standard
// or Bundi) — a genuine, previously-unbuilt gap identified during this
// session's audit, not a pre-existing feature being extended.
model LibraryImport {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileName      String?
  source        String // "csv" | "xlsx" | "paste" | "bundi"
  totalRows     Int
  createdRows   Int
  updatedRows   Int      @default(0) // existing ISBN matched -> copiesTotal increased, not duplicated
  failedRows    Int
  errorRows     String? // JSON [{row, message}] (null when none)
  createdById   String
  createdByName String
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
}

// AA.2 — real bulk import history for an existing school's teacher-
// subject-class allocation (founder-requested 2026-07-12, onboarding
// scenario: "if a school enrolls into neyo and they already have their
// teachers subject already allocated subjects how can an import that can
// read that be entered"). Mirrors the exact real StaffImport/LibraryImport
// pattern — a real per-run history row, never silently mutating without a
// trace. `createdNeeds`/`matchedNeeds` distinguish a genuinely NEW
// ClassSubjectNeed row from one that already existed and was simply
// re-confirmed/updated (a school re-importing a corrected file should not
// see every row reported as "created" a second time).
model TeacherAllocationImport {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileName       String?
  source         String // "csv" | "xlsx" | "paste" | "bundi"
  totalRows      Int
  createdNeeds   Int // real NEW ClassSubjectNeed rows created
  matchedNeeds   Int // real EXISTING ClassSubjectNeed rows matched/updated
  createdTeachers Int // real NEW User+TeacherSubject rows created for a teacher name not already in the school
  failedRows     Int
  errorRows      String? // JSON [{row, message}] (null when none)
  createdById    String
  createdByName  String
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
}

// R.6 — School Activities / Trips (founder-requested "Form 4 trip" style
// optional fee-collection tracking). A real, separate model from B.7 fee
// invoicing/fee structures on purpose: an activity is OPTIONAL — a student
// who neither pays nor gets an explicit waiver owes NOTHING, ever, ever
// showing up as a fee balance. Only two real events ever create a real
// Invoice for a student: (1) a real payment is actually collected (invoice
// created already fully paid, zero balance), or (2) staff explicitly
// records a waiver/promise-to-pay for a student who is going without having
// paid yet — from THAT moment it behaves exactly like any other real fee
// balance (arrears, reminders, promise-to-pay), per the founder's own exact
// specification. Creating the activity for one or more classes immediately
// builds the full roster of every real student in those classes (matching
// the founder's "if a school has a trip for grade 1 to grade 3, all of them
// are added in the list") — participation membership is the roster ITSELF,
// never a separate opt-in step, since paying is what actually confirms
// going.
model SchoolActivity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String // "Form 4 Mombasa Trip"
  description String?
  amountKes   Int // the real per-student cost/contribution amount
  year        Int
  term        Int
  eventDate   String? // YYYY-MM-DD, optional (some activities are ongoing)
  archived    Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classes      SchoolActivityClass[]
  participants ActivityParticipant[]

  @@index([tenantId])
  @@index([tenantId, year, term])
}

// Which real classes this activity's roster is drawn from (a real school
// can run one trip across several classes/grades at once).
model SchoolActivityClass {
  id         String         @id @default(cuid())
  tenantId   String
  activityId String
  activity   SchoolActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  classId    String

  @@unique([activityId, classId])
  @@index([tenantId])
}

// One real row per real student on the roster. `status` is the real, honest
// truth of where that student stands — never inferred solely from whether
// an Invoice happens to exist, since most participants will genuinely have
// NO invoice at all (the whole point of this feature).
//   NOT_PAID   — on the roster, nothing collected, no waiver — owes NOTHING.
//   PAID       — a real payment was collected; invoiceId is set and that
//                invoice is fully paid (zero balance) the moment it's created.
//   WAIVED     — staff explicitly recorded "going without paying yet" for a
//                real parent request; invoiceId is set with a REAL open
//                balance from that moment on, behaving exactly like any
//                other fee invoice (arrears, reminders, promise-to-pay).
model ActivityParticipant {
  id           String         @id @default(cuid())
  tenantId     String
  activityId   String
  activity     SchoolActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentId    String
  status       String         @default("NOT_PAID") // NOT_PAID | PAID | WAIVED
  invoiceId    String? // set only for PAID or WAIVED — NEVER for NOT_PAID
  waivedReason String? // e.g. "Parent asked to pay after half-term"
  waivedById   String?
  waivedAt     DateTime?
  updatedAt    DateTime       @updatedAt

  @@unique([activityId, studentId])
  @@index([tenantId])
  @@index([tenantId, status])
}

// =============================================================================
// PART Y.1 — NEYO Pathway Guide (Career & Subject Selection Guidance)
// =============================================================================
// Founder request 2026-07-09: build a NEYO version of the EduPoa "Career
// Compass" concept — a real interest/values questionnaire that recommends a
// CBE Senior School pathway + subject combination, PLUS a real KUCCPS
// cluster/course reference so a student can see which real degree courses
// their recommended subject combination genuinely relates to. Deliberately
// NO KCSE-style letter-grade entry anywhere in this feature (founder
// correction 2026-07-09: "this is cbe ... they use BE AE EE ME IN 8 POINTS
// so leave the adding of grade idea out") — CBE learners are graded on the
// 4-point CBC rubric, not KCSE A-E letters, and a real Grade 9/Senior School
// learner has no KCSE grades to enter anyway (they will sit the future
// Senior Secondary Assessment at Grade 12). Matching is purely
// SUBJECT-COMBINATION based: does the learner's recommended/chosen elective
// combination contain a subject that could satisfy each of a KUCCPS
// cluster's real subject-requirement slots. Must (a) work for logged-in NEYO
// school students/parents for FREE (reuses existing J.10/P.1 pathway + J.18
// career-discovery machinery), AND (b) be reachable by a member of the
// public with NO NEYO account at all, gated behind a small M-Pesa-paid
// unlock for the FULL matched-course list (a free "glimpse" of a few
// clusters stays free even for outsiders). Two independent Founder-Ops flags
// control visibility (in-app vs public), both default ON, switchable at any
// moment without a deploy — reuses the existing PlatformFlag mechanism
// (G.22 family), never a new ad-hoc boolean.
//
// Real official KUCCPS data (20 degree-programme clusters, actual 2025/2026
// subject-requirement rules, real subject groups I-V per the Ministry of
// Education/KUCCPS public guidance) is seeded as data via
// `KuccpsCluster`/`KuccpsCourse` — NOT hardcoded in UI copy — so NEYO Ops can
// correct/update it as KUCCPS revises requirements each intake year, exactly
// like every other NEYO reference dataset. The real per-course minimum-grade
// info is kept as INFORMATIONAL "grades to aim for" display data (shown to
// help a learner understand what a course will require once they DO sit
// KCSE-equivalent exams) — never required as user input.

// One of the 20 real KUCCPS degree-programme clusters (e.g. "Cluster 13 —
// Medicine, Health, Veterinary Medicine & Related"). Company-wide reference
// data — NOT tenant-owned (same family as PricingCatalog/CurriculumLibrary).
model KuccpsCluster {
  id               String         @id @default(cuid())
  number           Int // 1-20, the official KUCCPS cluster number
  name             String // "Medicine, Health, Veterinary Medicine & Related"
  description      String?
  // JSON array of up to 4 real subject-requirement rules for THIS cluster,
  // e.g. [{"slot":1,"anyOf":["ENG","KIS"]},{"slot":2,"anyOf":["MAT"]},
  // {"slot":3,"anyOf":["BIO"]},{"slot":4,"anyOf":["CHE"]}] — "anyOf" lets a
  // slot legitimately accept either of two subjects (e.g. Eng/Kis, or
  // Math/Physics) exactly as KUCCPS's own official tables read.
  subjectRulesJson String
  displayOrder     Int            @default(0)
  archived         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courses          KuccpsCourse[]

  @@unique([number])
}

// One real degree programme within a cluster (e.g. "Bachelor of Medicine and
// Surgery (MBChB)"). Company-wide reference data.
model KuccpsCourse {
  id            String        @id @default(cuid())
  clusterId     String
  cluster       KuccpsCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  name          String
  // INFORMATIONAL ONLY — real minimum grade "to aim for" per cluster-subject
  // slot, shown so a learner understands what a course will eventually
  // require once real KCSE-equivalent exams are sat. Never collected as
  // input from the learner (this feature has no grade-entry step).
  minGradesJson String
  minMeanGrade  String // informational overall mean grade to aim for, e.g. "C+"
  typicalCutoff Float? // typical/most-recent published cluster-point cutoff, e.g. 42.5 (informational, not a guarantee)
  careerAreas   String        @default("[]") // JSON array of related CAREER_AREAS keys (links back to existing J.18 taxonomy)
  archived      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clusterId])
}

// One real Pathway Guide session — created the moment ANY user (logged-in
// NEYO student/parent OR a public outsider with no account) starts the
// questionnaire. `tenantId`/`studentId` are null for a genuine public
// outsider session (deliberately NOT in TENANT_OWNED_MODELS, same reasoning
// as SchoolQuoteRequest — queried directly via `db`, never `tenantDb()`,
// since a public session has no tenant context at all).
model PathwayGuideSession {
  id                      String               @id @default(cuid())
  tenantId                String? // set only when a real logged-in NEYO user ran this
  studentId               String? // set only when linked to a real Student profile
  isPublic                Boolean              @default(false) // true = an outsider with no NEYO account
  fullName                String? // outsider's own typed name (never "John Doe" placeholder copy)
  phone                   String? // normalized +254 phone, for outsider STK/unlock
  // The 4-pillar questionnaire answers: interests, skills, values, aspirations.
  interestsJson           String               @default("[]")
  skillsJson              String               @default("[]")
  valuesJson              String               @default("[]")
  aspirationsJson         String               @default("[]")
  // Computed recommendation (rule-based, matches existing J.18 engine style —
  // never dependent on Bundi/any AI provider).
  recommendedGroup        String? // "STEM" | "SOCIAL_SCIENCES" | "ARTS_SPORTS"
  recommendedTrack        String? // e.g. "Pure Sciences"
  recommendedSubjectsJson String               @default("[]") // JSON array of {name, code} recommended real subjects/electives
  careerAreasJson         String               @default("[]") // JSON array of matched CAREER_AREAS
  // Paid unlock (public outsiders only; always free/pre-unlocked for a real
  // logged-in NEYO student/parent session).
  unlocked                Boolean              @default(false)
  unlockedAt              DateTime?
  paymentId               String?              @unique
  payment                 PathwayGuidePayment? @relation(fields: [paymentId], references: [id])
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([tenantId])
  @@index([studentId])
  @@index([phone])
}

// A real, single, one-time small M-Pesa payment made by a public outsider to
// unlock their full matched-KUCCPS-course report for ONE session (single-use
// per founder's own decision — a fresh quiz run needs a fresh payment).
// Mirrors the existing SubscriptionPayment/central-billing STK pattern
// exactly (same DarajaProvider/MockProvider, same PENDING->PAID lifecycle).
model PathwayGuidePayment {
  id                String               @id @default(cuid())
  phone             String
  amountKes         Int // the real editable-in-Ops fee actually charged (KES)
  status            String               @default("PENDING") // PENDING | PAID | FAILED
  checkoutRequestId String?              @unique
  mpesaRef          String?
  resultDesc        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  session           PathwayGuideSession?

  @@index([phone])
  @@index([status])
}

// =============================================================================
// PART Y.2 — NEYO Team & Access (a real Founder page to create/manage NEYO
// company accounts: NEYO Support, NEYO Operations, and the Founder)
// =============================================================================
// Founder request 2026-07-09: "have a founder page for founders account that
// can give the neyo support and any other neyo role to access but since am
// alone for now me the founder can access everything in the system." Real,
// distinct company role tiers now exist (`FOUNDER`/`NEYO_OPS`/`NEYO_SUPPORT`
// in `src/lib/core/roles.ts`, alongside the legacy `SUPER_ADMIN` kept for
// backward compatibility). This model tracks WHICH specific extra
// permissions a real NEYO_OPS/NEYO_SUPPORT account has been individually
// granted (founder's own answer: "option 3... you pick permissions
// individually per account") — a FOUNDER/SUPER_ADMIN account ignores this
// table entirely (unrestricted by definition, per `can()`'s own real logic).
//
// Deliberately NOT tenant-owned (same reasoning as `SchoolQuoteRequest`/
// `PathwayGuideSession` for a public session — a NEYO company account's
// permissions are a COMPANY-level concept, not scoped to any one school's
// tenant, even though the underlying `User` row is still tenant-owned for
// storage purposes, per the pre-existing A.2.9 pattern).
model NeyoTeamMember {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // JSON array of extra Permission strings individually granted on top of
  // whatever the account's base role (`NEYO_OPS`/`NEYO_SUPPORT`) already
  // gives via the real permission matrix — e.g. a NEYO_SUPPORT account can
  // be individually granted "platform.founder_ops" read-only areas without
  // becoming a full NEYO_OPS account. Empty array = base role only.
  extraPermissionsJson String @default("[]")

  // A short, real, human-readable note the Founder leaves for themselves
  // about why this account exists / what it's for (never shown to the
  // account holder themselves).
  note String?

