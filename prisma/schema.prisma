// ---------------------------------------------------------------------------
// PART F.1 — Internal NEYO Founder Operations (dogfooding on neyo.co.ke).
// Company-level records, deliberately NOT tenant-owned. These power NEYO's own
// operating rhythm: build log, weekly metrics, founder meetings, interviews,
// investor/board updates and annual impact reporting. Access is SUPER_ADMIN in
// the service/API layer that follows.
// ---------------------------------------------------------------------------

model NeyoIntegrationSecret {
  id         String   @id @default(cuid())
  key        String   @unique
  provider   String
  label      String
  ciphertext String
  iv         String
  tag        String
  masked     String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([provider])
}

model NeyoCustomerThread {
  id            String   @id @default(cuid())
  tenantId      String?
  schoolName    String
  contactUserId String?
  contactName   String
  contactRole   String?
  contactEmail  String?
  contactPhone  String?
  subject       String
  status        String   @default("OPEN") // OPEN | WAITING_ON_NEYO | WAITING_ON_CUSTOMER | RESOLVED | CLOSED
  priority      String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  source        String   @default("SCHOOL_OS") // SCHOOL_OS | NEYO_OPS | SMS | EMAIL | WHATSAPP | CALL
