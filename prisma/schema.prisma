  photoUrl     String?
  sortOrder    Int     @default(0)
  published    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, published, sortOrder])
}

model PublicSiteGalleryImage {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title     String
  caption   String?
  imageUrl  String // A.9 stored image URL
  category  String  @default("School life")
  sortOrder Int     @default(0)
  published Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, published, sortOrder])
  @@index([tenantId, category])
}

model PublicSiteActivity {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String
  iconName    String? // lucide icon key used by the UI, safe fallback if unknown
  sortOrder   Int     @default(0)
  published   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, published, sortOrder])
}

model NewsPost {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title        String
  slug         String // e.g. "term-3-closing-announcement"
  excerpt      String?
  content      String // markdown / text content of the post
  imageFileUrl String? // optional header image URL
  status       String    @default("DRAFT") // DRAFT | PUBLISHED
  featured     Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, status, publishedAt])
