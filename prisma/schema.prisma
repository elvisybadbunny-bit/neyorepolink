  heroHeadline      String  @default("Nurturing Excellence & Character")
  heroSubheading    String? // factual school-specific introduction
  heroImageUrl      String? // A.9 stored image for the landing hero
  history           String? // school story / history
  whyChooseUs       String? // JSON array of short proof points
  mapEmbedUrl       String? // optional Google/OSM embed URL, entered by the school
  seoTitle          String?
  seoDescription    String?
  ogImageUrl        String?
  primaryCtaLabel   String  @default("Begin Application")
  secondaryCtaLabel String  @default("Parent Portal")

