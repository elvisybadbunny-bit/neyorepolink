  grade           String        // e.g. "Grade 7", "Grade 8", "Grade 9"
  prompt          String
  questionType    String        @default("MULTIPLE_CHOICE") // MULTIPLE_CHOICE | SHORT_ANSWER | TRUE_FALSE
