model TimetableConfig {
  id                 String  @id @default(cuid())
  tenantId           String
  tenant             Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId            String  @unique
  periodsPerDay      Int     @default(8)
  freePeriodsPerWeek Int     @default(4)
  coCurricularCount  Int     @default(2)
  coCurricularName   String  @default("Games")
  schoolDayStartTime String  @default("08:00") // HH:MM — school day/assembly start
  assemblyBeforeLessonsLabel String? // Optional assembly/advisory before Period 1
  assemblyBeforeLessonsMins  Int     @default(0)
  saturdayStartTime  String  @default("08:00") // HH:MM — Saturday/remedial/prep start
  saturdayEndTime    String  @default("12:40") // HH:MM — Saturday short-day end
  lessonDurationMins Int     @default(40)
  shortBreakStart    Int     @default(2) // after Period 2
  shortBreakMins     Int     @default(15)
  shortBreak2Start   Int? // Optional 2nd short break (e.g. afternoon)
  shortBreak2Mins    Int?
  gamesPeriodTarget  String? // JSON array of class IDs targeted for specific PE/Games
  saturdayEarlyHome  Boolean @default(true) // Automatically schedule "HOME" blocks for free periods

  longBreakStart       Int     @default(4) // after Period 4
  longBreakMins        Int     @default(30)
  lunchStart           Int     @default(6) // after Period 6
  lunchMins            Int     @default(60)
  hasRemedials         Boolean @default(false)
  hasPreps             Boolean @default(false)
  lunchShift           Int     @default(1)
  // CC.1 — real, direct "lunch is after period N" choice, replacing the
  // rigid Shift 1/2/3/4 (period 5/6/7/8 only) model with genuine
  // flexibility: a school picks ANY real period number lunch should
  // follow, matching their own real schedule (e.g. "our 10-slot day —
  // Form 1&2 eat after period 6, Form 3&4 eat after period 7"). Nullable
  // and deliberately backward-compatible: null (the default, and every
  // already-configured real school's current value) means "keep using
  // the existing lunchShift enum exactly as before" — a school's
  // existing real timetable is never silently changed by this addition.
  // Once a school explicitly sets this (via the redesigned Schedule
  // Rules UI), it always wins over lunchShift for that class.
  lunchAfterPeriod     Int?
  hasSaturday          Boolean @default(true) // class-level Saturday toggle
  // P.5 — how many real timetable periods exist on Saturday for this class
  // (independent of periodsPerDay, since Saturday is normally a short day).
  // The main whole-school solver treats Saturday as a first-class day within
  // the SAME conflict-checked pass as Mon-Fri whenever hasSaturday is true,
  // instead of the separate bolt-on Bulk/Fair Saturday tools existing before.
  saturdayPeriodsCount Int     @default(4)
}

// I.97 — syllabus coverage / scope tracking per class + subject + term.

