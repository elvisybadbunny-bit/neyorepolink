// Idea 7: KNEC / KJSEA National Candidate Index Studio (`By Admission or Exam Merit`)
model KnecCandidateRegistration {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation("KnecCandidateRegistrations", fields: [tenantId], references: [id], onDelete: Cascade)
  studentId        String
  studentName      String
  admissionNo      String
  knecCentreCode   String   // e.g. "20401001"
  candidateType    String   // KCSE | KJSEA
  indexNumber      String   // e.g. "20401001/001"
  photo300x300Url  String?
  placementExamId  String?  // when ordered by exam merit
  meritRank        Int?     // rank in the placement exam
  status           String   @default("REGISTERED") // REGISTERED | EXPORTED
  createdAt        DateTime @default(now())

  // REAL BUG FIX (2026-07-18): the default Prisma-generated names for
  // these two indexes are 64 and 65 characters — over Postgres' hard
  // 63-byte identifier limit. Postgres silently TRUNCATES an over-long
  // identifier at creation time rather than erroring, so the index this
  // model believed it owned never actually existed under the name Prisma
  // itself expected — confirmed live: a later `prisma migrate diff`-
  // generated migration tried `ALTER INDEX "...instance..." RENAME TO
  // "...idx"` and failed with `relation ... does not exist` because the
  // "long" name was never the real one Postgres stored. Fixed with an
  // explicit short `map` name on each, which is what Prisma should have
  // generated in the first place for a model name this long.
  @@unique([tenantId, knecCentreCode, indexNumber], map: "KnecCandidateRegistration_tenant_centre_index_key")
  @@index([tenantId, candidateType, indexNumber], map: "KnecCandidateRegistration_tenant_type_index_idx")
}

