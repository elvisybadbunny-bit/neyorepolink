// U.3 — Founder Morning Dashboard + "Ask Bundi" (Founder AI) + Product
// Analytics + Compliance (founder-requested completion of U.3, 2026-07-09).
// =============================================================================

// U.3 — a real, logged Q&A record for the internal "Ask Bundi" (Founder)
// layer. NEVER customer-facing; this is Founder/NEYO_OPS-only tooling.
// `contextJson` is the REAL, live company-data snapshot assembled from
// already-real NEYO data (revenue/MRR, churn-risk schools, open support
// queues, module adoption) BEFORE any provider call — so the founder always
// gets a genuine, real-numbers answer even while `status` is NOT_CONFIGURED
// (the raw context is shown honestly), and the SAME context is what would be
// handed to a real LLM as retrieval context once a provider key exists.
// Deliberately NOT tenant-owned (a company-level concept, same reasoning as
// NeyoTeamMember above) — queried directly via `db`.
model FounderAiQuery {
  id       String @id @default(cuid())
  question String

  // ANSWERED | NOT_CONFIGURED | ERROR — real, honest, never fabricated.
  status String @default("NOT_CONFIGURED")

  // The real synthesized company-data snapshot fed as context (JSON) — always
  // populated from real live data, independent of whether a provider exists.
  contextJson String

  // Set only when status = ANSWERED (a real provider call succeeded).
  answer String?

  provider      String? // NONE | OPENAI | ANTHROPIC | GOOGLE
  model         String?
  promptTokens  Int?
  outputTokens  Int?
  costUsd       Float?
  costKes       Int?
  errorMessage  String?

  askedById   String
  askedByName String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([askedById])
}

// U.3 — a real, centrally-visible compliance queue: every school's real
// data-export event (auto-logged the moment `exportTenantData` runs) AND a
// real, explicit "request account/data deletion" ask a school can submit
// (deliberately NEVER a silent self-service delete — deleting a WHOLE
// school's real records is always a human-reviewed Founder/NEYO_OPS decision,
// per the KE Data Protection Act's own real accountability requirement).
// Deliberately NOT tenant-owned (NEYO-Ops-wide visibility is the entire
// point) even though every row records a real originating tenant.
model ComplianceRequest {
  id             String  @id @default(cuid())
  tenantId       String
  tenantName     String // denormalized for a fast NEYO Ops list without a join per row
  kind           String // EXPORT_DATA | DELETE_ACCOUNT
  status         String  @default("PENDING") // PENDING | ACKNOWLEDGED | COMPLETED | DECLINED
  note           String?

  requestedById   String
  requestedByName String
  requestedByRole String

  resolvedById     String?
  resolvedByName   String?
  resolutionNote   String?
  resolvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([kind])
}

// =============================================================================
// U.2 — A Genuine Unit-Economics Dashboard (Revenue/Cost/Margin per School,
// per Student, per SMS, CAC, LTV, MRR) — founder-requested completion,
