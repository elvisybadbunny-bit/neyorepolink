  masterSchoolDiaryEvents      MasterSchoolDiaryEvent[] @relation("MasterSchoolDiaryEvents")

  @@index([osKey])
  gradingScale GradingScale?

}

// B.9 extended staff record (User holds login/role; this holds HR facts).
model StaffProfile {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId           String   @unique
  tscNumber        String? // Teachers Service Commission no.
  nationalId       String?
  kraPin           String?
  nssfNo           String? // NSSF statutory number
  nhifNo           String? // SHIF / NHIF statutory number
  qualifications   String? // "B.Ed (Maths/Physics), Kenyatta University"
  employmentDate   String? // YYYY-MM-DD
  contractType     String   @default("PERMANENT") // PERMANENT | CONTRACT | BOM | INTERN
  contractEndDate  String? // for CONTRACT/BOM/INTERN
  emergencyContact String?
  visibilityAreas  String? // JSON array: KITCHEN | CLINIC | TRANSPORT | SECURITY | GENERAL, narrows SUPPORT_STAFF access
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
}

// B.9 leave management. Balances derive from LEAVE_TYPES allowances - taken.
model LeaveRequest {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  userName      String
  type          String // ANNUAL | SICK | MATERNITY | PATERNITY | COMPASSIONATE | STUDY
  startDate     String // YYYY-MM-DD
  endDate       String
  days          Int
  reason        String?
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  decidedById   String?
  decidedByName String?
  decidedAt     DateTime?
  decisionNote  String?
  createdAt     DateTime  @default(now())

  // T.12 (founder-requested 2026-07-07) — real substitute-teacher coverage
  // proposals generated the moment this leave is approved (never fully
  // automatic — founder's own confirmed answer: PROPOSE a substitute for a
  // human, usually the deputy/HOD, to explicitly confirm before it goes
  // live on the real timetable a parent/student would see).
  substituteAssignments SubstituteAssignment[]

  @@index([tenantId, userId])
  @@index([tenantId, status])
}

// T.12 — a real, DATE-SCOPED substitute-teacher coverage record for one
// real TimetableSlot during one real approved LeaveRequest's real date
// range. Deliberately NEVER mutates the underlying TimetableSlot itself
// (that row is a permanent weekly TEMPLATE, reused every week all year —
// overwriting its own real teacherId would silently and permanently lose
// the original teacher, and would still be "covering" long after the real
// leave ends). Instead this is a real, separate, per-date overlay row a
// school confirms/declines, and the real substitute's own name is what
// every date-aware read path (teacher portal "today", parent/student
// timetable views, printed timetables) overlays on top of the slot's own
// base teacher for exactly the real leave's own date range.
model SubstituteAssignment {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveRequestId String
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  timetableSlotId String
  timetableSlot   TimetableSlot @relation(fields: [timetableSlotId], references: [id], onDelete: Cascade)

  originalTeacherId     String // the real teacher on leave (denormalised off the slot at proposal time, for a stable audit trail even if the slot's own teacherId is later independently edited)
  originalTeacherName   String
  substituteTeacherId   String? // null while a real qualified candidate could not be found (founder-confirmed: leave the gap visible + notify leadership, never silently fabricate a name)
  substituteTeacherName String?

  // The real, actual dated coverage window this substitution applies to —
  // NOT necessarily the full leave range, since a slot only recurs on its
  // own specific real weekday; computed as the real leave-range dates that
  // land on this slot's own dayOfWeek.
  coverageDates String // JSON array of real "YYYY-MM-DD" dates within the leave range that land on this slot's dayOfWeek

  status String @default("PROPOSED") // PROPOSED | CONFIRMED | DECLINED | REVERTED | UNFILLED
  // UNFILLED = a real, honest "no qualified free teacher was found" state
  // (founder-confirmed: leave the slot visibly needing coverage + alert
  // leadership, never silently mark a class as covered when it is not).

  confirmedById   String?
  confirmedByName String?
  confirmedAt     DateTime?
  declineReason   String?

  // T.12 — real, founder-confirmed manual-return handling: a staff member
  // explicitly marks the original teacher back (rather than a same-day
  // automatic reversion), since a teacher may return early or need their
  // leave extended — this timestamp is set only once a human confirms it.
  revertedById   String?
  revertedByName String?
  revertedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, leaveRequestId])
  @@index([tenantId, timetableSlotId])
  @@index([tenantId, status])
  @@index([tenantId, substituteTeacherId])
}

// B.9 recruitment.
model JobPosting {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  deadline     String? // YYYY-MM-DD
  open         Boolean          @default(true)
  applications JobApplication[]
  createdAt    DateTime         @default(now())

  @@index([tenantId])
}

model JobApplication {
  id        String     @id @default(cuid())
  postingId String
  posting   JobPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  email     String?
  notes     String?
  status    String     @default("NEW") // NEW | SHORTLISTED | INTERVIEWED | HIRED | REJECTED
  createdAt DateTime   @default(now())
}

// B.9 performance appraisal (simple periodic review).
model Appraisal {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  userName     String
  period       String // "2026-T2"
  score        Int // 1..5
  strengths    String?
  improvements String?
  reviewerId   String
  reviewerName String
  createdAt    DateTime @default(now())

  @@index([tenantId, userId])
}

// B.9 disciplinary records (staff).
model DisciplinaryRecord {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  date           String
  category       String // VERBAL_WARNING | WRITTEN_WARNING | SUSPENSION | OTHER
  details        String
  actionTaken    String?
  recordedById   String
  recordedByName String
  createdAt      DateTime @default(now())

  @@index([tenantId, userId])
}

// B.9 training / CPD records.
model TrainingRecord {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  title          String // "SEPU CBC upskilling workshop"
  provider       String?
  date           String
  durationDays   Int      @default(1)
  certificateUrl String?
  createdAt      DateTime @default(now())

  @@index([tenantId, userId])
}

// B.8 staff salary setup (KES/month).
model StaffSalary {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                String   @unique
  basicKes              Int
  houseAllowanceKes     Int      @default(0)
  transportAllowanceKes Int      @default(0)
  otherAllowanceKes     Int      @default(0)
  saccoKes              Int      @default(0) // monthly SACCO contribution
  loanKes               Int      @default(0) // monthly loan repayment
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
}

// B.8 one month's payroll run.
model PayrollRun {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period        String // "2026-06"
  status        String    @default("DRAFT") // DRAFT | APPROVED
  payslips      Payslip[]
  createdById   String
  createdByName String
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@unique([tenantId, period])
}

// B.8 one staff member's payslip in a run (all KES).
model Payslip {
  id             String     @id @default(cuid())
  runId          String
  run            PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  role           String
  basicKes       Int
  allowancesKes  Int
  overtimeKes    Int        @default(0)
  grossKes       Int
  payeKes        Int
  shifKes        Int // SHA/SHIF 2.75%
  nssfKes        Int // employee Tier I+II
  housingLevyKes Int // AHL 1.5%
  saccoKes       Int
  loanKes        Int
  netKes         Int

  @@unique([runId, userId])
}

// B.7 fee structure: what a class level pays in a term (KES).
// T.7 — applyToAllLevels: a real school-wide, ALL-LEVELS shortcut. When true,
// `level`/`classId` are stored as "ALL"/null and batchInvoice()'s class-lookup
// treats this ONE structure as matching every real active class regardless of
// level — a school with a genuinely flat fee no longer has to create one
// duplicate-content structure per level. Founder-confirmed (2026-07-08):
// "option 1" (one flat structure for the whole school) PLUS per-class-level
// fee differences must still reflect correctly on every real student
// dimension — both real capabilities already coexist here: applyToAllLevels
// for the flat case, the pre-existing level/classId override for the
// per-class-differs case, never one replacing the other.
model FeeStructure {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String // "Form 2 — Term 2 2026" or "All levels — Term 2 2026"
  level            String // class level it applies to ("Form 2", "Grade 4"), or "ALL" when applyToAllLevels
  classId          String? // optional exact class/stream override (I.35)
  applyToAllLevels Boolean   @default(false) // T.7 — one real flat structure for every level/class
  year             Int
  term             Int
  items            FeeItem[]
  invoices         Invoice[]

  @@unique([tenantId, level, year, term, classId])
}

model FeeItem {
  id          String       @id @default(cuid())
  structureId String
  structure   FeeStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  label       String // "Tuition", "Boarding", "Activity fee"
  amountKes   Int
}

// B.7 invoice: one student's bill for a term (from a structure or manual).
// status derived from amounts: UNPAID | PARTIAL | PAID (computed, stored for filters).
model Invoice {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNo      String // KH-INV-000001 (A.4)
  studentId      String
  structureId    String?
  structure      FeeStructure? @relation(fields: [structureId], references: [id], onDelete: SetNull)
  description    String // "Term 2 2026 fees" or manual reason
  kind           String        @default("FEE") // FEE | ARREARS | MANUAL | SERVICE
  totalKes       Int
  paidKes        Int           @default(0)
  discountKes    Int           @default(0) // B.7 scholarships/bursaries/waivers
  discountReason String? // "Bursary — county fund", "Sibling discount"
  reminderSentAt DateTime? // last overdue-SMS (dedupe window)
  // B.7+ print tracking (proof-of-payment discipline)
  printCount     Int           @default(0)
  lastPrintedAt  DateTime?
  lastPrintedBy  String?
  status         String        @default("UNPAID") // UNPAID | PARTIAL | PAID
  dueDate        String // YYYY-MM-DD
  year           Int
  term           Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  promisesToPay              PromiseToPay[]
  teacherCashPaymentRequests TeacherCashPaymentRequest[]

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, studentId])
  @@index([tenantId, status, dueDate])
}

// T.10 — a real teacher-submitted cash-payment entry, PENDING real
// confirmation by a bursar/leadership user before it ever touches the real
// invoice ledger. Gated by a real school-level opt-in
// (Tenant.allowTeacherCashPayments, off by default). This is a thin,
// narrowly-scoped PRE-STEP in front of the already-battle-tested real
// applyPaymentToInvoice()/recordWalkInPayment() — confirming this request
// is the ONLY path that ever calls those real functions on its behalf;
// there is no second, parallel payment-recording system.
model TeacherCashPaymentRequest {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  submittedById   String // the real TEACHER/CLASS_TEACHER portal User
  submittedByName String
  amountKes       Int
  note            String?

  status String @default("PENDING") // PENDING | CONFIRMED | REJECTED

  decidedById   String?
  decidedByName String?
  decidedAt     DateTime?
  rejectReason  String? // required on reject — "cash didn't reach the office" etc.

  // Set only once CONFIRMED genuinely applies the real payment.
  resultPaymentId String?

  createdAt DateTime @default(now())

  @@index([tenantId, status])
  @@index([tenantId, invoiceId])
}

// B.6 CBC competency strand within a subject (e.g. English -> "Listening and
// Speaking"). learningOutcome = the KICD outcome statement (B.6.2 tagging).
model CbcStrand {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  learningAreaId  String?
  learningArea    LearningArea?   @relation(fields: [learningAreaId], references: [id], onDelete: SetNull)
  subjectId       String
  name            String
  learningOutcome String?
  assessments     CbcAssessment[]
  lessonPlans     LessonPlan[]
  substrands      CbcSubstrand[]
  learningVideos  LearningVideo[]
  questionBankEntries QuestionBankEntry[]
  paperQuizFormativeBatches PaperQuizFormativeBatch[]

  @@unique([tenantId, subjectId, name])
  @@index([tenantId, subjectId])
}

// EE.1 — real KICD sub-strand under a strand (e.g. strand "Numbers" ->
// sub-strands "Whole Numbers", "Fractions", "Money"). Nullable link from
// CbcAssessment (backward compatible — an assessment can still be recorded
// at the strand level alone, exactly as before this feature).
model CbcSubstrand {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  strandId        String
  strand          CbcStrand       @relation(fields: [strandId], references: [id], onDelete: Cascade)
  name            String
  learningOutcome String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assessments     CbcAssessment[]
  learningVideos  LearningVideo[]
  questionBankEntries QuestionBankEntry[]
  paperQuizFormativeBatches PaperQuizFormativeBatch[]
  curriculumDesign CbeCurriculumDesign?

  @@unique([tenantId, strandId, name])
  @@index([tenantId, strandId])
}

// B.6 formative assessment: one observation of one learner on one strand.
// level: 4=EE 3=ME 2=AE 1=BE (KICD 4-point rubric).
// CBE Delivery Hub: a reviewed, school-owned enrichment of one curriculum
// sub-strand. JSON arrays preserve flexible KICD/CBE structures without
// inventing a fixed national list; every value is manually reviewable and
// version/source labelled. NEYO never silently scrapes curriculum content.
model CbeCurriculumDesign {
  id                           String   @id @default(cuid())
  tenantId                     String
  tenant                       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  substrandId                  String   @unique
  substrand                    CbcSubstrand @relation(fields: [substrandId], references: [id], onDelete: Cascade)
  suggestedLearningExperiences String?  // JSON string[]
  keyInquiryQuestions          String?  // JSON string[]
  competencyCodes              String?  // JSON string[] mapped to configured competencies
  values                       String?  // JSON string[]
  pertinentIssues              String?  // JSON string[]
  crossLearningAreaLinks       String?  // JSON { learningArea, connection }[]
  communityServiceIdeas        String?  // JSON string[]
  suggestedResources           String?  // JSON string[]
  assessmentCriteria           String?  // JSON string[]
  lessonAllocation             Int?
  sourceLabel                  String?
  sourceVersion                String?
  sourceReference              String?
  reviewStatus                 String   @default("DRAFT") // DRAFT | REVIEWED | PUBLISHED
  reviewedById                 String?
  reviewedByName               String?
  reviewedAt                   DateTime?
  createdById                  String
  createdByName                String
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  sessions                     CbeDeliverySession[]

  @@index([tenantId, reviewStatus])
}

// One real delivery event: this teacher delivered this curriculum design to
// this class on this date. Existing lesson/assessment/syllabus records remain
// their own authoritative objects and are linked by ID rather than duplicated.
model CbeDeliverySession {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  curriculumDesignId String
  curriculumDesign   CbeCurriculumDesign @relation(fields: [curriculumDesignId], references: [id], onDelete: Cascade)
  classId            String
  teacherId          String
  teacherName        String
  deliveredOn        String
  timetableSlotId    String?
  lessonPlanId       String?
  syllabusTopicId    String?
  assessmentPlanId   String?
  status             String   @default("PLANNED") // PLANNED | DELIVERED | REVIEWED
  deliveryNotes      String?
  resourceLinks      String?  // JSON string[]
  nextSteps          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  evidence           CbeDeliveryEvidence[]
  interventions      CbeIntervention[]

  @@index([tenantId, classId, deliveredOn])
  @@index([tenantId, teacherId])
  @@index([tenantId, curriculumDesignId])
}

// A small, source-explicit learner observation made during a delivery event.
// It can reference existing CBE/assessment/competency/portfolio records after
// those workflows create them, but never claims they exist automatically.
model CbeDeliveryEvidence {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliverySessionId    String
  deliverySession      CbeDeliverySession @relation(fields: [deliverySessionId], references: [id], onDelete: Cascade)
  studentId            String
  level                Int?
  observation          String
  evidenceUrl          String?
  cbcAssessmentId      String?
  assessmentRecordId   String?
  competencyEvidenceId String?
  portfolioItemId      String?
  recordedById         String
  recordedByName       String
  recordedAt           DateTime @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, deliverySessionId])
}

// Reviewed support loop: identify a specific curriculum need, assign a
// supported response, review it on a real date and record the outcome.
model CbeIntervention {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliverySessionId String?
  deliverySession   CbeDeliverySession? @relation(fields: [deliverySessionId], references: [id], onDelete: SetNull)
  studentId         String
  substrandId       String
  reason            String
  actionType        String // QUESTION_SET | SIMULATION | RESOURCE | RETEACH | GOAL | OTHER
  actionDetails     String
  targetLevel       Int?
  reviewDate        String
  status            String @default("PLANNED") // PLANNED | IN_PROGRESS | REVIEWED | CLOSED
  outcome           String?
  reviewedLevel     Int?
  parentSummary     String?
  assignedById      String
  assignedByName    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, studentId, status])
  @@index([tenantId, reviewDate])
  @@index([tenantId, substrandId])
}

model CbcAssessment {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId   String
  strandId    String
  strand      CbcStrand     @relation(fields: [strandId], references: [id], onDelete: Cascade)
  // EE.1 — optional real sub-strand this specific observation is scored
  // against. Nullable: a school not yet using sub-strands keeps working
  // exactly as before (strand-level only).
  substrandId String?
  substrand   CbcSubstrand? @relation(fields: [substrandId], references: [id], onDelete: SetNull)
  level       Int // 1..4
  comment     String?
  // EE.2 — true when `comment` was chosen by the rubric-driven comment
  // bank auto-fill (never AI-generated — a school-authored phrase picked
  // deterministically by level/subject/strand/sub-strand match) rather
  // than freely typed by the teacher. Purely informational (lets a
  // report/print distinguish "teacher's own words" from "bank phrase"
  // later if ever wanted) — never blocks editing either way.
  commentFromBank Boolean @default(false)
  date        String // YYYY-MM-DD
  teacherId   String

  teacherName String
  createdAt   DateTime  @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, strandId, date])
  @@index([tenantId, substrandId])
}

// EE.2 — a school's own bank of ready-made comment phrasings per rubric
// level, scoped to a subject and optionally narrowed to one specific
// strand/sub-strand (a narrower match always wins over a subject-wide
// generic one — see resolveAutoComment() in cbc.service.ts). Never
// AI-generated: every phrase here is authored by the school itself (or
// seeded from a real, human-written KICD-style starter set) and picked by
// simple deterministic lookup + weighted random rotation so repeat
// comments don't feel robotic — this is data + a picker, not a language
// model, matching the founder's explicit "never AI powered" instruction.
model CbcCommentBankEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectId   String
  strandId    String? // null = applies to the whole subject at this level
  substrandId String? // null = applies to the whole strand at this level
  level       Int // 1..4, matches CbcAssessment.level / KICD rubric
  text        String
  enabled     Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, subjectId, level])
  @@index([tenantId, strandId])
  @@index([tenantId, substrandId])
}


// B.5 exam (e.g. "End of Term 2", "CAT 1"). Subjects mapped via ExamSubject.
model Exam {
  id               String                       @id @default(cuid())
  tenantId         String
  tenant           Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  year             Int
  term             Int // 1..3
  type             String                       @default("EXAM") // EXAM | CAT
  maxMarks         Int                          @default(100)
  published        Boolean                      @default(false) // published = parents/students can see
  subjects         ExamSubject[]
  results          ExamResult[]
  releaseApprovals ExamReleaseApprovalRequest[]
  scannedExamPapers ScannedExamPaper[]
  createdAt        DateTime                     @default(now())

  @@index([tenantId, year, term])
}

// I.2 results-release approval workflow. HOD/academics request, Principal/Owner approves.
model ExamReleaseApprovalRequest {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  examId          String
  exam            Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  requestedById   String
  requestedByName String
  requestedAt     DateTime  @default(now())
  decidedById     String?
  decidedByName   String?
  decidedAt       DateTime?
  decisionNote    String?
  summaryJson     String?

  @@index([tenantId, status, requestedAt])
  @@index([tenantId, examId])
}

// Subjects sat in an exam (B.5.2).
model ExamSubject {
  id        String @id @default(cuid())
  examId    String
  exam      Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectId String

  @@unique([examId, subjectId])
}

// One student's mark in one subject of one exam. Idempotent upsert target.
model ExamResult {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  examId      String
  exam        Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  subjectId   String
  marks       Int // raw marks out of exam.maxMarks
  enteredById String
  updatedAt   DateTime      @updatedAt
  PaperResult PaperResult[]

  @@unique([examId, studentId, subjectId])
  @@index([tenantId, examId, studentId])
}

// =============================================================================
// PART J.3 — Flexible Assessment Engine foundation
// =============================================================================

// A configurable assessment type for a tenant. This is not a replacement for
// B.5 Exam/CAT; it is a flexible catalog that can represent projects, practicals,
// oral work, observations, portfolio tasks, peer/self assessment and continuous
// assessment while still allowing formal EXAM/CAT types to coexist.
model AssessmentType {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key                String // EXAM, CAT, PROJECT, PRACTICAL, ORAL, OBSERVATION, PORTFOLIO, PEER, SELF, CONTINUOUS, CUSTOM...
  name               String
  description        String?
  category           String   @default("SCHOOL_DEFINED") // FORMAL | PRACTICAL | PORTFOLIO | OBSERVATION | SCHOOL_DEFINED
  scoreMode          String   @default("MIXED") // MARKS | RUBRIC | NARRATIVE | MIXED
  defaultMaxMarks    Int?
  defaultWeight      Int      @default(0) // percentage weight suggestion; plan can override
  effectiveFrom      String? // YYYY-MM-DD
  effectiveTo        String? // YYYY-MM-DD
  evidenceAllowed    Boolean  @default(true)
  requiresModeration Boolean  @default(true)
  rubricId           String? // J.5 configurable Rubric bridge
  isSystem           Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  plans AssessmentPlan[]

  @@unique([tenantId, key])
  @@index([tenantId, active])
  @@index([tenantId, category])
}

// A planned assessment event or continuous-assessment slot. It links to the
// J.2 curriculum engine and existing academic records by ID instead of creating
// a duplicate class/subject/exam module.
model AssessmentPlan {
  id               String         @id @default(cuid())
  tenantId         String
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessmentTypeId String
  assessmentType   AssessmentType @relation(fields: [assessmentTypeId], references: [id], onDelete: Cascade)

  // Optional compatibility links to existing/J.2 records. Kept as scalar IDs so
  // J.3 can evolve without forcing back-relations into every mature module.
  curriculumId     String?
  educationLevelId String?
  gradeBandId      String?
  learningAreaId   String?
  subjectId        String?
  classId          String?
  academicTermId   String?
  examId           String? // optional bridge to B.5 formal Exam when needed later
  homeworkId       String? // optional bridge to B.12/B.13 homework
  quizId           String? // optional bridge to B.13 quiz
  cbcStrandId      String? // optional bridge to B.6 CBC strand
  rubricId         String? // J.5 configurable Rubric bridge

  year             Int
  term             Int
  title            String
  description      String?
  instructions     String?
  weight           Int      @default(0) // 0..100; service validation comes in Chunk 2
  maxMarks         Int?
  dueDate          String? // YYYY-MM-DD
  rubricJson       String? // temporary descriptor storage until J.5 configurable Rubric model lands
  status           String   @default("DRAFT") // DRAFT | ACTIVE | MODERATION | RELEASED | ARCHIVED
  visibleToParents Boolean  @default(false)
  createdById      String
  createdByName    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  records     AssessmentRecord[]
  lessonPlans LessonPlan[]

  @@index([tenantId, year, term])
  @@index([tenantId, assessmentTypeId])
  @@index([tenantId, classId])
  @@index([tenantId, subjectId])
  @@index([tenantId, learningAreaId])
  @@index([tenantId, status])
}

// One learner's result/observation for an AssessmentPlan. Supports marks,
// rubric levels and narrative comments in one compatible ledger. Formal
// ExamResult remains the formal exam source of truth; this record can link back
// via sourceModule/sourceId when a later chunk imports or syncs outcomes.
model AssessmentRecord {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId          String
  plan            AssessmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  studentId       String
  scoreMarks      Float?
  scorePct        Int?
  rubricLevel     Int?
  rubricCode      String? // e.g. EE, ME, AE, BE or a school-defined rubric code
  narrative       String?
  status          String         @default("DRAFT") // DRAFT | SCORED | SUBMITTED | MODERATED | RELEASED
  rubricId        String? // J.5 configurable Rubric bridge
  sourceModule    String? // EXAM | CBC | LMS_HOMEWORK | LMS_QUIZ | MANUAL | PORTFOLIO
  sourceId        String?
  assessedById    String
  assessedByName  String
  assessedAt      DateTime       @default(now())
  moderatedById   String?
  moderatedByName String?
  moderatedAt     DateTime?
  releasedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  evidence AssessmentEvidence[]

  @@unique([tenantId, planId, studentId])
  @@index([tenantId, studentId])
  @@index([tenantId, planId])
  @@index([tenantId, status])
  @@index([tenantId, sourceModule, sourceId])
}

// Evidence attached to a flexible assessment record. File uploads must use the
// existing encrypted Storage Vault path (FileUpload -> /api/files/encrypted) in
// later UI/service chunks; this table stores the resulting file reference.
model AssessmentEvidence {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recordId       String
  record         AssessmentRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  storedFileId   String?
  fileUrl        String?
  fileName       String?
  contentType    String?
  evidenceType   String           @default("FILE") // FILE | LINK | NOTE | PHOTO | VIDEO | CERTIFICATE
  note           String?
  uploadedById   String
  uploadedByName String
  createdAt      DateTime         @default(now())

  @@index([tenantId, recordId])
  @@index([tenantId, storedFileId])
}

// =============================================================================
// PART J.4 — Competency Framework foundation
// =============================================================================

// A configurable competency group inside a curriculum, e.g. "Core CBC
// Competencies" or a private-school custom group. Kept tenant-owned and
// curriculum-linked without hardcoding CBC names.
model CompetencyGroup {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  curriculumId String?
  name         String
  code         String
  description  String?
  sequence     Int      @default(1)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  competencies Competency[]

  @@unique([tenantId, code])
  @@index([tenantId, curriculumId])
  @@index([tenantId, active])
}

// A configurable competency, e.g. Communication, Critical Thinking,
// Creativity, Citizenship, Digital Literacy or a school-defined skill.
model Competency {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId        String?
  group          CompetencyGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  curriculumId   String?
  learningAreaId String?
  rubricId       String? // J.5 configurable Rubric bridge
  name           String
  code           String
  description    String?
  sequence       Int              @default(1)
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  evidence   CompetencyEvidence[]
  LessonPlan LessonPlan[]

  @@unique([tenantId, code])
  @@index([tenantId, groupId])
  @@index([tenantId, curriculumId])
  @@index([tenantId, learningAreaId])
  @@index([tenantId, active])
}

// One evidence point for one learner on one competency. This can be sourced
// from CBC observations, J.3 AssessmentRecord rows, LMS work, manual teacher
// observation, clubs or a future portfolio item without duplicating those source
// modules. Parent visibility/service rules come in later chunks.
model CompetencyEvidence {
  id                 String     @id @default(cuid())
  tenantId           String
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competencyId       String
  competency         Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  studentId          String
  sourceModule       String     @default("MANUAL") // CBC | ASSESSMENT | LMS | MANUAL | CLUB | PORTFOLIO
  sourceId           String?
  assessmentRecordId String?
  cbcAssessmentId    String?
  rubricId           String? // J.5 configurable Rubric bridge
  level              Int? // 1..4 when rubric-like
  scorePct           Int? // 0..100 when percentage-like
  narrative          String?
  evidenceDate       String // YYYY-MM-DD
  recordedById       String
  recordedByName     String
  approved           Boolean    @default(false)
  visibleToParents   Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([tenantId, competencyId])
  @@index([tenantId, studentId])
  @@index([tenantId, sourceModule, sourceId])
  @@index([tenantId, assessmentRecordId])
  @@index([tenantId, cbcAssessmentId])
  @@index([tenantId, visibleToParents])
}

// =============================================================================
// PART J.2 — Curriculum Engine foundation
// =============================================================================

// A configurable curriculum/version for a tenant. This keeps School OS future-proof:
// CBC, 8-4-4, Cambridge, Montessori, private-school custom frameworks, and future
// Kenya curriculum updates are records, not hardcoded branches.
model Curriculum {
  id            String  @id @default(cuid())
  tenantId      String
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String // e.g. "CBC Kenya", "8-4-4 Legacy", "Cambridge Lower Secondary"
  country       String  @default("Kenya")
  context       String? // e.g. "Junior School", "Senior School", "Private international"
  activeVersion String  @default("v1")
  effectiveFrom String? // YYYY-MM-DD
  effectiveTo   String? // YYYY-MM-DD, null = still active
  isActive      Boolean @default(true)

  status            String       @default("ACTIVE") // DRAFT | ACTIVE | ARCHIVED
  previousVersionId String?
  previousVersion   Curriculum?  @relation("CurriculumHistory", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions      Curriculum[] @relation("CurriculumHistory")

  // J.21 — if this curriculum was adopted from a NEYO Ops library template, we
  // remember which template + which template version, so schools can be told
  // when a newer version is published and adopt the update intentionally.
  adoptedTemplateId      String?
  adoptedTemplateVersion String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  educationLevels EducationLevel[]
  gradeBands      GradeBand[]
  learningAreas   LearningArea[]
  subjects        Subject[]
  classes         SchoolClass[]
  academicTerms   AcademicTerm[]

  @@unique([tenantId, name, activeVersion])
  @@index([tenantId, isActive])
}

// A broad education stage inside a curriculum, e.g. Preschool, Primary, Junior,
// Senior, Forms, or a custom school-defined stage. Kept configurable so NEYO is
// not locked to CBC names only.
model EducationLevel {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  curriculumId String
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  name         String // "Junior School", "Senior School", "Forms", "Primary"
  levelKey     String // stable key: preschool | primary | junior | senior | custom
  sequence     Int        @default(1)
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  gradeBands GradeBand[]

  @@unique([tenantId, curriculumId, name])
  @@index([tenantId, curriculumId, sequence])
}

// A configurable grade/class band name, e.g. PP1, Grade 7, Form 2, Year 9. This
// maps existing SchoolClass.level values without replacing SchoolClass.
model GradeBand {
  id               String          @id @default(cuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  curriculumId     String
  curriculum       Curriculum      @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  educationLevelId String?
  educationLevel   EducationLevel? @relation(fields: [educationLevelId], references: [id], onDelete: SetNull)
  name             String // "Grade 7", "Form 2", "Year 9"
  shortName        String? // "G7", "F2"
  sequence         Int             @default(1)
  entryAge         Int?
  exitAge          Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  classes SchoolClass[]

  @@unique([tenantId, curriculumId, name])
  @@index([tenantId, curriculumId, sequence])
  @@index([tenantId, educationLevelId])
}

// A curriculum learning area. Existing Subject rows can map here, and CBC strands
// can also point here, allowing future competencies/portfolio items to connect
// to the curriculum without duplicating Subjects.
model LearningArea {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  curriculumId String
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  name         String // "Mathematics", "Languages", "Integrated Science"
  code         String // "MAT", "LANG", "ISC"
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  subjects   Subject[]
  cbcStrands CbcStrand[]

  @@unique([tenantId, curriculumId, code])
  @@index([tenantId, curriculumId, name])
}

// B.4 departments (Languages, Sciences, Humanities...).

// PART J.9 — Activity-Aware Timetable
// Configurable non-academic activity categories (Clubs, STEM, Music, Sports).
model ActivityCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String // e.g., "STEM Lab", "Drama Club", "Community Service"
  color       String   @default("gray") // Tailwind color stem (blue, green, purple, amber, rose)
  description String?
  maxPerWeek  Int? // Optional constraint (e.g., max 2 STEM labs per class per week)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timetableSlots TimetableSlot[]

  @@unique([tenantId, name])
}

model Department {
  id       String    @id @default(cuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  hodId    String? // User with HOD role
  subjects Subject[]

  @@unique([tenantId, name])
}

// B.4 subjects (Mathematics, Kiswahili, Integrated Science...).
model Subject {
  id                        String                      @id @default(cuid())
  tenantId                  String
  tenant                    Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                      String
  code                      String // "MAT", "KIS", "ENG"
  curriculum                String // "CBC" | "8-4-4" | "BOTH"
  curriculumId              String?
  curriculumRef             Curriculum?                 @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  learningAreaId            String?
  learningArea              LearningArea?               @relation(fields: [learningAreaId], references: [id], onDelete: SetNull)
  departmentId              String?
  department                Department?                 @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  archived                  Boolean                     @default(false)
  // P.2 (2026-07-02): Kenya CBE Senior School compulsory-subject variants.
  // "Mathematics" splits into two REAL, separately-taught, separately-graded
  // subjects at Senior School: Core Mathematics (STEM pathway) vs Essential
  // Mathematics (non-STEM, practical/utilitarian) — same compulsory learning
  // area, genuinely different syllabus/subject rows, never one subject with
  // a cosmetic label swap. Null for every other (non-Math, non-Senior)
  // subject — zero behaviour change for existing rows.
  mathVariant               String? // "CORE" | "ESSENTIAL" | null
  // JSON array of pathway group keys this subject is COMPULSORY for, e.g.
  // ["STEM"] for Core Mathematics, ["SOCIAL_SCIENCES","ARTS_SPORTS"] for
  // Essential Mathematics. Null/empty = not a compulsory-by-pathway subject
  // (ordinary elective, unaffected). Reused by P.3 for Community Service
  // Learning (compulsory for ALL pathway groups) so this stays one shared
  // mechanism rather than a Math-only special case.
  compulsoryPathwayGroups   String?                     @default("[]")
  timetableSlots            TimetableSlot[]
  lessonPlans               LessonPlan[]
  homework                  Homework[]
  classNotes                ClassNote[]
  quizzes                   Quiz[]
  PathwaySubjectRequirement PathwaySubjectRequirement[]
  SubjectPaperConfig        SubjectPaperConfig[]
  scannedExamPapers         ScannedExamPaper[]
  learningVideos            LearningVideo[]
  questionBankEntries       QuestionBankEntry[]
  paperQuizFormativeBatches PaperQuizFormativeBatch[]
  interSchoolContests       InterSchoolContest[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, curriculumId])
  @@index([tenantId, learningAreaId])
}

// B.4 academic calendar — Kenyan 3-term year.
model AcademicTerm {
  talentRecords         TalentRecord[]
  id                    String                  @id @default(cuid())
  tenantId              String
  tenant                Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  curriculumId          String?
  curriculum            Curriculum?             @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  year                  Int
  term                  Int // 1 | 2 | 3
  startDate             String // YYYY-MM-DD
  endDate               String
  current               Boolean                 @default(false)
  StudentGoal           StudentGoal[]
  MarksPortal           MarksPortal[]
  StudentDutyAssignment StudentDutyAssignment[]

  @@unique([tenantId, year, term])
  @@index([tenantId, curriculumId])
}

// I.78 — generated teacher duty-roster timetable.
model DutyRosterEntry {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  termLabel            String
  rotationPeriod       String // WEEKLY | BI_WEEKLY | MONTHLY
  weekNo               Int
  startDate            String // YYYY-MM-DD
  endDate              String // YYYY-MM-DD
  primaryTeacherId     String
  primaryTeacherName   String
  assistantTeacherId   String?
  assistantTeacherName String?
  dutyTeamSize         Int      @default(2)
  dutyTeacherIds       String? // JSON array for all teachers assigned in this reshuffle cycle
  dutyTeacherNames     String? // JSON array for display/print
  duties               String
  generatedById        String
  generatedByName      String
  createdAt            DateTime @default(now())

  @@unique([tenantId, termLabel, weekNo])
  @@index([tenantId, termLabel])
  @@index([tenantId, primaryTeacherId])
}

// B.4 timetable — one subject slot per class/day/period.
model TimetableSlot {
  id                 String            @id @default(cuid())
  tenantId           String
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId            String
  subjectId          String?
  subject            Subject?          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  activityCategoryId String?
  activityCategory   ActivityCategory? @relation(fields: [activityCategoryId], references: [id], onDelete: SetNull)
  teacherId          String? // User
  dayOfWeek          Int // 1=Mon .. 5=Fri
  period             Int // 1..8
  slotType           String            @default("ACADEMIC") // ACADEMIC | REMEDIAL | PREP | ACTIVITY | ELECTIVE_BLOCK
  weekRotation       String            @default("ALL") // ALL | WEEK_A | WEEK_B for alternating Saturdays
  venue              String? // classroom/lab/hall for venue printing

  // AA.1 — when slotType = ELECTIVE_BLOCK, this real period genuinely has NO
  // single subject/teacher for the class as a whole (different real
  // students attend different real parallel lessons based on their own
  // choices) — subjectId/teacherId stay null on THIS row by design, and the
  // real per-subject breakdown (which teacher/room/subject a given
  // student's choice maps to) lives in ElectiveBlockSlotSubject, looked up
  // via electiveBlockSlotId. Kept as its own distinct slotType (not reusing
  // ACADEMIC) so print/live renderers can render this real "whole level in
  // an Options Block" cell differently from a normal single-subject cell.
  electiveBlockSlotId String?
  electiveBlockSlot   ElectiveBlockSlot? @relation(fields: [electiveBlockSlotId], references: [id], onDelete: SetNull)

  // T.12 — real, date-scoped substitute-coverage overlays proposed against
  // this real recurring slot (never mutates this row's own teacherId).
  substituteAssignments SubstituteAssignment[]

  @@unique([tenantId, classId, dayOfWeek, period, slotType])
  @@index([tenantId, teacherId, dayOfWeek, period])
}

// B.4 lesson plans (teacher-owned; AI assist comes at B.23).
model LessonPlan {
  id               String          @id @default(cuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId        String
  teacherName      String
  subjectId        String
  subject          Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classId          String
  date             String // YYYY-MM-DD
  topic            String
  objectives       String?
  strandId         String?
  strand           CbcStrand?      @relation(fields: [strandId], references: [id], onDelete: SetNull)
  competencyId     String?
  competency       Competency?     @relation(fields: [competencyId], references: [id], onDelete: SetNull)
  assessmentPlanId String?
  assessmentPlan   AssessmentPlan? @relation(fields: [assessmentPlanId], references: [id], onDelete: SetNull)

  resources    LessonResource[]
  observations LessonObservation[]
  activities   String?
  notes        String?
  status       String              @default("PLANNED") // PLANNED | TAUGHT | SKIPPED
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([tenantId, teacherId, date])
  @@index([tenantId, classId, date])
}

// B.12 homework a teacher assigns to a whole class (subject-tagged).
// Parents/students see it on the shared family portal (B.10/B.11).
// Submissions + grading come at B.13 (LMS) — this model is reused there.
model Homework {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId      String
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId    String
  teacherName  String // denormalized for fast portal lists
  title        String
  instructions String?
  dueDate      String // YYYY-MM-DD
  fileUrl      String? // optional attachment (A.9 storage)
  fileName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions HomeworkSubmission[] // B.13

  @@index([tenantId, classId, dueDate])
  @@index([tenantId, teacherId])
}

// B.12 class notes / study material a teacher shares with a class.
// Students download these from the shared portal. B.13 LMS reuses this model.
model ClassNote {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId     String
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId   String
  teacherName String
  title       String
  description String?
  fileUrl     String // A.9 storage (PDF/DOC/image)
  fileName    String
  createdAt   DateTime @default(now())

  @@index([tenantId, classId])
  @@index([tenantId, teacherId])
}

// B.13 a student's submission for a Homework task. One per student per task.
// Graded by the teacher (gradePct + feedback).
model HomeworkSubmission {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  homeworkId  String
  homework    Homework  @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentId   String
  text        String? // typed answer / cover note
  fileUrl     String? // optional uploaded work (A.9)
  fileName    String?
  late        Boolean   @default(false) // submitted after dueDate
  submittedAt DateTime  @default(now())
  gradePct    Int? // 0-100, set by teacher
  feedback    String?
  gradedById  String?
  gradedAt    DateTime?

  @@unique([homeworkId, studentId])
  @@index([tenantId, homeworkId])
  @@index([tenantId, studentId])
}

// B.13 quiz with auto-grading. Questions are MCQ; grading is SERVER-side
// (correct answers never leave the server before an attempt).
model Quiz {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId      String
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId    String
  teacherName  String
  title        String
  instructions String?
  published    Boolean  @default(false) // students only see published
  dueDate      String? // YYYY-MM-DD; attempts blocked after this
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([tenantId, classId])
  @@index([tenantId, teacherId])
}

model QuizQuestion {
  id           String @id @default(cuid())
  tenantId     String
  quizId       String
  quiz         Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order        Int
  prompt       String
  options      String // JSON array of option strings (2-6)
  correctIndex Int // index into options — NEVER sent to students pre-attempt

  @@index([tenantId, quizId])
}

// One graded attempt per student per quiz (auto-graded on submit).
model QuizAttempt {
  id          String   @id @default(cuid())
  tenantId    String
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String
  answers     String // JSON array of selected indexes (aligned to question order)
  score       Int // correct answers
  total       Int // question count at attempt time
  scorePct    Int // rounded %
  submittedAt DateTime @default(now())

  @@unique([quizId, studentId])
  @@index([tenantId, studentId])
}

// B.13 class discussion forum — thread + flat replies, per class.
model ForumThread {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId    String
  title      String
  body       String
  authorId   String
  authorName String
  authorRole String // TEACHER | STUDENT | PARENT | ... (for the role chip)
  locked     Boolean  @default(false) // teacher can lock a thread
  createdAt  DateTime @default(now())

  posts ForumPost[]

  @@index([tenantId, classId])
}

model ForumPost {
  id         String      @id @default(cuid())
  tenantId   String
  threadId   String
  thread     ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  body       String
  authorId   String
  authorName String
  authorRole String
  createdAt  DateTime    @default(now())

  @@index([tenantId, threadId])
}

// B.14 one bulk send (SMS/announcement) to an audience. Receipt of WHO was
// targeted + delivery counts + cost — the school's communication ledger.
model BulkMessage {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audienceType   String // SCHOOL_GUARDIANS | CLASS_GUARDIANS | ROLE
  classId        String? // when CLASS_GUARDIANS
  audienceLabel  String // human label frozen at send time ("Form 2 East parents")
  role           String? // when ROLE (e.g. TEACHER)
  channel        String // sms | in_app (dispatcher cascade for users)
  body           String
  recipientCount Int
  sentCount      Int
  skippedCount   Int
  costKes        Float    @default(0)
  senderId       String
  senderName     String
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
}

// B.15 a library book (physical copies + optional digital file).
// isbn doubles as the barcode value for phone scanning.

// I.10 — teacher class-parent messages require Principal/Deputy approval before delivery.
model TeacherCommsApprovalRequest {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audienceType    String // CLASS_GUARDIANS only for now
  classId         String
  audienceLabel   String
  channel         String    @default("in_app") // teachers may request in_app only; SMS is blocked
  body            String
  recipientCount  Int
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED
  requestedById   String
  requestedByName String
  decidedById     String?
  decidedByName   String?
  decidedAt       DateTime?
  decisionNote    String?
  bulkMessageId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([tenantId, requestedById])
}

model LibraryBook {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  author      String?
  isbn        String? // barcode / ISBN — scanned or typed
  category    String? // "Set book", "Reference", "Fiction"...
  shelf       String? // physical location, e.g. "B2"
  copiesTotal Int      @default(1)
  fileUrl     String? // digital copy (A.9) — the "digital library"
  fileName    String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())

  issues BookIssue[]
  copies LibraryBookCopy[] // T.1 — real per-physical-copy tracking, opt-in per book

  @@unique([tenantId, isbn])
  @@index([tenantId, archived])
}

// T.1 — one row PER PHYSICAL COPY of a book (not per title). A school opts
// into per-copy tracking for a given LibraryBook by generating copy rows
// ("Generate copy codes"); a book with zero LibraryBookCopy rows behaves
// exactly as before (bare copiesTotal integer, no forced migration). Once
// copies exist for a book, they become the real source of truth for
// availability -- copiesTotal is kept in sync for backward-compatible reads.
// Each copy gets its own real, scannable code via the EXISTING
// DocumentVerification pattern (N.2's proven scan-to-resolve mechanism),
// never a second, parallel code system.
model LibraryBookCopy {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookId    String
  book      LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  copyNo    Int // 1, 2, 3... within this book (human-readable "Copy 3")
  code      String // the real DocumentVerification.code for this copy's QR — denormalized for fast lookup
  status    String      @default("AVAILABLE") // AVAILABLE | OUT | LOST | DAMAGED | RETIRED
  createdAt DateTime    @default(now())

  issues BookIssue[]

  @@unique([tenantId, bookId, copyNo])
  @@unique([tenantId, code])
  @@index([tenantId, bookId, status])
}

// B.15 one borrow record. Open while returnedAt is null. fineKes is
// auto-computed from days overdue at return time (and previewed live).
model BookIssue {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookId         String
  book           LibraryBook      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  // T.1 — optional link to the exact physical copy borrowed, when the book
  // has opted into per-copy tracking. Null for books still on plain counts.
  copyId         String?
  copy           LibraryBookCopy? @relation(fields: [copyId], references: [id], onDelete: SetNull)
  // H.5 Teacher Book Borrowing: a borrower is a STUDENT or a STAFF member.
  borrowerType   String           @default("STUDENT") // STUDENT | STAFF
  studentId      String? // set when borrowerType = STUDENT
  borrowerUserId String? // set when borrowerType = STAFF (a User)
  studentName    String // denormalized borrower name (student or staff) for fast lists
  admissionNo    String           @default("") // student admission no; "" / TSC-style id for staff
  issuedById     String
  issuedByName   String
  issuedAt       DateTime         @default(now())
  dueDate        String // YYYY-MM-DD
  returnedAt     DateTime?
  fineKes        Int              @default(0)
  finePaid       Boolean          @default(false)

  @@index([tenantId, bookId])
  @@index([tenantId, studentId])
  @@index([tenantId, returnedAt])
}

// B.16 a hostel building (dorm). gender: BOYS | GIRLS | MIXED.
model Hostel {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String // "Simba House"
  gender         String // BOYS | GIRLS | MIXED
  masterId       String? // User (HOSTEL_MASTER / housemother)
  boardingFeeKes Int      @default(0) // per-term boarding fee (B.7 invoicing)
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())

  rooms HostelRoom[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// B.16 a room within a hostel; capacity = number of beds.
model HostelRoom {
  id       String @id @default(cuid())
  tenantId String
  hostelId String
  hostel   Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  name     String // "Room 4"
  capacity Int    @default(4)

  allocations HostelAllocation[]

  @@unique([tenantId, hostelId, name])
  @@index([tenantId, hostelId])
}

// B.16 one student in one bed. Open while releasedAt is null.
// bedNo is the bed within the room (1..capacity).
model HostelAllocation {
  id          String     @id @default(cuid())
  tenantId    String
  roomId      String
  room        HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  studentId   String
  studentName String // denormalized
  admissionNo String
  bedNo       Int
  allocatedAt DateTime   @default(now())
  releasedAt  DateTime?

  @@index([tenantId, roomId])
  @@index([tenantId, studentId])
}

// B.16 curfew register — one row per boarder per night.
// status: IN (present at curfew) | OUT (missing!) | LEAVE (authorised away).
model HostelAttendance {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId    String
  studentName  String
  hostelName   String
  date         String // YYYY-MM-DD (the night of)
  status       String // IN | OUT | LEAVE
  note         String?
  markedById   String
  markedByName String
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, studentId, date])
  @@index([tenantId, date])
}

// B.17 a transport route (e.g. "Route A — Kasarani"). Stops as JSON list.
model TransportRoute {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String // "Route A — Kasarani"
  stops      String? // JSON array of stop names, in order
  termFeeKes Int      @default(0) // per-term transport fee (B.7 invoicing) — the real DEFAULT/fallback fee when a shift has no fee override of its own
  // T.8 (founder-requested 2026-07-06): a route's OWN direct vehicle/driver
  // fields are kept for full real backward compatibility with every
  // existing school's real data (a school that never adopts shifts keeps
  // working exactly as before, zero migration risk) — but a route that HAS
  // real TransportShift rows is now the richer, real "one route, many
  // shifts" model (e.g. Route A Morning uses Bus 1, Route A Afternoon uses
  // Bus 2), each shift with its OWN real vehicle/driver/time window/seat
  // cap/fee. assignStudent() real-prefers a specific real shift when the
  // route has any; falls back to the route's own direct vehicle otherwise.
  vehicleId  String?
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driverId   String?
  driver     Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())

  assignments TransportAssignment[]
  shifts      TransportShift[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// T.8 — Transport Shifts (founder-requested 2026-07-06, "new TransportShift
// child model" — a real, separate real-world timeslot under one route, each
// with its OWN vehicle/driver/time window/seat cap/fee override, so ONE
// route (e.g. "Route A — Kasarani") can genuinely run a MORNING shift with
// one bus and an AFTERNOON shift with a completely different bus, a real,
// common Kenyan school/matatu scheduling pattern a single route-to-vehicle
// FK could never represent.
model TransportShift {
  id       String         @id @default(cuid())
  tenantId String
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routeId  String
  route    TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  name      String // "Morning", "Afternoon", "Evening" — school's own real label, never hardcoded
  startTime String? // "06:30" — real, optional, for real display/sorting only, never enforced as a hard scheduling constraint here
  endTime   String?

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)

  // T.8 — "a school can customize the seats number to their liking too": a
  // REAL, school-chosen effective capacity independent of the vehicle's own
  // physical seat count (e.g. deliberately leaving safety-margin seats
  // empty). Null = fall back to the real vehicle's own physical capacity.
  seatCapOverride Int?

  // Real, optional per-shift fee override — null = fall back to the real
  // parent route's own termFeeKes, so a school that doesn't care about
  // per-shift pricing pays nothing extra in complexity.
  termFeeKesOverride Int?

  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  assignments TransportAssignment[]

  @@unique([tenantId, routeId, name])
  @@index([tenantId, routeId])
}

// I.47 — hardware connection registry: truthful status, never fake connected.
model HardwareDeviceConnection {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceType    String // GPS | BARCODE | THERMAL_PRINTER | RFID | FINGERPRINT | CCTV | FACE_CAMERA
  label         String
  status        String    @default("NOT_CONNECTED") // NOT_CONNECTED | READY_TO_PAIR | CONNECTED | ERROR
  deviceName    String?
  lastSeenAt    DateTime?
  metadataJson  String?
  updatedById   String?
  updatedByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, deviceType, label])
  @@index([tenantId, deviceType, status])
}

// I.47 — GPS bus tracker feed seam. Tracker hardware posts coordinates here.
model GpsBusLocation {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicleId    String?
  vehicleRegNo String?
  trackerId    String
  lat          Float
  lng          Float
  speedKph     Float?
  headingDeg   Float?
  recordedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([tenantId, trackerId, recordedAt])
  @@index([tenantId, vehicleId, recordedAt])
}

// I.47 — CCTV connection seam. Stores camera/NVR endpoints only; no video saved by NEYO.
model CctvCamera {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  location      String
  streamUrl     String?
  status        String    @default("NOT_CONNECTED")
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, status])
}

// B.17 a driver (staff or contracted).
model Driver {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName      String
  phone         String // +254...
  licenseNo     String // DL number
  licenseExpiry String? // YYYY-MM-DD — expiry alerts
  nationalId    String?
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())

  routes TransportRoute[]
  shifts TransportShift[]

  @@unique([tenantId, licenseNo])
  @@index([tenantId])
}

// B.17 a vehicle. insuranceExpiry/inspectionExpiry drive compliance alerts (KE NTSA).
model Vehicle {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  regNo            String // "KCB 123A"
  make             String? // "Toyota Coaster"
  capacity         Int      @default(33)
  insuranceExpiry  String? // YYYY-MM-DD
  inspectionExpiry String? // NTSA inspection sticker
  archived         Boolean  @default(false)
  createdAt        DateTime @default(now())

  routes          TransportRoute[]
  shifts          TransportShift[]
  maintenanceLogs VehicleMaintenance[]
  fuelLogs        FuelLog[]

  @@unique([tenantId, regNo])
  @@index([tenantId])
}

// B.17 maintenance entry (service, repairs, tyres...).
model VehicleMaintenance {
  id          String   @id @default(cuid())
  tenantId    String
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date        String // YYYY-MM-DD
  type        String // SERVICE | REPAIR | TYRES | INSPECTION | OTHER
  description String
  costKes     Int      @default(0)
  odometerKm  Int?
  garage      String?
  createdById String
  createdAt   DateTime @default(now())

  @@index([tenantId, vehicleId, date])
}

// B.17 fuel fill-up. litres + cost; odometer enables consumption tracking.
model FuelLog {
  id          String   @id @default(cuid())
  tenantId    String
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date        String // YYYY-MM-DD
  litres      Float
  costKes     Int
  odometerKm  Int?
  station     String?
  createdById String
  createdAt   DateTime @default(now())

  @@index([tenantId, vehicleId, date])
}

// B.17 student on a route (open while releasedAt null). pickupStop from the route's stops.
model TransportAssignment {
  id          String          @id @default(cuid())
  tenantId    String
  routeId     String
  route       TransportRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  // T.8 — real, optional link to the specific real shift this assignment
  // rides (null for a school that never adopted shifts — the assignment
  // simply uses the route's own direct vehicle, exactly as before).
  shiftId     String?
  shift       TransportShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  studentId   String
  studentName String
  admissionNo String
  pickupStop  String?
  assignedAt  DateTime        @default(now())
  releasedAt  DateTime?

  @@index([tenantId, routeId])
  @@index([tenantId, studentId])
  @@index([tenantId, shiftId])
}

// T.8 — a real parent-portal-initiated request to change transport route
// and/or shift, gated by a real school-level opt-in toggle
// (Tenant.allowParentTransportRequests). NEVER applies itself — a school
// staff member must explicitly approve it (mirroring the same real
// pending-then-approved shape as B.25 Procurement's expense-approval flow
// and R.6's waive/unwaive pattern), at which point the real fee adjustment
// (per the school's own chosen Tenant.transportMidTermBillingRule) is
// applied atomically with the real route/shift reassignment.
model TransportRouteChangeRequest {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  requestedById   String // the real parent/guardian portal User who submitted this
  requestedByName String

  currentRouteId      String?
  currentShiftId      String?
  requestedRouteId    String
  requestedShiftId    String?
  requestedPickupStop String?
  reason              String?

  status String @default("PENDING") // PENDING | APPROVED | DECLINED | CANCELLED

  decidedById   String?
  decidedByName String?
  decidedAt     DateTime?
  declineReason String?

  // Real, honest record of what billing action (if any) was taken when this
  // was approved — never silent, always auditable after the fact.
  billingActionTaken String? // NONE | PRORATED | TOPUP_INVOICE_CREATED | DEFERRED_TO_NEXT_TERM
  billingNote        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, studentId])
}

// B.18 a physical store (Main Store, Kitchen Store, Lab Store...).
model Store {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  location String?
  archived Boolean @default(false)

  items StockItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// B.18 a stock item in a store. qty is the CURRENT balance (updated by
// movements). reorderLevel drives the low-stock alert. sellPriceKes set =
// item can be SOLD to students (uniform, books) → lands on their invoice.
model StockItem {
  id           String        @id @default(cuid())
  tenantId     String
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  category     String // "Food", "Stationery", "Uniform", "Cleaning", "Lab"...
  unit         String        @default("pcs") // pcs | kg | L | bales | boxes
  qty          Float         @default(0)
  reorderLevel Float         @default(0)
  sellPriceKes Int? // set = sellable to students (B.7 invoice link)
  imageUrl     String? // G.24 uniform catalogue photo (A.9 storage)
  sizes        UniformSize[] // B.25 per-size stock split
  trackExpiry  Boolean       @default(false) // perishables -> batch+expiry mode
  archived     Boolean       @default(false)
  createdAt    DateTime      @default(now())

  batches   StockBatch[]
  movements StockMovement[]

  @@unique([tenantId, storeId, name])
  @@index([tenantId, storeId])
}

// B.18 a batch of a perishable item (flour, rice, lab reagents).
model StockBatch {
  id         String    @id @default(cuid())
  tenantId   String
  itemId     String
  item       StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batchNo    String
  qty        Float
  expiryDate String? // YYYY-MM-DD — expiry alerts
  receivedAt DateTime  @default(now())

  @@index([tenantId, itemId])
}

// B.18 every stock change — the audit trail. type: IN | OUT | SALE | ADJUST.
// SALE rows carry the student + the invoice the sale was billed to.
model StockMovement {
  id          String    @id @default(cuid())
  tenantId    String
  itemId      String
  item        StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type        String // IN | OUT | SALE | ADJUST
  qty         Float // positive number; sign comes from type
  reason      String? // "Term 2 delivery", "Kitchen issue — lunch", "Sold to student"
  studentId   String? // SALE: who bought it
  studentName String?
  invoiceId   String? // SALE: the B.7 invoice it was billed to
  byId        String
  byName      String
  createdAt   DateTime  @default(now())

  @@index([tenantId, itemId, createdAt])
  @@index([tenantId, studentId])
}

// B.18 a fixed asset (separate from consumable stock): computers, furniture,
// vehicles already have their own module — this is the general register.
model Asset {
  id                     String             @id @default(cuid())
  tenantId               String
  tenant                 Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tag                    String // "KH-AST-0001"
  name                   String
  category               String // "ICT", "Furniture", "Kitchen", "Sports"...
  location               String?
  custodian              String? // person responsible
  acquiredOn             String? // YYYY-MM-DD
  valueKes               Int                @default(0)
  condition              String             @default("GOOD") // GOOD | FAIR | NEEDS_REPAIR | DISPOSED
  // B.25: straight-line depreciation — % of acquisition value per year.
  // 0 = no depreciation (land). Book value computed from acquiredOn.
  depreciationPctPerYear Int                @default(0)
  // B.25: next planned service date (YYYY-MM-DD) — due/overdue badges.
  nextMaintenanceOn      String?
  archived               Boolean            @default(false)
  createdAt              DateTime           @default(now())
  maintenance            AssetMaintenance[]

  @@unique([tenantId, tag])
  @@index([tenantId])
}

// B.25 maintenance/repair log per asset (mirrors B.17 VehicleMaintenance).
model AssetMaintenance {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  date      String // YYYY-MM-DD
  kind      String   @default("SERVICE") // SERVICE | REPAIR | INSPECTION | OTHER
  costKes   Int      @default(0)
  note      String?
  byName    String
  createdAt DateTime @default(now())

  @@index([tenantId, assetId])
}

// B.19 weekly menu — one entry per day+meal. menu is the dish text.
model MealPlanEntry {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 1=Mon .. 7=Sun
  mealType  String // BREAKFAST | LUNCH | SUPPER
  menu      String // "Githeri + greens", "Ugali, sukuma, beef stew"
  updatedAt DateTime @updatedAt

  @@unique([tenantId, dayOfWeek, mealType])
  @@index([tenantId])
}

// H.5 Cafeteria Table Allocation — students are seated per CLASS (never mixed
// across classes/streams) at tables of a chosen size, for a meal session
// (LUNCH | SUPPER). One row per table; the seated learners are stored as JSON
// (id/name/admNo frozen at allocation time) so the seating plan is printable.
model CafeteriaTable {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session      String // LUNCH | SUPPER
  classId      String
  classLabel   String // "Form 2 East" frozen at allocation
  tableNo      Int // 1-based within the class
  seats        Int // table size used
  studentsJson String // JSON array of { id, name, admNo }
  createdAt    DateTime @default(now())

  @@unique([tenantId, session, classId, tableNo])
  @@index([tenantId, session])
}

// I.19/B.19 — Cafeteria meal serving queue. One queue per date + meal session.
model CafeteriaQueueEntry {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date         String // YYYY-MM-DD
  session      String // BREAKFAST | LUNCH | SUPPER
  queueNo      Int
  studentId    String
  studentName  String
  admissionNo  String
  classLabel   String?
  status       String    @default("WAITING") // WAITING | SERVED | CANCELLED
  joinedAt     DateTime  @default(now())
  servedAt     DateTime?
  servedById   String?
  servedByName String?

  @@unique([tenantId, date, session, studentId])
  @@index([tenantId, date, session, status])
  @@index([tenantId, studentId])
}

// B.19 a student's meal card (e.g. lunch plan for the term). Issued =
// IMMEDIATELY billed to the student's invoice (founder rule). cardNo printed
// on the card the student shows at the serving line.
model MealCard {
  id                 String            @id @default(cuid())
  tenantId           String
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cardNo             String // MC-0001
  studentId          String
  studentName        String
  admissionNo        String
  planName           String // "Lunch plan — Term 2 2026"
  meals              String // JSON array of meal types covered, e.g. ["LUNCH"]
  termFeeKes         Int
  invoiceId          String // the B.7 invoice this card was billed to
  year               Int
  term               Int
  active             Boolean           @default(true)
  issuedAt           DateTime          @default(now())
  cancelledAt        DateTime?
  // T.9 — founder-confirmed: "a school chooses what they want" when a
  // class-level default feeding cost changes mid-term. followsLiveDefault
  // is chosen PER CARD at issue time (bulk-issue lets a staff member pick
  // once for the whole batch): false (default) = the current, safe,
  // already-proven LOCKED behavior — termFeeKes never changes once
  // invoiced, exactly like every other NEYO fee always has. true = this
  // card's real feePlanId is tracked and a real sync job/action can push
  // the card's live plan cost forward — but NEVER retroactively touches an
  // invoice that's already been raised; a "sync" only affects a FUTURE
  // top-up, never rewrites history.
  followsLiveDefault Boolean           @default(false)
  feePlanId          String?
  feePlan            CafeteriaFeePlan? @relation(fields: [feePlanId], references: [id], onDelete: SetNull)

  @@unique([tenantId, cardNo])
  @@index([tenantId, studentId])
}

// T.9 — a real, school-configurable default feeding cost per class LEVEL
// (or an exact class/stream override), mirroring FeeStructure's own real
// per-level/optional-class-override shape exactly (never a parallel
// concept). Used by bulkIssueCards() to auto-issue every ACTIVE student in
// a level/class a real meal card + invoice in one action, and — for a card
// that opted into followsLiveDefault — as the real live source a sync
// action reads from.
model CafeteriaFeePlan {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String // "Form 2 — Lunch — Term 2 2026"
  level      String // class level this plan applies to ("Form 2", "Grade 4")
  classId    String? // optional exact class/stream override
  meals      String // JSON array, e.g. ["LUNCH"]
  termFeeKes Int
  year       Int
  term       Int
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())

  cards MealCard[]

  @@unique([tenantId, level, year, term, classId])
  @@index([tenantId, archived])
}

// T.9 — a real parent-portal-initiated request to enroll or cancel a
// child's feeding-program membership mid-term, gated by a real school-
// level opt-in toggle (Tenant.allowParentCafeteriaRequests) — the exact
// same real pending-then-approved shape as T.8's TransportRouteChangeRequest
// and B.25 Procurement's expense-approval flow. NEVER applies itself; a
// real staff member must explicitly approve it, at which point the real
// card issue/cancel (with its own real invoice side effects) fires.
model CafeteriaEnrollmentRequest {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  requestedById   String // the real parent/guardian portal User who submitted this
  requestedByName String

  action String // ENROLL | CANCEL
  reason String?

  status String @default("PENDING") // PENDING | APPROVED | DECLINED | CANCELLED

  decidedById   String?
  decidedByName String?
  decidedAt     DateTime?
  declineReason String?

  // Real, honest record of what happened when this was approved.
  resultCardId String?
  resultNote   String?

  createdAt DateTime @default(now())

  @@index([tenantId, status])
  @@index([tenantId, studentId])
}

// G.24 a parent's uniform order from the catalogue. Billed to the student's
// invoice on PLACEMENT (founder rule); the supplier/tailor delivers at school.
// status: PLACED -> SENT_TO_SUPPLIER -> DELIVERED (or CANCELLED).
model UniformOrder {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNo     String // UO-0001
  studentId   String
  studentName String
  admissionNo String
  itemId      String // StockItem (Uniform category)
  itemName    String
  size        String? // "Size 32", "M", custom note
  qty         Int
  unitKes     Int
  totalKes    Int
  invoiceId   String // billed at placement (founder invoice rule)
  status      String    @default("PLACED")
  placedById  String // the PARENT (or staff) who ordered
  placedAt    DateTime  @default(now())
  deliveredAt DateTime?

  @@unique([tenantId, orderNo])
  @@index([tenantId, studentId])
  @@index([tenantId, status])
}

// G.22 PLATFORM feature flags (NEYO company level — NOT tenant-owned!).
// SUPER_ADMIN pauses a module key globally while we keep building it:
// paused modules disappear from nav + block APIs for ALL schools, with a
// "coming soon" note. No row = live.
model PlatformFlag {
  id        String   @id @default(cuid())
  moduleKey String   @unique
  paused    Boolean  @default(false)
  note      String? // "Cafeteria is in beta — back next week"
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// T.3 — School-Requested Custom Feature Pipeline. A real school describes a
// bespoke feature they want; NEYO Ops reviews, quotes a real recurring
// per-period cost, and — once built — grants it to that ONE school via the
// existing real J.23 `feature-grants.service.ts` mechanism (founder's own
// words: "have a flag area for custom fees and the team should tell the
// school about the cost that will be incurred per period when their feature
// is launched to them" — never a brand-new one-off PlatformFlag per feature).
// `deliveredFeatureKey` links a DELIVERED request to the real grant key used,
// so "those who request the same [feature already built for someone else]
// can get their features being delivered in the same route" — NEYO Ops can
// see which requests already map to an existing key and grant it instantly
// rather than re-quoting/re-building. `platformReleaseNote` records NEYO's
// own later decision to "launch the whole to the whole NEYO ecosystem"
// (release a custom one-off to every school), a real, explicit, separate
// step from a single-school grant.
model CustomFeatureRequest {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title           String
  description     String
  requestedById   String
  requestedByName String

  // SUBMITTED -> REVIEWING -> QUOTED -> APPROVED -> IN_PROGRESS -> DELIVERED
  // (or DECLINED at REVIEWING/QUOTED)
  status String @default("SUBMITTED")

  quotedPriceKes     Int? // real recurring cost per billing period, once quoted
  quotedBillingCycle String? // "MONTHLY" | "TERMLY" | "YEARLY" (matches Subscription's real cadence concepts)
  opsNote            String? // NEYO Ops-only internal note (never shown to the school)
  schoolReply        String? // the school's own real response to a quote (accept/decline reasoning)
  declineReason      String?

  // Once actually built and granted, the real feature-grant key used —
  // lets a later, same-idea request from a DIFFERENT school be recognised
  // and delivered via the same existing grant instantly, without re-quoting.
  deliveredFeatureKey String?
  deliveredAt         DateTime?

  // NEYO's own later decision to make this available to EVERY school, not
  // just the one(s) who originally asked and paid for it — a real, distinct,
  // explicit step (never automatic/implied by a single-school delivery).
  releasedToAllSchools Boolean   @default(false)
  releasedAt           DateTime?

  decidedById   String?
  decidedByName String?
  decidedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([status])
}

// T.5a — Background Task Runner. A real, persistent, user-visible tracking
// row for any long user-initiated action (bulk import, bulk PDF batch,
// timetable regeneration, etc.) — genuinely generalizes the pattern
// `TimetableGenerationJob` already proved for ONE specific feature, so ANY
// long real action can show "N tasks running" in the Topbar and fire a real
// in-app notification (reusing the existing A.7 `notify()` cascade) the
// moment it finishes, wherever the user has since navigated to.
model BackgroundJob {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  kind     String // "STUDENT_IMPORT" | "BUNDI_IMPORT" | "LIBRARY_IMPORT" | "STAFF_IMPORT" | "REPORT_CARD_BATCH" | ...
  label    String // human-readable, e.g. "Importing 240 students from Form 2 East.xlsx"
  status   String @default("QUEUED") // QUEUED | RUNNING | DONE | FAILED
  progress Int    @default(0) // 0..100

  resultJson String? // real, kind-specific result summary once DONE (e.g. {created, updated, failed})
  error      String?

  startedById   String
  startedByName String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?

  @@index([tenantId, status])
  @@index([tenantId, startedById, status])
}

// B.20 a discipline incident. Demerit points feed behavior tracking.
// severity: MINOR | MAJOR | SEVERE. MAJOR+ auto-SMS the guardian.
model DisciplineIncident {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId        String
  studentName      String
  admissionNo      String
  date             String // YYYY-MM-DD
  category         String // FIGHTING | BULLYING | LATENESS | NOISEMAKING | SNEAKING | VANDALISM | CHEATING | OTHER
  severity         String // MINOR | MAJOR | SEVERE
  points           Int       @default(1) // demerit points (behavior tracking)
  description      String
  actionTaken      String? // "Warned", "Manual work", "Sent to deputy"
  reportedById     String
  reportedByName   String
  status           String    @default("APPROVED") // PENDING | APPROVED | REJECTED
  approvedById     String?
  approvedByName   String?
  approvedAt       DateTime?
  decisionNote     String?
  parentNotifiedAt DateTime?
  proofFileUrl     String? // Added for incident photo proof (H.3)
  proofFileName    String? // Added for incident photo proof name (H.3)
  createdAt        DateTime  @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, date])
}

// B.20 a suspension. Active while status=ACTIVE and today <= endDate.
model Suspension {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId        String
  studentName      String
  admissionNo      String
  startDate        String // YYYY-MM-DD
  endDate          String
  reason           String
  conditions       String? // "Return with parent", "Letter of apology"
  status           String    @default("ACTIVE") // ACTIVE | COMPLETED | REVOKED
  issuedById       String
  issuedByName     String
  approvedById     String?
  approvedByName   String?
  approvedAt       DateTime?
  decisionNote     String?
  parentNotifiedAt DateTime?
  createdAt        DateTime  @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, status])
}

// B.20 CONFIDENTIAL counseling note. Only counseling.confidential holders
// (Principal/Deputy) ever read these — never parents, never regular staff.
model CounselingNote {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId     String
  studentName   String
  date          String // YYYY-MM-DD
  sessionType   String // INDIVIDUAL | GROUP | FAMILY | REFERRAL
  note          String // the confidential record
  followUpOn    String? // YYYY-MM-DD reminder
  counselorId   String
  counselorName String
  createdAt     DateTime @default(now())

  @@index([tenantId, studentId])
}

// B.21 one medical profile per student: blood group, chronic conditions,
// ALLERGIES (JSON array — drives alerts on clinic + kitchen), SHA number.
model StudentMedical {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId  String   @unique
  bloodGroup String? // A+ B- O+ ...
  conditions String? // "Asthma", "Sickle cell trait"
  allergies  String? // JSON array of strings: ["Penicillin","Groundnuts"]
  shaNumber  String? // SHA (ex-NHIF) member number
  notes      String?
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}

// B.21 a clinic/sickbay visit.
model ClinicVisit {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId        String
  studentName      String
  admissionNo      String
  date             String // YYYY-MM-DD
  complaint        String // "Headache and fever"
  treatment        String // "Paracetamol 500mg, rest"
  medicationGiven  String?
  referredTo       String? // "Kiambu Level 5" when referred out
  recordedById     String
  recordedByName   String
  parentNotifiedAt DateTime? // referrals SMS the guardian
  createdAt        DateTime  @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, date])
}

// B.21 an ongoing medication plan (e.g. asthma inhaler, antibiotics course).
model MedicationPlan {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId   String
  studentName String
  drug        String // "Amoxicillin 250mg"
  dosage      String // "1 tablet"
  frequency   String // "3x daily after meals"
  startDate   String // YYYY-MM-DD
  endDate     String?
  active      Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())

  doses MedicationDose[]

  @@index([tenantId, studentId])
}

// B.21 each administered dose (the tracking trail).
model MedicationDose {
  id       String         @id @default(cuid())
  tenantId String
  planId   String
  plan     MedicationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  givenAt  DateTime       @default(now())
  byId     String
  byName   String
  note     String?

  @@index([tenantId, planId])
}

// G.31 print queue (founder 2026-06-12): documents print THEMSELVES at the
// reception print station. If the printer/station is off, jobs stay QUEUED
// and flush automatically when it comes back. kind: INVOICE | RECEIPT |
// CLASS_BATCH (all invoices of a class in one PDF for easy distribution).
model PrintJob {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind       String // INVOICE | RECEIPT | CLASS_BATCH
  refId      String // invoiceId / paymentId / structureId
  classId    String? // grouping for distribution
  classLabel String? // "Form 2 East" frozen at queue time
  title      String // "Invoice KH-INV-000012 — Achieng (PAID)"
  url        String // the PDF endpoint the station fetches
  status     String    @default("QUEUED") // QUEUED | PRINTED | FAILED
  queuedBy   String // "System (cash payment)" / user name
  queuedAt   DateTime  @default(now())
  printedAt  DateTime?

  @@index([tenantId, status])
  @@index([tenantId, classId])
}

// H.2 Customized Printing Limits — when a non-privileged user hits their daily
// print limit, they raise a PrintApprovalRequest that a Principal/Deputy/HOD
// approves. Approval lets that user print one more document of that kind.
model PrintApprovalRequest {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedByName String
  docKind         String // INVOICE | RECEIPT | REPORT_CARD | ID_CARD | TRANSCRIPT | LETTER | OTHER
  docRef          String? // e.g. invoiceId — what they want to print
  reason          String?
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED | USED
  decidedById     String?
  decidedByName   String?
  decidedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId, status])
  @@index([tenantId, requestedById, status])
}

// B.22 a gate pass: a student leaving campus during school hours (clinic
// runs, family emergencies). Must be authorised; gate staff check the code.
model GatePass {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  passNo         String // GP-0001 — quoted at the gate
  studentId      String
  studentName    String
  admissionNo    String
  reason         String
  leaveAt        DateTime
  returnBy       DateTime? // null = not returning today
  escortName     String? // who picks/escorts the learner
  status         String    @default("ACTIVE") // ACTIVE | USED | EXPIRED | CANCELLED
  issuedById     String
  issuedByName   String
  approvedById   String?
  approvedByName String?
  approvedAt     DateTime?
  decisionNote   String?
  usedAt         DateTime? // stamped by the gate when the student exits
  returnedAt     DateTime? // EE.11 — stamped when the student checks back in at the gate
  createdAt      DateTime  @default(now())

  @@unique([tenantId, passNo])
  @@index([tenantId, status])
  @@index([tenantId, studentId])
}

// B.22 authorised-pickup list: ONLY these people may collect the student.
model PickupPerson {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId    String
  fullName     String
  relationship String // "Mother", "Uncle", "House help"
  phone        String // +254...
  nationalId   String? // checked at the gate
  active       Boolean  @default(true)
  addedById    String
  createdAt    DateTime @default(now())

  @@index([tenantId, studentId])
}

// H.4 Alternate Pickup verification — a ONE-TIME authorization for someone NOT
// on the permanent pickup list. The parent (or office) creates it with a secure
// short code and optionally an uploaded screenshot of the confirmation message
// they sent the picker. The guard verifies the code (and/or views the
// screenshot) at the gate, which marks it USED + SMS-confirms the parent.
model AltPickupAuthorization {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId      String
  studentName    String // frozen for the gate sheet
  pickerName     String
  pickerPhone    String? // +254...
  relationship   String? // "Aunt", "Family friend"
  code           String // secure short verification code shown at the gate
  screenshotUrl  String? // A.9 file: screenshot of the parent's confirmation message
  screenshotName String?
  status         String    @default("ACTIVE") // ACTIVE | USED | CANCELLED | EXPIRED
  expiresAt      DateTime // single-day validity by default
  verifiedAt     DateTime?
  verifiedById   String?
  createdById    String
  createdByName  String
  createdAt      DateTime  @default(now())

  @@index([tenantId, status])
  @@index([tenantId, studentId])
}

// B.22 emergency panic alert: any staff triggers; leadership is SMSed and
// every staff member gets an in-app alert instantly.
model PanicAlert {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind         String // FIRE | MEDICAL | INTRUDER | OTHER
  location     String // "Science lab block"
  note         String?
  raisedById   String
  raisedByName String
  resolvedAt   DateTime?
  resolvedBy   String?
  smsSent      Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([tenantId, createdAt])
}

// B.3 teacher + support-staff attendance (clock in/out). One row per user/day.
model StaffAttendance {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  userName     String // denormalized for fast lists
  role         String
  date         String // YYYY-MM-DD (Nairobi)
  clockInAt    DateTime
  clockOutAt   DateTime?
  // G.17 GPS verification (null = clocked in before geofencing / geofence off)
  gpsVerified  Boolean   @default(false)
  gpsLat       Float?
  gpsLng       Float?
  gpsDistanceM Int?

  @@unique([tenantId, userId, date])
  @@index([tenantId, date])
}

// B.2 admission application — the pipeline record.
// status: APPLIED -> REVIEW -> INTERVIEW -> OFFER (waiting deposit) ->
//         ADMITTED | WAITLISTED | REJECTED | WITHDRAWN
model AdmissionApplication {
  id            String @id @default(cuid())
  tenantId      String
  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applicationNo String // KH-ADM-000001 (A.4)
  status        String @default("APPLIED")

  // applicant
  firstName      String
  middleName     String?
  lastName       String
  gender         String // M | F
  dateOfBirth    String? // YYYY-MM-DD
  gradeWanted    String // "Grade 4" / "Form 1"
  curriculum     String? // CBC | 8-4-4
  previousSchool String?

  // guardian
  guardianName  String
  guardianPhone String
  guardianEmail String?

  notes  String?
  source String  @default("online") // online | walk_in | inquiry

  // interview (B.2.3)
  interviewDate   String? // YYYY-MM-DD
  interviewTime   String? // HH:MM
  interviewNote   String?
  calendarEventId String?

  // deposit-before-admission (B.2.8)
  depositRequiredKes Int       @default(0)
  depositPaidKes     Int       @default(0)
  depositPaidAt      DateTime?
  depositRef         String?

  // outcome
  decisionNote String?
  letterCode   String? // admission letter verification (A.10)
  studentId    String? @unique // set when admitted -> B.1 student created
  inquiryId    String? // A.18 AdmissionInquiry origin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, applicationNo])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// G.16 promotion / reshuffle run. moves JSON = [{studentId, fromClassId,
// toClassId|null, graduated?:bool, prevStatus?, prevGradYear?}] — enables undo.
model PromotionRun {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind          String // "promotion" | "reshuffle"
  summary       String // human description ("Promoted 5 classes · 142 students · 38 graduated")
  moves         String // JSON move log (undo source of truth)
  undoneAt      DateTime?
  createdById   String
  createdByName String
  createdAt     DateTime  @default(now())

  @@index([tenantId, createdAt])
}

// AA.3 — a permanent, read-only historical snapshot of ONE real class
// (e.g. "Form 4 West") taken at the exact moment its final-year cohort
// graduates, BEFORE that same class row is quietly reused next year for the
// class moving up into it (e.g. Form 3 West -> Form 4 West). This is what
// lets NEYO keep reusing the same SchoolClass ID across years — which is
// what makes teacher continuity "just carry over" automatically — WITHOUT
// ever losing or blurring a graduated year's own real roster and real
// subject-teacher allocation. One row per graduated class per graduation
// event (a class could in principle appear again in a future year if a
// school somehow re-used a level/stream name after a gap — each event gets
// its own permanent row, never overwritten).
//
// Deliberately independent of stream COUNT or naming per level — a school
// where e.g. Form 1 has 3 streams (East/West/North) but Form 4 only has 2
// (East/West) already works today because SchoolClass rows are individually
// keyed by (level, stream), not by an assumed symmetric grid; this history
// table follows the exact same one-row-per-real-class-instance model, so it
// needs no special handling for uneven stream counts across levels or years.
model ClassYearHistory {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId          String // the real SchoolClass.id that graduated (and will be reused)
  level            String // "Form 4" — the level AS OF the graduation moment
  stream           String? // "West" (null = single-stream)
  curriculum       String // "CBC" | "8-4-4" — as of the graduation moment
  graduationYear   Int // the real Class of YYYY this snapshot belongs to
  promotionRunId   String? // the real PromotionRun that produced this snapshot, if any
  studentCount     Int
  roster           String // JSON [{id, name, admissionNo, gender}] — frozen at graduation
  subjectTeachers  String // JSON [{subjectId, subjectName, teacherId, teacherName, lessonsPerWeek}] — frozen ClassSubjectNeed allocation at graduation
  classTeacherId   String?
  classTeacherName String?
  createdById      String
  createdByName    String
  createdAt        DateTime @default(now())

  @@index([tenantId, graduationYear])
  @@index([tenantId, classId])
}

// AA.3 — tracks one real "New Academic Year — Teacher Allocation Review"
// wizard session per level, tying together the already-real Continuity
// Engine (L.7) + autoAssignTeachersToClasses() specifically for the
// post-promotion moment. A Principal walks through it level-by-level right
// after committing a promotion; this row is the honest, auditable record of
// which real decision was made per subject/class-teacher slot (KEEP the
// existing teacher, REPLACE with a specific recommended/chosen teacher, or
// AUTO — let NEYO's own fair auto-assign fill it), and whether it has been
// applied yet. Never a hidden background process — always staff-reviewed
// and staff-confirmed before any real ClassSubjectNeed/SchoolClass row
// changes, exactly like every other real decision this session's Continuity
// Engine already requires.
model TeacherAllocationReviewRun {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promotionRunId  String? // the real PromotionRun this review follows, if any
  level           String // the level being reviewed, e.g. "Form 2"
  status          String    @default("IN_PROGRESS") // "IN_PROGRESS" | "COMPLETED"
  decisions       String // JSON [{classId, subjectId|null, roleType: "SUBJECT"|"CLASS_TEACHER", decision: "KEEP"|"REPLACE"|"AUTO", teacherId|null}]
  appliedCount    Int       @default(0)
  autoFilledCount Int       @default(0)
  createdById     String
  createdByName   String
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, level])
}

// L.7 — Automatic admissions grouping / annual reshuffle rules.
model ClassGroupingRule {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  targetLevel String? // e.g. "Form 3" or null = all levels
  ruleType    String   @default("SUBJECT_SET") // SUBJECT_SET | BALANCE | SCHOOL_DEFINED
  priority    Int      @default(100)
  active      Boolean  @default(true)
  configJson  String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, targetLevel, active])
}

// L.7 — Teacher continuity / fairness workload settings.
model TeacherWorkloadRule {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId          String?
  maxClasses         Int? // max distinct classes/streams teacher may handle
  maxLessonsPerWeek  Int?
  retainSubjectLoads Boolean  @default(true)
  retainClassTeacher Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId, teacherId])
}

// L.7 — continuity of class-group teachers across academic years.
model TeacherContinuityAssignment {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  levelKey  String // logical cohort key, e.g. "Form 1::EAST"
  subjectId String?
  classId   String?
  teacherId String
  roleType  String   @default("SUBJECT") // SUBJECT | CLASS_TEACHER
  locked    Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, levelKey, roleType, active])
  @@index([tenantId, teacherId, active])
}

// L.7 — formal teacher transfer/change event with impact + recommendation snapshot.
model TeacherTransferImpact {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId            String
  replacementTeacherId String?
  status               String   @default("OPEN") // OPEN | APPLIED | DISMISSED
  reason               String?
  affectedJson         String   @default("[]")
  recommendationJson   String   @default("[]")
  timetableJobId       String?
  createdById          String
  createdByName        String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId, teacherId, status])
}

// B.3 daily class attendance. One row per student per day (idempotent upsert).
// status: P present | A absent | L late | E excused.
// I.6 Principal Powers & Delegation: non-sensitive tasks assigned by Principal/Owner to teachers.
model PrincipalDelegationTask {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title          String
  details        String?
  category       String    @default("GENERAL") // GENERAL | ACADEMICS | ATTENDANCE_FOLLOWUP | PARENT_FOLLOWUP | DUTY
  assignedToId   String
  assignedToName String
  assignedById   String
  assignedByName String
  dueDate        String?
  status         String    @default("OPEN") // OPEN | DONE | CANCELLED
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, assignedToId, status])
  @@index([tenantId, assignedById, createdAt])
}

model AttendanceRecord {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId      String? // class at the time of marking (kept even if student moves)
  date         String // YYYY-MM-DD (Nairobi day)
  status       String // P | A | L | E
  note         String?
  smsSentAt    DateTime? // absentee auto-SMS bookkeeping (dedupe)
  markedById   String
  markedByName String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, studentId, date])
  @@index([tenantId, classId, date])
  @@index([tenantId, date])
}

// N.2 — QR Hardware Integration: every scan of a student's ID QR at the gate/
// front-desk is logged here (audit trail + the actual duplicate-scan guard).
// A scan is rejected as a duplicate if the SAME student was scanned for the
// SAME action within the cooldown window (protects against a camera reading
// the same code twice in one pass, or a student tapping the QR repeatedly).
model QrScanEvent {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation("QrScanStudent", fields: [studentId], references: [id], onDelete: Cascade)
  action        String // "ATTENDANCE" | "PAYMENT_LOOKUP"
  result        String // "OK" | "DUPLICATE" | "BLOCKED"
  detail        String? // e.g. "Marked present" / "Already scanned 4s ago"
  scannedById   String
  scannedByName String
  createdAt     DateTime @default(now())

  @@index([tenantId, studentId, action, createdAt])
}

// B.1 transfer-out record (school-to-school). One ACTIVE transfer per student;
// undo soft-reverses it (keeps the row for history, marks reversedAt).
model StudentTransfer {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  destinationSchool String
  destinationCounty String?
  transferDate      String // YYYY-MM-DD
  reason            String? // relocation | fees | boarding | discipline | other (free text allowed)
  previousClassId   String? // restored on undo
  letterCode        String? // DocumentVerification code for the leaving letter
  reversedAt        DateTime?
  createdById       String
  createdByName     String
  createdAt         DateTime  @default(now())

  @@index([tenantId, studentId])
}

// B.1 bulk import history. One row per committed import run (CSV/XLSX/paste).
// errorRows keeps the per-row failures as JSON so the bursar can fix + retry.
// R.1 (2026-07-03) — "smart import" (create-OR-update): a re-import matching
// an EXISTING student (by admission no/UPI/birth-cert/name+DOB/name+guardian
// phone) now fills in missing fields and adds new info instead of always
// being rejected as a duplicate or silently creating a second student row.
model StudentImport {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileName      String? // null when pasted from Google Sheets/clipboard
  source        String // "csv" | "xlsx" | "paste"
  totalRows     Int
  createdRows   Int
  updatedRows   Int      @default(0) // R.1 — rows that matched an existing student and were enriched, not duplicated
  failedRows    Int
  errorRows     String? // JSON [{row, message}] (null when none)
  targetClassId String? // M.4 — set when this run imported into ONE specific class only
  // BB.4 — a real, honest count of how many real StudentSubjectSelection
  // rows this import run itself created (from an optional real "Subjects"
  // column + a real declared-compulsory-subjects list, e.g. a fresh Grade
  // 10 intake arriving with subject choices already made in Junior
  // Secondary). Zero for every import that doesn't map a Subjects column —
  // no behaviour change for any pre-existing import flow.
  subjectSelectionsCreated Int      @default(0)
  createdById              String
  createdByName            String
  createdAt                DateTime @default(now())

  @@index([tenantId, createdAt])
}

// BB.4 — a real, auditable record of one "Allocate Class" wizard run: takes
// a level's real students (freshly imported or already enrolled) with real
// confirmed StudentSubjectSelection data and places them into real classes
// by subject combination, reusing the exact same real fair-grouping engine
// L.7's runAutoGroupingPreview()/commitAutoGrouping() already provides —
// BB.4 never invents a second placement algorithm. This row exists purely
// so a school can see WHEN a Grade 10 (or any level's) intake was allocated,
// how many real classes were created vs. reused, and which real
// PromotionRun (the actual student-move ledger) resulted, mirroring the
// exact same "wizard session -> real underlying engine call" pattern AA.3's
// TeacherAllocationReviewRun already established.
model ClassAllocationRun {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  level String // the level allocated, e.g. "Grade 10"

  // "CREATE_NEW" — the wizard created its own real new classes/streams for
  // this run (school supplied streamCount + capacity); "USE_EXISTING" — the
  // wizard placed students into real classes that already existed (e.g.
  // already named in the import file), never creating a new one.
  classStrategy String // "CREATE_NEW" | "USE_EXISTING"

  streamCount      Int? // real number of classes created, when classStrategy = CREATE_NEW
  capacityPerClass Int? // the real per-class cap the school chose for this run (feeds BB.3)

  createdClassIds String @default("[]") // JSON — real SchoolClass.id[] genuinely created by this run (empty for USE_EXISTING)

  // The real underlying calls this run made — never a duplicate engine.
  promotionRunId String? // the real L.7 PromotionRun produced by commitAutoGrouping()
  timetableJobId String? // the real background TimetableGenerationJob, if the school chose to generate immediately after

  totalStudents          Int @default(0)
  classSubjectNeedsSeeded Int @default(0) // real ClassSubjectNeed rows this run created from students' actual subject combinations
  teachersAutoAssigned    Int @default(0) // real teacher gaps filled by the existing fair auto-assign engine

  status String @default("PENDING") // "PENDING" | "COMPLETED" | "FAILED"

  createdById   String
  createdByName String
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, level])
}

// PART M.4 — Import Engine Upgrades: schools can map spreadsheet columns
// beyond the fixed IMPORT_FIELDS list (e.g. "House", "Sponsor", "Previous
// School") onto a student, kept as clean labeled key/value pairs — never
// mixed into the free-text `notes` field, and never depending on AI (the
// school types the label once at mapping time; matching stays deterministic).
model StudentCustomField {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  label     String // school-defined column label, e.g. "House"
  value     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, label])
  @@index([tenantId, studentId])
}

// Verifiable document record (A.10). The QR on a receipt/report points to
// /verify/<code>; we confirm it matches the issued payload (anti-forgery).
model DocumentVerification {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String   @unique // short public code in the QR/URL
  docType     String // "payment_receipt", "report_card", ...
  summary     String // human-readable one-liner shown on the verify page
  payloadHash String // sha256 of the canonical document data
  createdAt   DateTime @default(now())
  // N.2 — when docType = "student_id", the ID card's QR resolves DIRECTLY to
  // this real student (not just a human-readable summary string), so a gate/
  // reception scan can trigger real 1-tap attendance/payment actions without
  // any fragile name-matching. Null for every other docType.
  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
}

// A stored file (A.9). Tenant-owned; key is tenant-prefixed for isolation.

model TenantStorageProvider {
  id                  String    @id @default(cuid())
  tenantId            String    @unique
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider            String    @default("NEYO_MANAGED_OBJECT_STORAGE") // NEYO_MANAGED_OBJECT_STORAGE | GOOGLE_WORKSPACE_MANAGED | GOOGLE_WORKSPACE_BYOS
  status              String    @default("DESIGN_READY") // DESIGN_READY | READY_TO_CONNECT | CONNECTED | ERROR | DISABLED
  accountEmail        String?
  rootFolderId        String?
  storageLimitBytes   BigInt    @default(16106127360) // 15 GiB starter where available
  storageUsedBytes    BigInt    @default(0)
  encryptionMode      String    @default("AES_256_GCM_ENVELOPE")
  healthStatus        String    @default("NOT_CONNECTED") // NOT_CONNECTED | HEALTHY | WARNING | ERROR
  lastHealthCheckAt   DateTime?
  lastUpgradePromptAt DateTime?
  upgradePlan         String?
  notes               String?

  // R.7 — School-Linked External Storage. A real founder request: a school
  // that doesn't want to pay NEYO for extra storage can paste a link to
  // their OWN external storage (Google Drive/Dropbox/OneDrive/etc folder)
  // as their real overflow destination. A bare pasted link genuinely cannot
  // receive automatic uploads from NEYO (Drive/Dropbox require a real OAuth
  // connection to write files, a much bigger, separate project) — so this
  // is honestly modeled as a real, verified signpost: NEYO keeps doing all
  // the real uploading/storing it already does, and clearly surfaces this
  // link as "move your older files here yourself" the moment NEYO's own
  // storage genuinely starts filling up, with automatic fallback to NEYO's
  // own paid storage warning if the school ignores it.
  linkedStorageUrl         String? // the real pasted folder link
  linkedStorageLabel       String? // e.g. "School Google Drive" — the school's own name for it
  linkedStorageProvider    String? // GOOGLE_DRIVE | DROPBOX | ONEDRIVE | OTHER — auto-detected from the URL, never guessed silently
  linkedStorageAddedById   String?
  linkedStorageAddedAt     DateTime?
  linkedStorageVerifiedAt  DateTime? // last time NEYO confirmed the link is genuinely still reachable (a real HTTP check, not just saved)
  linkedStorageLastCheckOk Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([provider, healthStatus])
}

model StorageUsageSnapshot {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       String
  usedBytes      BigInt
  limitBytes     BigInt
  percentUsed    Int
  healthStatus   String
  actionRequired String?
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([healthStatus])
}

model StoredFile {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key              String   @unique // storage object key, e.g. tenants/<id>/uploads/<uuid>.jpg
  url              String // public/served URL
  fileName         String
  contentType      String
  size             Int // bytes
  category         String   @default("general") // avatar, attachment, document...
  provider         String   @default("LOCAL_OR_R2")
  providerObjectId String?
  encrypted        Boolean  @default(false)
  encryptionMode   String?
  checksumSha256   String?
  wrappedKeyRef    String?
  uploadedById     String
  createdAt        DateTime @default(now())

  // W.1 — Storage Intelligence Engine (founder-requested 2026-07-06). A real
  // 3-tier file-lifecycle classification, never silently guessed: PERMANENT
  // (student/fee/attendance/certificate/CBE-evidence records — the school's
  // real official records, NEVER auto-deleted), GENERATED (a real,
  // regenerate-on-demand artifact like a report-card PDF — safe to prune,
  // NEYO can always rebuild it from the underlying data), TEMPORARY (a real
  // failed-import scratch file, OCR working image, draft export — safe to
  // auto-delete after a short real window). Defaults to PERMANENT so any
  // pre-existing/unclassified file is always treated as the safest, never-
  // delete case until explicitly reclassified by the real upload call site.
  lifecycleTier  String    @default("PERMANENT") // PERMANENT | GENERATED | TEMPORARY
  lastAccessedAt DateTime? // real, updated whenever the file is genuinely re-served/downloaded — used to flag truly unused uploads, never guessed

  @@index([tenantId])
  @@index([category])
  @@index([lifecycleTier])
}

// W.1 — Storage Intelligence Engine (founder-requested 2026-07-06). A real,
// auditable record of every nightly (or manually-triggered) storage-cleanup
// run — what was found, what was actually deleted, and how much real space
// was freed. Schools never see this; it lives entirely inside NEYO Ops.
model StorageOptimizerRun {
  id       String  @id @default(cuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  triggeredBy     String // "SCHEDULED_CRON" | a real SUPER_ADMIN user id for a manual run
  triggeredByName String @default("Storage Intelligence Engine")

  duplicateFilesFound   Int    @default(0)
  duplicateBytesFound   BigInt @default(0)
  temporaryFilesDeleted Int    @default(0)
  temporaryBytesFreed   BigInt @default(0)
  unusedFilesFlagged    Int    @default(0) // real files with no lastAccessedAt in N+ months — flagged, never auto-deleted
  totalBytesFreed       BigInt @default(0)

  dryRun Boolean @default(false) // a real preview run (report only, deletes nothing) vs a real committed cleanup

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([createdAt])
}

// A conversation thread (A.8). type: DIRECT | GROUP | ANNOUNCEMENT.
model Conversation {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String   @default("DIRECT")
  title       String? // group name / announcement subject (null for 1:1)
  classId     String? // G.19: set = this is THE class group chat (one per class)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt // bumped on each new message (for sorting)

  participants ConversationParticipant[]
  messages     Message[]

  @@unique([tenantId, classId])
  @@index([tenantId])
  @@index([updatedAt])
}

// Membership in a conversation, with read-receipt tracking.
model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  lastReadAt     DateTime? // for unread counts + read receipts
  role           String       @default("member") // member | admin (announcement sender)
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

// A message in a conversation (A.8).
model Message {
  id                String       @id @default(cuid())
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenantId          String
  senderId          String
  senderName        String
  body              String
  attachmentUrl     String? // set when A.9 file storage lands
  attachmentName    String?
  requiresAck       Boolean      @default(false) // I.85 "I received this" button
  urgentFallbackAt  DateTime? // when non-readers/non-acknowledgers receive SMS fallback
  fallbackSmsSentAt DateTime? // set after fallback job runs
  createdAt         DateTime     @default(now())

  acknowledgements MessageAcknowledgement[]
  deliveryReport   MessageDeliveryReport?

  @@index([conversationId, createdAt])
  @@index([tenantId])
  @@index([tenantId, urgentFallbackAt, fallbackSmsSentAt])
}

// I.85 — explicit "I received this" acknowledgement per message/user.
model MessageAcknowledgement {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messageId      String
  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  acknowledgedAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([tenantId, userId])
  @@index([tenantId, messageId])
}

// I.85 — sender-facing 24-hour delivery report for school messages.
model MessageDeliveryReport {
  id                   String    @id @default(cuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messageId            String    @unique
  message              Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversationId       String
  senderId             String
  senderName           String
  recipientCount       Int
  readCount            Int
  ackCount             Int
  unreadCount          Int
  smsFallbackSentCount Int       @default(0)
  unreadJson           String? // JSON [{userId,name,phone}]
  summary              String
  generatedAt          DateTime  @default(now())
  notifiedAt           DateTime?

  @@index([tenantId, senderId, generatedAt])
  @@index([tenantId, conversationId])
}

// I.69/I.95 — in-product intercom call signalling. Audio is browser-to-browser;
// this row is only the call state: RINGING -> ACCEPTED/DECLINED/ENDED/MISSED.
model IntercomCall {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerId   String
  callerName String
  targetId   String
  targetName String
  status     String    @default("RINGING") // RINGING | ACCEPTED | DECLINED | ENDED | MISSED
  acceptedAt DateTime?
  endedAt    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId, callerId, status])
  @@index([tenantId, targetId, status])
}

// In-app notification (A.7). Belongs to a recipient user within a tenant.
model WebPushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, userId])
}

model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipientId String // User.id
  title       String
  body        String
  category    String    @default("general") // fees, attendance, exam, system...
  href        String? // optional deep link
  readAt      DateTime?
  // Delivery summary across channels (JSON: {sms:"sent",email:"skipped",...})
  channels    String?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([recipientId, readAt])
}

// Per-user channel preferences / unsubscribe (A.7).
model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  // JSON map of channel -> boolean, e.g. {"sms":true,"email":false}
  optOut    String   @default("{}")
  updatedAt DateTime @updatedAt
}

// Reusable templates with {{variable}} substitution (A.7).
model NotificationTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String // e.g. "fees_reminder"
  title     String
  body      String // may contain {{studentName}} etc.
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}

// Per-tenant payment provider credentials (A.6). SECRETS ARE ENCRYPTED with the
// tenant's DEK (A.2.7) before storage — we never keep plaintext Daraja keys.
model PaymentCredential {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider          String   @default("mpesa_daraja")
  // Non-secret config:
  shortcode         String? // Paybill / Till number
  environment       String   @default("sandbox") // sandbox | production
  connectionMode    String   @default("STK_PAYBILL") // STK_PAYBILL | STK_TILL | PAYBILL_ONLY | MANUAL
  shortcodeType     String   @default("PAYBILL") // PAYBILL | TILL
  connectionStatus  String   @default("SAVED_NOT_TESTED") // SAVED_NOT_TESTED | CREDENTIALS_VERIFIED | ACTION_REQUIRED | MANUAL
  accountReferenceFormat String?
  // Encrypted secrets (ciphertext from A.2.7 encryptForTenant):
  consumerKeyEnc    String?
  consumerSecretEnc String?
  passkeyEnc        String?
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
}

// A generic payment record (A.6). mpesaRef is globally unique (idempotency).
model Payment {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider          String    @default("mpesa_daraja")
  amount            Int // KES
  phone             String // payer, +254...
  accountRef        String? // e.g. student adm no / invoice id
  invoiceId         String? // B.7: when set, a PAID callback auto-applies to this invoice
  description       String?
  status            String    @default("PENDING") // PENDING | PAID | FAILED | CANCELLED
  // Daraja identifiers:
  checkoutRequestId String?   @unique // returned by STK push; correlates the callback
  mpesaRef          String?   @unique // M-Pesa receipt number (globally unique)
  resultCode        String?
  resultDesc        String?
  rawCallback       String? // JSON of the raw webhook for audit
  createdAt         DateTime  @default(now())
  paidAt            DateTime?

  // Soft-delete (G.6): when set, the row is in the Recycle Bin (hidden from
  // normal reads via tenantDb). Hard-purge removes it permanently.
  deletedAt   DateTime?
  deletedById String?

  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
}

// NEYO platform subscription for a school (A.5). One per tenant.
model Subscription {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planKey String @default("msingi") // see core/plans.ts
  status  String @default("ACTIVE") // ACTIVE | PAST_DUE | GRACE | SUSPENDED | CANCELLED

  // Price grandfathering: the price locked in at subscribe time (KES/term).
  grandfatheredPrice Int @default(0)

  addOns String? // JSON array of add-on keys currently active

  // Part V — Capacity-Based Pricing 2.0 (founder-confirmed 2026-07-06,
  // "migrate everyone now"): which pricing philosophy this school is on.
  // LEGACY_TIER = the old plans.ts tiered/module-gated system (kept working
  // for historical reference only; the founder confirmed every real school
  // is migrated to SIZE_BASED_V2, this field exists so the migration itself
  // is a real, trackable, auditable one-time event rather than an ambiguous
  // silent switch).
  pricingMode String @default("SIZE_BASED_V2") // LEGACY_TIER | SIZE_BASED_V2

  // Part V — the school's REAL, currently-active computed price (KES/term)
  // under the new size-based engine. Distinct from grandfatheredPrice
  // (the legacy field) so the two systems' pricing history is never
  // conflated — a school migrated to SIZE_BASED_V2 has its real active
  // price here, computed by pricing-engine.service.ts, changing ONLY at a
  // real renewal boundary per the founder's own confirmed "next billing"
  // answer, never mid-term.
  sizeBasedPriceKes Int @default(0)

  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime // when the next payment is due
  graceEndsAt        DateTime? // set when payment missed; data preserved until/after

  // U.2 — real, honest timestamp of the moment a subscription's status
  // actually became CANCELLED (never approximated via `updatedAt`, which
  // changes for many unrelated reasons — price changes, grace-period
  // updates, etc.). Stamped exactly once, the first time status transitions
  // to CANCELLED; feeds a real, accurate LTV/churn-rate calculation.
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments SubscriptionPayment[]

  @@index([tenantId])
  @@index([status])
}

// Part V — Capacity-Based Pricing 2.0 (founder-confirmed 2026-07-06). A real,
// persisted snapshot of the EXACT inputs a school's current price was
// computed from — the real "baseline" every future reprice-trigger check
// compares real current numbers against. Without a real stored baseline,
// there is nothing to measure "usage grew by X%" against. A new real row is
// created every time the price is (re)computed, giving NEYO Ops a genuine,
// permanent, auditable history of every price change and why.
model TenantPricingSnapshot {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // The real inputs the price below was computed from.
  studentCount        Int
  staffCount          Int
  parentCount         Int // ALL parents, live or dormant (founder's own explicit answer)
  estimatedStorageGb  Float // the ESTIMATE, never the real measured bytes (founder: never show schools a real GB number)
  estimatedAiOcrUsage Float @default(0) // Part V.8-resolved: AI/OCR folded into the score, marketed as "no setup fee"

  // W.2 — Real, honest alumni long-term-storage factor (founder-requested
  // 2026-07-06, only active when NEYO Ops has switched
  // `alumniStorageFactorEnabled` ON in the pricing_engine_v2 config). A
  // school with zero graduated/imported alumni records always gets 0 here
  // — this whole factor is a genuine no-op for the overwhelming majority
  // of schools until they actually import historical/alumni records.
  alumniRecordCount    Int     @default(0) // real count of Student rows with status = GRADUATED at calculation time
  alumniStorageGbAdded Float   @default(0) // the real extra estimated GB this alumni volume adds to the score
  alumniFactorApplied  Boolean @default(false) // true only when this snapshot's price genuinely includes the alumni factor — never silently applied

  // The real computed result.
  rawScore        Float
  monthlyPriceKes Int

  // Why this snapshot was created — real, honest, auditable, never silent.
  reason String // INITIAL_SIGNUP | REPRICE_THRESHOLD_CROSSED | MANUAL_OPS_OVERRIDE | DISCRETIONARY_DECREASE

  // Who/what triggered it (a real staff actor for manual/discretionary
  // reasons; null for the automatic scheduled reprice-check job).
  triggeredById   String?
  triggeredByName String?
  note            String? // real free-text, e.g. why a discretionary decrease was approved

  calculatedAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, calculatedAt])
}

// Part V — Capacity-Based Pricing 2.0 (founder-confirmed 2026-07-06). A real
// quotation request — a prospective school (which may not even have a real
// Tenant yet, only having tried the real G.14 demo) requests a quote,
// declares their real expected student/staff/parent counts, sees an
// instant real computed price, and can optionally request a real
// NEYO-Ops-reviewed formal quotation document + real onboarding assistance
// (data import help, staff training, a guided walkthrough) — the founder's
// own explicit "option 2 but they can be assisted" answer: self-serve
// activation, human help offered alongside it, never gating it.
model SchoolQuoteRequest {
  id String @id @default(cuid())

  // Nullable: a genuinely prospective school requesting a quote BEFORE
  // signing up at all has no real tenantId yet. Once they accept and go
  // live via signupSchool(), this is backfilled to the real new tenant.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  schoolName   String
  contactName  String
  contactEmail String
  contactPhone String

  // Real declared numbers (or a real, honest "unsure, estimate for us" flag).
  declaredStudentCount Int?
  declaredStaffCount   Int?
  declaredParentCount  Int?
  requestedEstimate    Boolean @default(false) // true = "estimate for me based on typical schools this size"

  // The real instantly-computed price shown to the prospect immediately.
  instantQuotedPriceKes Int?

  // The real, optional, NEYO-Ops-reviewed formal quotation (a real PDF
  // document, reusing the existing @react-pdf/renderer system — never a
  // new document system). Ops MAY adjust the price for a real, justified
  // reason (always audit-logged).
  formalQuoteRequested Boolean   @default(false)
  finalQuotedPriceKes  Int?
  quotedById           String?
  quotedByName         String?
  quotedAt             DateTime?
  quotePdfUrl          String?

  status String @default("REQUESTED") // REQUESTED | QUOTED | ACCEPTED | DECLINED | LIVE

  // The founder's own explicit, non-blocking human-assistance offer.
  onboardingAssistanceRequested Boolean   @default(false)
  onboardingAssistanceNote      String?
  onboardingAssistanceDoneAt    DateTime?

  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([tenantId])
}

// A payment attempt/record against a subscription (A.5/A.6).
model SubscriptionPayment {
  id                    String       @id @default(cuid())
  subscriptionId        String
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId              String
  amount                Int // KES — the FULL undiscounted subscription amount for the period
  referralDiscountKes   Int          @default(0) // M.1 — real KES referral credit deducted from `amount` when charged
  // T.2/T.6 — real KES deducted from this SPECIFIC payment via a discount
  // campaign or an influencer code (mutually exclusive — at most ONE of
  // these two is ever non-zero on a real row, enforced in the service
  // layer). Distinct from referralDiscountKes so all three real discount
  // sources' history is never conflated on one payment.
  campaignDiscountKes   Int          @default(0)
  campaignId            String?
  influencerDiscountKes Int          @default(0)
  influencerCodeId      String?
  status                String       @default("PENDING") // PENDING | PAID | FAILED
  method                String       @default("central_mpesa_stk")
  phone                 String?
  accountRef            String?
  checkoutRequestId     String?      @unique
  mpesaRef              String?      @unique // globally-unique M-Pesa ref (A.6)
  resultCode            String?
  resultDesc            String?
  rawCallback           String?
  periodStart           DateTime
  periodEnd             DateTime
  createdAt             DateTime     @default(now())
  paidAt                DateTime?

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([status])
}

// Per-tenant metered usage within the current period (A.5 soft limits).
model UsageCounter {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric    String // "sms" | "students" | "staff" ...
  used      Int      @default(0)
  periodKey String // e.g. "2026-T2" to reset per billing period
  updatedAt DateTime @updatedAt

  @@unique([tenantId, metric, periodKey])
  @@index([tenantId])
}

// H.2 Multi-Owner Support — a critical action that one owner initiates and a
// DIFFERENT owner must approve (dual control). The rows + audit log form the
// "confirmation log" of joint approvals.
model OwnerApprovalRequest {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action          String // PERMANENT_DELETE | PAYROLL_APPROVE | OWNER_ROLE_CHANGE | MODULE_CHANGE | OTHER
  summary         String // human description of what is being authorised
  payload         String? // JSON detail (what to act on) for the caller to execute
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED | EXECUTED
  requestedById   String
  requestedByName String
  decidedById     String?
  decidedByName   String?
  decidedAt       DateTime?
  decisionNote    String?
  createdAt       DateTime  @default(now())

  @@index([tenantId, status])
}

// Platform user. Belongs to a tenant and carries one of the 16 roles.
model User {
  id            String  @id @default(cuid())
  tenantId      String
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  neyoLoginId   String  @unique // global NEYO login ID (A.4 two-ID system)
  fullName      String
  phone         String? // +254 format
  email         String?
  customNeyoEmail       String? @unique // Curated NEYO login email (e.g. kamau.m@karibuhigh.neyo.co.ke)
  hasSetInitialPassword Boolean @default(true) // false if first-time user needing initial password setup
  recoveryOtpCode       String? // 6-digit OTP for password recovery or mobile first-login
  recoveryOtpExpiresAt  DateTime?
  role          String  @default("RECEPTIONIST") // validated against the 16 roles
  secondaryRole String? // optional second role for dual-role staff

  passwordHash String? // Argon2id in production (A.14)
  isActive     Boolean @default(true)
  language     String  @default("en") // A.15 preferred UI language: en | sw
  popupStyle   String  @default("glass") // O.2 personal popup rendering: glass | solid
  lgContrast   String  @default("company") // O.3 personal colour-intensity override: company | 1 | 2 | 3
  // Shell Version personal override (founder-requested "NEYO 2.0" phase 2,
  // 2026-07-04): null = "follow the platform/school default"; "v1" | "v2" =
  // this staff member's own explicit personal choice, independent of
  // whatever NEYO Ops/their school has set. Only ever effective once NEYO
  // Ops has released the personal-toggle capability (see PlatformSetting
  // shell_personal_toggle_released / shell_personal_toggle_early_access in
  // shell-version.service.ts) — mirrors the exact same company-then-
  // personal layering already used by lgContrast above.
  shellVersion String? // "v1" | "v2" | null (follow default)

  // Part V — Capacity-Based Pricing 2.0 (founder-confirmed 2026-07-06): a
  // real, narrow, explicitly-grantable delegation. The founder's own words:
  // "option 1 [SUPER_ADMIN only] but when the ceo allows a staff to do so no
  // issue eg the ceo of neyo" — the rare, human-reviewed discretionary
  // price-DECREASE exception (a school's usage genuinely, drastically
  // dropped) defaults to SUPER_ADMIN-only, but the founder (acting as CEO)
  // can explicitly delegate this specific capability to a named staff
  // member without promoting them to SUPER_ADMIN. Settable ONLY by a real
  // SUPER_ADMIN (enforced in the service layer, not just by this being a
  // rarely-set column), always audit-logged when granted/revoked AND when
  // actually used.
  canApplyDiscretionaryDecrease Boolean @default(false)

  // T.11b — real login-activity tracking (did NOT exist before). Stamped by
  // every real successful login path (phone OTP, password, magic link,
  // passkey) so a real "N parents have never logged in" report can exist —
  // null means this user has NEVER once logged in for real, a genuinely
  // different and honest signal from "logged in a long time ago".
  lastLoginAt DateTime?

  // Z.1 — real Offline-First Resilience (founder-requested 2026-07-09,
  // "deep analysis... offline... saver thing... link to the actions and
  // activities"). Auto-enabled per the founder's own explicit choice
  // ("turn it on automatically... every school gets a background best-
  // effort save... no toggle needed") — the school/staff member can still
  // turn it off from the existing Bundle Saver card, this is just the real
  // default. Feeds the real read-fallback banner's own "last saved at" time
  // via the client's own IndexedDB record (bundle-cache.ts), never stored
  // server-side (this flag only controls whether the background auto-sync
  // on login should run at all).
  bundleSaverEnabled Boolean @default(true)

  // Z.3 — real, short printable code for this staff member on a printed
  // timetable (e.g. "MO" for Mary Omondi), shown in the bottom-right corner
  // of a lesson cell per the founder's own requested layout. Auto-generated
  // from real initials at first use (de-duplicated per tenant if two
  // teachers would otherwise collide), but a school can rename it to
  // whatever short code/label they prefer. Null until the timetable print
  // feature first needs one for this person.
  timetableShortCode String?

  // Two-factor authentication (A.1, TOTP / RFC 6238)
  totpSecret     String? // base32 secret; null until setup begins
  totpEnabled    Boolean   @default(false)
  totpVerifiedAt DateTime? // when 2FA was first confirmed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otpCodes             OtpCode[]
  sessions             Session[]
  magicLinks           MagicLink[]
  recoveryCodes        RecoveryCode[]
  credentials          Credential[]
  studentProfile       Student?                @relation("StudentUser")
  guardianProfile      Guardian?               @relation("GuardianUser")
  webPushSubscriptions WebPushSubscription[]
  oauthAccounts        OAuthConnectedAccount[]
  TalentRecord         TalentRecord[]
  StudentGoal          StudentGoal[]
  calendarFeedToken    CalendarFeedToken?

  // R.4 Multi-School Parent Accounts: this User row is one PARENT account at
  // ONE school. linkedAsPrimary/linkedAsLinked let the SAME real person
  // switch between their separate accounts at DIFFERENT NEYO schools without
  // merging the underlying tenant-scoped User rows (each school keeps its
  // own account, own audit trail, own permissions — nothing is shared).
  linkedAsPrimary LinkedGuardianAccount[] @relation("LinkPrimaryUser")
  linkedAsLinked  LinkedGuardianAccount[] @relation("LinkLinkedUser")

  // Y.2 — set only for a real NEYO_OPS/NEYO_SUPPORT company account; tracks
  // individually-granted extra permissions beyond the base role.
  neyoTeamMember NeyoTeamMember?

  @@index([tenantId])
  @@index([role])
}

// R.4 — Multi-School Parent Accounts. Connects two SEPARATE, real PARENT
// User accounts (each at its own tenant/school) that belong to the SAME real
// person, once verified by a fresh OTP to their own phone (never automatic,
// per founder's explicit choice — no accidental linking of a shared/reused
// number). Bidirectional in practice: either side can switch to the other,
// so the link is modeled once and read from both directions.
model LinkedGuardianAccount {
  id            String @id @default(cuid())
  // The account the link was INITIATED from (the one the parent was signed
  // into when they tapped "Add another school").
  primaryUserId String
  primaryUser   User   @relation("LinkPrimaryUser", fields: [primaryUserId], references: [id], onDelete: Cascade)
  // The other real school account, now linked and switchable to.
  linkedUserId  String
  linkedUser    User   @relation("LinkLinkedUser", fields: [linkedUserId], references: [id], onDelete: Cascade)

  verifiedAt DateTime @default(now()) // OTP-verified at creation — never unverified
  createdAt  DateTime @default(now())

  @@unique([primaryUserId, linkedUserId])
  @@index([primaryUserId])
  @@index([linkedUserId])
}

model OAuthConnectedAccount {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  email             String?
  displayName       String?
  linkedAt          DateTime  @default(now())
  lastUsedAt        DateTime?

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([tenantId])
}

model OAuthState {
  id         String   @id @default(cuid())
  state      String   @unique
  tenantId   String
  userId     String
  provider   String
  redirectTo String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId, provider])
  @@index([expiresAt])
}

// A registered WebAuthn passkey (A.1). The private key stays on the user's
// device; we store the public key to verify their signed assertions.
model Credential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique // base64url of the raw credential ID
  publicKey    String // base64url of the COSE public key
  counter      Int       @default(0) // signature counter (anti-replay)
  transports   String? // JSON array: ["internal","hybrid",...]
  deviceLabel  String? // e.g. "iPhone Face ID"
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

// R.3 — a real, server-issued, short-lived, single-use proof that a
// specific user genuinely passed a fingerprint/Face ID/passkey check for a
// specific real action (e.g. "record a KES 5,000 cash payment"). Issued
// ONLY by verifyActionAssertion() after a real WebAuthn assertion succeeds;
// the money-moving route itself must present this ticket and have it
// consumed (marked usedAt) before the action proceeds — closing the real
// gap where a screen popup alone could be bypassed by calling the API
// directly. `actionKey` binds the ticket to one specific real operation
// (e.g. a stable hash of the amount+studentId) so a ticket for one payment
// can never be replayed against a different one.
model BiometricActionTicket {
  id        String    @id @default(cuid())
  userId    String
  tenantId  String
  actionKey String // e.g. "cash_payment:<amountKes>:<accountRef>" — binds the ticket to ONE real operation
  createdAt DateTime  @default(now())
  expiresAt DateTime // short-lived (see BIOMETRIC_TICKET_TTL_MINUTES)
  usedAt    DateTime? // set the moment the protected route consumes it — never reusable after

  @@index([userId])
  @@index([tenantId])
}

// Short-lived WebAuthn challenge for register/login (A.1).
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String // the random base64url challenge we must verify back
  purpose   String // "REGISTER" or "LOGIN"
  userId    String? // set for REGISTER (the signed-in user)
  email     String? // set for LOGIN (the claimed account)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
}

// Short-lived "2FA pending" challenge issued after step-1 login succeeds but
// before the TOTP code is entered. No real session exists until this is solved.
model TotpChallenge {
  id        String   @id @default(cuid())
  token     String   @unique // opaque token held by the client during the challenge
  userId    String
  userAgent String?
  ipAddress String?
  expiresAt DateTime // short, e.g. now + 10 minutes
  createdAt DateTime @default(now())

  @@index([userId])
}

// Hashed single-use 2FA backup codes (A.1). Used if the user loses their phone.
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String // SHA-256 of the recovery code (never the raw code)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// One-time passcode for phone login (A.1). We store ONLY a hash of the code.
model OtpCode {
  id         String    @id @default(cuid())
  phone      String // normalized +254XXXXXXXXX (E.164 without spaces)
  codeHash   String // SHA-256 of the 6-digit code (never the raw code)
  userId     String? // matched user, if the phone belongs to one
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    String    @default("LOGIN") // LOGIN, etc.
  attempts   Int       @default(0) // wrong-code attempts (verify-attempt limiting)
  consumedAt DateTime? // set when successfully used; can't be reused
  expiresAt  DateTime // typically now + 5 minutes
  createdAt  DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// One-click email sign-in link (A.1). We store ONLY a hash of the token.
model MagicLink {
  id         String    @id @default(cuid())
  email      String // normalized, lowercased
  tokenHash  String    @unique // SHA-256 of the random token in the link
  userId     String? // matched user, if the email belongs to one
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumedAt DateTime? // single-use: set once the link is clicked successfully
  expiresAt  DateTime // typically now + 15 minutes
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

// Server-side session behind the HTTP-only login cookie (A.1).
// Storing sessions in the DB lets us do "logout everywhere" by user_id.
model Session {
  id        String  @id @default(cuid())
  token     String  @unique // random opaque token stored in the cookie
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ipAddress String?
  deviceId  String?

  // Impersonation (A.2.9) / View-As (G.5). When set, `userId` is the REAL
  // actor and `impersonatedUserId` is who they're temporarily acting as.
  // viewAsReadOnly = true marks an in-school read-only "View As" (G.5) where
  // all mutations are blocked.
  impersonatedUserId String?
  viewAsReadOnly     Boolean @default(false)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// Which product modules a school has enabled (A.2.6). One row per module.
model TenantModule {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleKey String // e.g. "attendance", "hostel" (see core/modules.ts)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
}

// Background job run record (A.12). Platform-level (not tenant-scoped):
// jobs like the subscription state machine span all tenants.
model JobRun {
  id         String    @id @default(cuid())
  name       String // registered job name, e.g. "subscription-state-machine"
  status     String    @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED
  progress   Int       @default(0) // 0-100
  attempts   Int       @default(0)
  payload    String? // JSON args
  result     String? // JSON summary
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([name])
  @@index([status])
  @@index([createdAt])
}

// Atomic counter for tenant-scoped IDs like KH-S-000247 (A.4).
model IdSequence {
  id         String @id @default(cuid())
  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType String // "STUDENT", "INVOICE", etc.
  lastValue  Int    @default(0)

  @@unique([tenantId, entityType])
}

// Immutable audit log (A.14). App code only ever inserts; never updates/deletes.
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String? // user who performed the action
  actorName  String?
  action     String // "student.create", "auth.login", ...
  entityType String?
  entityId   String?
  metadata   String? // JSON string of extra context
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([entityType, entityId])
}

// =============================================================================
// A.16 — Public API & Webhooks
// =============================================================================

// A developer API key for a tenant. The plaintext secret is shown ONCE at
// creation; we store only a SHA-256 hash (keyHash) + a short non-secret prefix
// (keyPrefix, e.g. "neyo_sk_3f9c") for display. Bearer auth (A.16.2) hashes the
// presented token and looks it up here.
model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String // human label, e.g. "SIS integration"
  keyPrefix   String // non-secret, for display: "neyo_sk_3f9c…" (or "neyo_partner_…" for a NEYO Partner key)
  keyHash     String    @unique // SHA-256 of the full secret
  scopes      String // JSON array of permission strings this key may use
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  // Part X — Developer Center 2.0 (founder-requested 2026-07-06). A real,
  // explicit key TIER, never inferred from the token prefix alone:
  //   SCHOOL       — a school's own key, self-issued from Settings →
  //                   Developer, for THEIR OWN third-party integrations
  //                   (their own finance system, biometric device, etc.).
  //                   Same real auth/rate-limit/scope mechanism as every
  //                   other key — no separate system, per the founder's
  //                   own confirmed answer.
  //   NEYO_PARTNER — a key NEYO ITSELF issues (SUPER_ADMIN only, via NEYO
  //                   Ops) for NEYO's own future first-party accessories
  //                   (e.g. a NEYO-built fingerprint device or ID
  //                   printer) — a genuinely more privileged, explicitly
  //                   NEYO-vetted tier, real-audited separately from a
  //                   school's own self-service keys.
  tier            String  @default("SCHOOL") // SCHOOL | NEYO_PARTNER
  // Real, honest sandbox/live distinction (founder's own "Sandbox" ask,
  // D.5) — a sandbox key only ever reads/writes a real, isolated demo
  // dataset, NEVER a real school's live data, so a developer can build and
  // test safely before ever touching production. `tenantId` above always
  // stays the OWNING school (for real listing/management/ownership in
  // their own Settings → Developer page); `sandboxTenantId` is the real,
  // separate, isolated demo-style tenant this key actually reads/writes
  // against when `environment === "sandbox"` — a genuinely different real
  // tenant, never the school's own live data, even though the SAME school
  // owns/manages the key.
  environment     String  @default("live") // live | sandbox
  sandboxTenantId String?

  usageLogs ApiUsageLog[]

  @@index([tenantId])
  @@index([keyHash])
  @@index([tier])
}

// A tenant's webhook endpoint. Each delivery is HMAC-signed (A.16.5) with
// `signingSecret` so the receiver can verify authenticity.
model WebhookSubscription {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url            String // HTTPS endpoint to POST events to
  events         String // JSON array of event names, or ["*"] for all
  signingSecret  String // used to compute the HMAC-SHA256 signature
  active         Boolean   @default(true)
  description    String?
  lastDeliveryAt DateTime?
  createdAt      DateTime  @default(now())

  deliveries WebhookDelivery[]

  @@index([tenantId])
}

// One delivery attempt-record for a webhook event (A.16.6 retry queue).
// Status: PENDING | DELIVERED | FAILED. attempts + nextAttemptAt drive the
// exponential-backoff retry job.
model WebhookDelivery {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String // e.g. "payment.recorded"
  payload        String // JSON body sent
  status         String              @default("PENDING") // PENDING | DELIVERED | FAILED
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(6)
  responseStatus Int?
  responseBody   String? // truncated response for debugging
  error          String?
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime            @default(now())

  @@index([tenantId])
  @@index([status, nextAttemptAt])
  @@index([subscriptionId])
}

// Part X — Developer Center 2.0 (founder-requested 2026-07-06). A real,
// lightweight per-request audit row for EVERY real Public API call — the
// exact real data NEYO Ops needs to answer "total requests / active
// integrations / failed calls / slow endpoints / top developers / usage by
// school / security alerts" honestly, without guessing. Written by the
// same real `authenticateApiRequest()` middleware every /api/v1/* route
// already calls, so covering the API surface costs zero new integration
// work per route as the surface grows.
model ApiUsageLog {
  id       String  @id @default(cuid())
  tenantId String? // null only for a genuinely failed/unauthenticated request (no real key resolved yet)
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKeyId String?
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  method       String // GET | POST | PUT | PATCH | DELETE
  path         String // e.g. "/api/v1/students"
  statusCode   Int
  durationMs   Int
  requestBytes Int    @default(0)

  // Real, honest security-relevant classification — never a raw guess,
  // only ever set by the real authentication/authorization outcome itself.
  outcome String // OK | UNAUTHENTICATED | INVALID_TOKEN | INSUFFICIENT_SCOPE | RATE_LIMITED | SERVER_ERROR

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([statusCode])
  @@index([createdAt])
}

// =============================================================================
// A.17 — Calendar (Shared)
// =============================================================================

// A school calendar event (A.17). Layered on top of the read-only Kenyan
// holiday/cultural moments from A.15 (cultural-calendar.ts). Audience-targeting
// (A.17.5): if `audienceRole` is null the event is school-wide; otherwise only
// that role sees it / is invited.
model CalendarEvent {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  // Stored as YYYY-MM-DD (all-day) plus optional HH:MM start/end for timed events.
  date         String // "2026-07-15"
  endDate      String? // multi-day events; null = single day
  startTime    String? // "14:00" (24h, Africa/Nairobi); null = all-day
  endTime      String?
  location     String?
  type         String   @default("event") // event | meeting | exam | holiday | sports | deadline
  audienceRole String? // null = whole school; else a Role string (A.17.5)
  color        String? // optional hex for the dot
  // B.25 Recurring events: null = one-off. WEEKLY repeats on the same weekday
  // as `date`; MONTHLY repeats on the same day-of-month. Expanded server-side.
  recurrence   String? // null | "WEEKLY" | "MONTHLY"
  recurUntil   String? // YYYY-MM-DD — last day the series may occur (inclusive)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, date])
}

// M.3 — a personal, revocable subscription token for a REAL native-mobile
// calendar sync (webcal://): a phone's Calendar app polls the public feed URL
// on its own schedule and gets LIVE updates, instead of the old one-shot
// manual .ics download button. One row per (user, tenant); regenerating
// replaces the token so any lost/leaked link stops working immediately.
// Deliberately NOT tenant-owned (no tenantId auto-stamping needed beyond the
// FK) since the public feed route must look this up with NO session at all.
model CalendarFeedToken {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String    @unique // opaque random token embedded in the public feed URL
  createdAt    DateTime  @default(now())
  rotatedAt    DateTime  @default(now())
  lastPolledAt DateTime? // stamped on every real feed fetch, so we can show "last synced"

  @@index([tenantId])
}

// =============================================================================
// A.18 — Receptionist Operations
// =============================================================================

// A front-desk visitor record (A.18.5). The receptionist signs visitors in and
// out; an in-browser badge can be printed (thermal-printer device is a later
// hardware seam). "purpose" + "host" capture why they're here and who they came
// to see.
model VisitorLog {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  phone       String? // +254...
  idNumber    String? // national ID for security
  purpose     String // e.g. "Fees enquiry", "Visiting student"
  host        String? // staff/student they came to see
  studentId   String? // B.16: set = visiting THIS boarder (hostel visitor tracking)
  badgeNo     String // short per-day badge, e.g. "V-014"
  signedInAt  DateTime  @default(now())
  signedOutAt DateTime?
  createdById String?

  @@index([tenantId])
  @@index([tenantId, signedInAt])
  @@index([tenantId, studentId])
}

// A walk-in admission enquiry captured at the desk (A.18.6). Becomes a lead the
// admissions team can follow up.
model AdmissionInquiry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentName  String
  phone       String
  studentName String?
  gradeWanted String? // e.g. "Grade 4", "Form 1"
  curriculum  String? // "CBC" | "8-4-4"
  notes       String?
  status      String   @default("NEW") // NEW | CONTACTED | ENROLLED | CLOSED
  createdById String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

// A phone message taken at reception and relayed to a staff member's inbox
// (A.18.7). On creation we also drop a conversation message (A.8) to the
// recipient; this row keeps the desk's own log.
model PhoneMessage {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callerName     String
  callerPhone    String?
  forUserId      String // staff member the message is for
  forUserName    String
  message        String
  conversationId String? // the A.8 conversation we relayed into
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

// =============================================================================
// B.1 — Student Management
// =============================================================================

// A class/grade with an optional stream, e.g. "Grade 4 - Blue" (CBC) or
// "Form 2 - East" (8-4-4). curriculum distinguishes the two systems.
model SchoolClass {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  level          String // "Grade 4", "Form 2", "PP1"
  stream         String? // "Blue", "East", "A" (null = single-stream)
  curriculum     String      @default("CBC") // "CBC" | "8-4-4"
  curriculumId   String?
  curriculumRef  Curriculum? @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  gradeBandId    String?
  gradeBand      GradeBand?  @relation(fields: [gradeBandId], references: [id], onDelete: SetNull)
  classTeacherId String? // a User (CLASS_TEACHER/TEACHER) — row-scoping (A.3.8)
  capacity       Int?
  archived       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  scannedExamPapers ScannedExamPaper[]
  paperQuizFormativeBatches PaperQuizFormativeBatch[]
  students Student[]

  @@unique([tenantId, level, stream])
  @@index([tenantId])
  @@index([tenantId, curriculumId])
  @@index([tenantId, gradeBandId])
}

// A student. Tenant-owned + soft-deletable (G.6 Recycle Bin). Optionally linked
// to a NEYO login User (the student account) and to one SchoolClass.
model Student {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  admissionNo        String // school-side ID, e.g. KH-S-000247 (A.4)
  legacyAdmissionNo  String? // school's own pre-existing legacy admission number (A.1.8)
  firstName          String
  middleName         String?
  lastName           String
  gender             String // "M" | "F"
  dateOfBirth        String? // YYYY-MM-DD
  photoUrl           String?
  status             String  @default("ACTIVE") // ACTIVE | INACTIVE | GRADUATED | TRANSFERRED | SUSPENDED
  graduationYear     Int? // set when status -> GRADUATED ("Class of 2026"); cleared on un-graduate
  finalClassLabel    String? // class at graduation (e.g. "Form 4 East") — kept after the seat is freed
  // T.13 — manual repeat-a-level marker (staff decision during a promotion run, never automatic).
  isRepeating        Boolean @default(false) // true while this student is repeating their current level
  repeatingSinceYear Int? // the academic year this repeat started (shown on the profile badge)
  // Government/registration identifiers (Kenya).
  upiNumber          String? // NEMIS/UPI assessment number
  birthCertNo        String?
  specialNeedsCode   String? // MOE special needs code
  pocketWallet       StudentPocketWallet? @relation("StudentPocketWallet")

  classId      String?
  schoolClass  SchoolClass? @relation(fields: [classId], references: [id], onDelete: SetNull)
  boardingType String       @default("BOARDER") // "DAY" | "BOARDER" - gates hostel allocations (H.3)

  // Optional linked NEYO login account (the student logs in).
  userId String? @unique
  user   User?   @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)

  admittedOn DateTime @default(now())
  notes      String?

  // Soft-delete (G.6).
  deletedAt   DateTime?
  deletedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guardians                    StudentGuardian[]
  documents                    StudentDocument[]
  questionBankAttempts         QuestionBankAttempt[]
  contestAttempts              ContestAttempt[]
  requirements                 StudentRequirement[]
  customFields                 StudentCustomField[]
  transfers                    StudentTransfer[]
  attendance                   AttendanceRecord[]
  promisesToPay                PromiseToPay[]
  reportCardDayCheckIns        ReportCardDayCheckIn[]
  leavingCertificate           LeavingCertificate? // Added for Leaving Certificate Vault (H.3)
  skillsPassportEntries        SkillsPassportEntry[]
  portfolioItems               PortfolioItem[]
  StudentPathwayPreference     StudentPathwayPreference[]
  TalentRecord                 TalentRecord[]
  StudentGoal                  StudentGoal[]
  passportRequests             TransferPassportRequest[]
  CommunityServiceActivity     CommunityServiceActivity[]
  CareerDiscoveryRecord        CareerDiscoveryRecord[]
  StudentApprovalRequest       StudentApprovalRequest[]
  StudentDutyAssignment        StudentDutyAssignment[]
  StudentSubjectSelection      StudentSubjectSelection[]
  PromotionRequest             PromotionRequest[]
  learnerJourneyPins           LearnerJourneyPin[]
  documentVerifications        DocumentVerification[]
  qrScanEvents                 QrScanEvent[]                 @relation("QrScanStudent")
  seniorTimetableProofs        SeniorLearnerTimetableProof[]
  nationalAssessments          StudentNationalAssessment[]
  transportRouteChangeRequests TransportRouteChangeRequest[]
  cafeteriaEnrollmentRequests  CafeteriaEnrollmentRequest[]

  @@unique([tenantId, admissionNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, classId])
  @@index([deletedAt])
}

// A parent/guardian. May be linked to a NEYO PARENT login User for the parent
// portal (B.10) + PARENT row-scoping (A.3.9).
model Guardian {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName   String
  phone      String // +254...
  email      String?
  nationalId String?
  userId     String?  @unique // linked PARENT User (B.10)
  user       User?    @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  students      StudentGuardian[]
  promisesToPay PromiseToPay[]

  @@index([tenantId])
  @@index([tenantId, phone])
}

// Join: a student has one or more guardians, each with a relationship + primary flag.
model StudentGuardian {
  id           String   @id @default(cuid())
  tenantId     String
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardianId   String
  guardian     Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  relationship String   @default("Parent") // Parent | Mother | Father | Guardian | Other
  isPrimary    Boolean  @default(false)

  @@unique([studentId, guardianId])
  @@index([tenantId])
}

// A stored document for a student (birth cert, report, KCPE slip...). Uses A.9.
model StudentDocument {
  id               String   @id @default(cuid())
  tenantId         String
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  label            String
  fileUrl          String
  fileName         String?
  hardcopyLocation String   @default("Unspecified") // physical location for the original hardcopy
  uploadedById     String?
  createdAt        DateTime @default(now())

  @@index([tenantId])
  @@index([studentId])
}

// Per-student joining requirement tick-off (G.9 master list -> per student).
model StudentRequirement {
  id          String    @id @default(cuid())
  tenantId    String
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  label       String
  category    String    @default("other")
  quantity    String?
  mandatory   Boolean   @default(true)
  fulfilled   Boolean   @default(false)
  fulfilledAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([studentId])
}

// G.33 2.0 — COMPANY-GLOBAL platform settings (deliberately NOT tenant-owned,
// same family as PlatformFlag). Key-value: e.g. "liquid_level" = "1"|"2"|"3".
// Only NEYO (SUPER_ADMIN) writes here — schools cannot change the system look.
model PlatformSetting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// B.25 Uniform Management — per-size stock for Uniform-category StockItems.
// The master StockItem.qty stays the total; size rows split it (S/M/L/Size 28…).
model UniformSize {
  id       String    @id @default(cuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemId   String
  item     StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  size     String // "XS".."XXL", "Size 26".."Size 34", custom
  qty      Int       @default(0)

  @@unique([tenantId, itemId, size])
}

// B.25 Supplier Management — who the school buys from.
model Supplier {
  id        String             @id @default(cuid())
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  category  String // "Food", "Uniform", "Cleaning", "Stationery", "Transport", "Services", "Other"
  phone     String? // +254...
  email     String?
  contact   String? // contact person
  kraPin    String? // for compliant procurement later (C.24)
  rating    Int                @default(0) // 0 = unrated, 1-5 stars
  notes     String?
  archived  Boolean            @default(false)
  createdAt DateTime           @default(now())
  contracts SupplierContract[]

  @@unique([tenantId, name])
  @@index([tenantId, category])
}

// B.25 supply contracts w/ expiry (≤30d alert pattern from B.17).
model SupplierContract {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  title      String // "Maize flour supply — Term 2"
  startsOn   String // YYYY-MM-DD
  endsOn     String // YYYY-MM-DD
  valueKes   Int      @default(0) // 0 = not stated
  note       String?
  createdAt  DateTime @default(now())

  @@index([tenantId, supplierId])
}

// B.25 Procurement — request → quotes → PO → approval → delivery → 3-way match.
model PurchaseRequest {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String // "Term 3 dry foods"
  details         String? // free text list of what's needed
  neededBy        String? // YYYY-MM-DD
  status          String          @default("OPEN") // OPEN | ORDERED | CANCELLED
  requestedById   String
  requestedByName String
  createdAt       DateTime        @default(now())
  quotes          PurchaseQuote[]
  orders          PurchaseOrder[]

  @@index([tenantId, status])
}

// Quotations gathered per request — the comparison board.
model PurchaseQuote {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestId    String
  request      PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  supplierId   String
  supplierName String // frozen at quote time
  amountKes    Int
  note         String? // delivery time, terms
  createdAt    DateTime        @default(now())

  @@index([tenantId, requestId])
}

// The order itself. Approval threshold rule: totalKes > Tenant.poApprovalThresholdKes
// => needs leadership approval before sending.
model PurchaseOrder {
  id                 String           @id @default(cuid())
  tenantId           String
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  poNo               String // KH-PO-000001 (A.4)
  requestId          String?
  request            PurchaseRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  quoteId            String? // winning quote
  supplierId         String
  supplierName       String // frozen
  title              String
  totalKes           Int
  status             String           @default("PENDING_APPROVAL") // PENDING_APPROVAL | APPROVED | SENT | DELIVERED | MATCHED | CANCELLED
  approvedById       String?
  approvedByName     String?
  approvedAt         DateTime?
  // Delivery (goods received note)
  deliveredAt        DateTime?
  deliveredNote      String? // what actually arrived
  deliveredValueKes  Int? // value of goods received
  // Supplier invoice (the 3rd leg of the match)
  supplierInvoiceNo  String?
  supplierInvoiceKes Int?
  // 3-way match result
  matchedAt          DateTime?
  matchOk            Boolean?
  matchNote          String? // mismatch explanation
  createdById        String
  createdByName      String
  createdAt          DateTime         @default(now())

  @@unique([tenantId, poNo])
  @@index([tenantId, status])
}

// B.25 — Expenses Tracking. Categories + cost centers are the reporting
// dimensions; Expense is the spend transaction with a threshold approval
// state-machine and an optional receipt photo (A.9 storage).
model ExpenseCategory {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String // "Utilities", "Repairs & Maintenance", "Stationery"
  archived  Boolean   @default(false)
  createdAt DateTime  @default(now())
  expenses  Expense[]

  @@unique([tenantId, name])
  @@index([tenantId, archived])
}

// A cost center = the part of the school the spend belongs to (a department,
// a department-like bucket, or "Whole school"). Drives the by-cost-center report.
model CostCenter {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String // "Kitchen", "Boarding", "Administration", "Academics"
  archived  Boolean   @default(false)
  createdAt DateTime  @default(now())
  expenses  Expense[]

  @@unique([tenantId, name])
  @@index([tenantId, archived])
}

// The spend record. Threshold rule: amountKes > Tenant.expenseApprovalThresholdKes
// => needs leadership approval before it counts as real spend (and before it
// hits the B.24 profitability line).
model Expense {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryName    String // frozen at entry for the report even if a category is renamed
  costCenterId    String?
  costCenter      CostCenter?     @relation(fields: [costCenterId], references: [id])
  costCenterName  String? // frozen
  payee           String // who was paid: "KPLC", "Mama Wanjiku Tailors"
  amountKes       Int
  spentOn         String // YYYY-MM-DD (Nairobi date the money left)
  note            String?
  receiptFileUrl  String? // A.9 storage key (receipt photo / PDF) — OCR auto-extract is Bundi-gated
  receiptFileName String?
  status          String          @default("PENDING_APPROVAL") // PENDING_APPROVAL | APPROVED | REJECTED
  approvedById    String?
  approvedByName  String?
  approvedAt      DateTime?
  rejectedReason  String?
  createdById     String
  createdByName   String
  createdAt       DateTime        @default(now())

  @@index([tenantId, status])
  @@index([tenantId, spentOn])
}

// ---------------------------------------------------------------------------
// G.15 — Term Trends Pulse (founder-requested 2026-06-13).
// A weekly leadership digest, computed every Monday 07:00 EAT from the rows the
// other modules already write (B.1 enrolment, B.3 attendance, B.7 fees). One
// row per tenant per ISO-week = idempotent send + a viewable history. The
// one-line `summary` is rule-based; the richer narrative is the Bundi swap
// point (B.23, platform-paused) — no feature depends on it.
// ---------------------------------------------------------------------------
model TermPulse {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  weekKey   String // ISO week the pulse covers, e.g. "2026-W24" (the week just ended)
  weekStart String // YYYY-MM-DD Monday of the covered week (Nairobi)
  weekEnd   String // YYYY-MM-DD Sunday of the covered week (Nairobi)

  // Enrolment
  activeStudents Int @default(0)
  joinedThisWeek Int @default(0)

  // Attendance (the covered week)
  attendancePct     Int @default(0) // present+late / marked, %
  attendancePrevPct Int @default(0) // previous week, for the WoW delta
  attendanceMarked  Int @default(0) // total marks recorded that week

  // Fees (the covered week)
  collectedWeekKes  Int @default(0) // money applied to invoices this week
  weeklyTargetKes   Int @default(0) // pro-rated weekly slice of the term target
  collectionTermPct Int @default(0) // term-to-date collection % (vs target context)

  summary   String // rule-based one-line digest (NEVER says "AI")
  sentCount Int    @default(0) // how many leaders were notified

  createdAt DateTime @default(now())

  @@unique([tenantId, weekKey])
  @@index([tenantId, createdAt])
}

model SavedView {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  entityType String // e.g. "student", "invoice", "payment"
  name       String
  filters    String // JSON string of active filter key-values
  createdAt  DateTime @default(now())

  @@index([tenantId, userId, entityType])
}

model TeacherSubject {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId String // User.id
  subjectId String // Subject.id
  isStrong  Boolean @default(false) // L.3 Strong area preference

  @@unique([tenantId, teacherId, subjectId])
  @@index([tenantId])
}

model ClassSubjectNeed {
  id               String  @id @default(cuid())
  tenantId         String
  tenant           Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId          String
  subjectId        String // Subject.id
  teacherId        String? // User.id
  lessonsPerWeek   Int     @default(5)
  // L.7 timetable: how many of the weekly lessons should be DOUBLE (back-to-back)
  // periods. The rest are scheduled as singles. e.g. lessonsPerWeek=6, doubleCount=2
  // => two doubles (4 periods) + two singles (2 periods).
  doubleCount      Int     @default(0)
  // If true, a double may be split across the day (two periods, not necessarily
  // adjacent) for hard subjects; if false, doubles are strictly consecutive.
  allowSplitDouble Boolean @default(false)

  // Z.3 — a real, optional required venue for this class's real lessons of
  // this subject (e.g. Grade 10 Chemistry always needs a real Chemistry
  // Lab). Null = no specific real venue required (a normal classroom is
  // assumed, never printed as a venue). When set, the solver treats every
  // real matching venue in the school's pool as a genuine bookable
  // resource — two classes can never be placed in the SAME real venue at
  // the same real period, and a venue's own configured singles/doubles
  // capacity is respected exactly like a teacher's own schedule.
  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id], onDelete: SetNull)

  // AA.4 — a real, school-set soft preference: this subject's own real
  // lessons involve genuine student MOVEMENT (e.g. a lab session, a
  // workshop, PE) and should be preferred right after a real break/lunch,
  // since students are already up and moving anyway rather than
  // interrupting a settled lesson block. A pure soft scoring bonus in the
  // solver's own existing candidate-scoring step (generalizing AA.1's own
  // ElectiveBlock.preferAfterBreak to ordinary per-class subjects) — NEVER
  // a hard rule, so a school with limited slots never gets an unplaced
  // lesson because of this preference. Default false (most subjects, e.g.
  // Mathematics, have no real reason to sit near a break).
  requiresMovement Boolean @default(false)

  // AA.8 — a real, school-set choice: this specific real class NEVER gets
  // a real lab/venue booking for THIS specific real subject (always
  // theory-only for this pairing), even if the subject is normally
  // venue-pooled and a matching venue has spare capacity. Per docs/
  // TEACHER-ALLOCATION-AND-ELECTIVES-ENGINE-DESIGN.md Part 13's "Per-class
  // lab blocking" — scoped per class+subject (not the whole class or the
  // whole venue), per the founder's own explicit choice, so e.g. "Form 2
  // West never gets the Chemistry Lab for Chemistry" doesn't also block
  // that same class's real Computer Studies lab sessions. Default false
  // (the overwhelmingly common case: a class WANTS its real lab session
  // when the subject needs one).
  noLabAccess Boolean @default(false)

  // AA.8 — a real, school-set soft priority for THIS class+subject pairing
  // when real lab/venue capacity is genuinely scarce (not every class can
  // get a session in one generation run). "HIGH" (e.g. a real exam-
  // candidate class) is weighted ahead of "NORMAL" in the solver's own
  // existing candidate-scoring step — a pure soft preference, NEVER a hard
  // guarantee, so a school with tight lab capacity never ends up with a
  // genuinely unplaced lesson purely because of this ordering preference.
  // Scoped per class+subject (not the whole class), per the founder's own
  // explicit choice, so a school can mark one class HIGH priority for
  // Chemistry labs specifically while staying NORMAL for Computer Studies.
  labPriority String @default("NORMAL") // NORMAL | HIGH

  // AA.9 — real, school-set "deliberately re-roll this subject's teacher
  // assignment at the start of each new term" flag. Per docs/TEACHER-
  // ALLOCATION-AND-ELECTIVES-ENGINE-DESIGN.md Part 14: today's
  // autoAssignTeachersToClasses() assignment is genuinely STICKY (stays
  // the same until manually changed or the teacher becomes unavailable),
  // which is correct for most subjects but wrong for a school that
  // deliberately wants a subject like PE (or any subject with NO
  // dedicated specialist) to rotate fairly among several eligible real
  // teachers term by term. Default false — most real subjects have no
  // reason to deliberately reset a working assignment. NEVER a hardcoded
  // rule about WHICH subject rotates or WHO covers it — a school's own
  // real TeacherSubject links (any teacher genuinely linked to this
  // subject) decide who's eligible; this flag only controls WHETHER a
  // real "start of term" reshuffle deliberately clears this pairing's own
  // sticky assignment before re-running the same fair-allocation logic.
  rotateTeacherEachTerm Boolean @default(false)

  @@unique([tenantId, classId, subjectId])
  @@index([tenantId])
  @@index([tenantId, venueId])
}

// AA.8 — Lab reshuffle / rotation memory (founder-requested via
// docs/TEACHER-ALLOCATION-AND-ELECTIVES-ENGINE-DESIGN.md Part 13). When a
// school's real lab/venue capacity is genuinely too tight to give every
// eligible real class a session in one generation run, this real,
// append-only history lets the solver fairly PRIORITIZE classes that were
// actually skipped last time, rather than the same classes always losing
// out cycle after cycle. One real row is written per class+subject EVERY
// time a fresh Master Button generation resolves whether that pairing got
// a real lab session or not — `gotSession=false` rows are what the next
// run's own soft scoring reads back to give that pairing a real priority
// boost, while `gotSession=true` rows reset that pairing's own "missed
// last time" streak. Never a hard guarantee — a class that keeps missing
// out due to genuinely severe capacity constraints is still reported
// honestly via the existing `unplaced` mechanism, never silently forced.
model VenueSessionHistory {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  classId   String
  subjectId String // Subject.id

  // The real generation run this row belongs to (for honest chronological
  // ordering — "last time" always means the most recent real run, never
  // an ambiguous timestamp race).
  generationJobId String?

  gotSession Boolean // true = this class+subject genuinely got a real lab/venue booking this run
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, classId, subjectId])
  @@index([tenantId, classId, subjectId, createdAt])
}

// Z.3 — Real Venue/Lab pool (founder-requested 2026-07-10). A school adds
// its own real rooms (e.g. "Chemistry Lab", "Computer Lab", "Home Science
// Room") and tags each with which real subjects it can host — a POOL by
// subject-type, not a single venue reserved for one class-subject pair, so
// a school with 2 identical Science Labs can let the solver pick whichever
// is genuinely free at a given real period. Each venue also declares its
// own real capacity in terms of singles/doubles it can host per day, so
// the solver can genuinely avoid double-booking one physical room.
model Venue {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String // "Chemistry Lab", "Computer Lab 1"
  // Z.3 — a real, short printable code for this venue (e.g. "CHEM", "LAB1"),
  // shown in the bottom-left corner of a printed lesson cell per the
  // founder's own requested layout. Auto-generated at first use (from the
  // venue's own name, de-duplicated per tenant), editable by the school.
  shortCode String?

  // JSON array of real Subject.id values this venue can host. A class's
  // ClassSubjectNeed.venueId is deliberately DIRECT (not derived from this
  // list) once assigned — this list only matters when a school lets the
  // solver auto-pick from the pool rather than pinning one exact venue.
  supportsSubjectIds String @default("[]")

  // Real capacity: how many genuinely simultaneous real bookings this
  // venue can host in one real period (almost always 1 — one physical
  // room can only host one real class at a time — but kept configurable
  // for a genuinely large real hall/workshop a school may split into
  // real bays). Defaults to the realistic single-room case.
  capacityPerPeriod Int @default(1)
  learnerCapacity   Int? // physical learner seats; null = school has not measured it yet

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classSubjectNeeds ClassSubjectNeed[]
  combinationGroups CombinationGroup[]
  electiveBlockSlotSubjects ElectiveBlockSlotSubject[] @relation("ElectiveBlockSlotSubjectPinnedVenue")
  electiveBlockSlotSubjectsResolved ElectiveBlockSlotSubject[] @relation("ElectiveBlockSlotSubjectResolvedVenue")

  @@unique([tenantId, name])
  @@index([tenantId])
}

// L.7 — School-defined combination groups: classes that take a subject together
// (e.g. Form 1 East + Form 2 West combined Physics). The solver schedules the
// subject once for the whole group at the same period across all member classes
// with one teacher. scope GLOBAL = applies to the whole class-group as configured;
// SELECTED = only the named member classes are combined.
model CombinationGroup {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String // "Physics Group A"
  subjectId      String
  teacherId      String? // shared teacher for the combined lesson
  lessonsPerWeek Int      @default(4)
  doubleCount    Int      @default(0)
  // GLOBAL = the school runs this combination for every class in the configured
  // class-group; SELECTED = only the explicitly listed member classes.
  scope          String   @default("SELECTED") // GLOBAL | SELECTED
  // SUBJECT_CHOICE = derive members from how students chose subjects
  // (StudentSubjectSelection); MANUAL = use the explicit member class list.
  source         String   @default("MANUAL") // MANUAL | SUBJECT_CHOICE
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Z.3 — founder-requested: a real combined/lab session (e.g. a CBE
  // combined Agriculture/Business/Computer/Home-Science block spanning a
  // whole stream) can require its own real venue, chosen the same way the
  // shared teacher is already chosen. Null = no specific real venue
  // required. Respects the venue's own real capacity/conflict rules
  // exactly like any other class-subject need.
  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id], onDelete: SetNull)

  // AA.4 — same real soft "prefer right after a break" preference as
  // ClassSubjectNeed.requiresMovement above, for a combined/lab session
  // that genuinely involves student movement (e.g. a combined Science
  // practical across streams). Default false.
  requiresMovement Boolean @default(false)

  members CombinationGroupClass[]

  @@index([tenantId])
  @@index([tenantId, venueId])
}

model CombinationGroupClass {
  id       String           @id @default(cuid())
  tenantId String
  groupId  String
  group    CombinationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  classId  String

  @@unique([groupId, classId])
  @@index([tenantId])
}

// AA.1 — Elective/Options Block engine (founder-requested 2026-07-12, full
// design in docs/TEACHER-ALLOCATION-AND-ELECTIVES-ENGINE-DESIGN.md Part 7).
//
// A real, school-defined group of subjects that a school's students choose
// BETWEEN (mutually exclusive alternatives), which must therefore occupy
// IDENTICAL real timetable slot(s) so every student in the block is doing
// SOMETHING during that time, but which specific lesson/room/teacher they
// attend depends on their own real subject choice. This is deliberately
// NOT the same real concept as CombinationGroup (which merges classes into
// ONE shared lesson with ONE shared teacher) — an ElectiveBlock instead
// holds MULTIPLE real parallel lessons (each potentially its own
// CombinationGroup if small cohorts are merged across streams) happening
// at the same real time, one of which each real student attends.
//
// Real worked example (the founder's own high school): a "Humanities Pair"
// block spanning 2 real weekly slots — Slot A = History+CRE running in
// parallel; Slot B = History+Geography running in parallel (History
// genuinely appears in only ONE of the block's slots, not every slot,
// modeling a real 2nd History lesson happening opposite Geography instead
// of opposite CRE). A student who chose Geography+Physics attends Geography
// in Slot B, is genuinely FREE in Slot A (they take neither History nor
// CRE), and Physics sits in its own separate non-block slot entirely.
model ElectiveBlock {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String // "Humanities Pair", "Technical & Applied", "STEM Electives"

  // MULTI_SLOT = different subjects may appear in different slots (the
  // Humanities Pair shape above) — schools set this up slot-by-slot.
  // SINGLE_CHOICE = every slot lists the exact same subject set (the
  // Technical & Applied "choose ONE of Business/Computer/Art/Agriculture/
  // French" shape, where all 5 run in parallel in EVERY one of the block's
  // slots) — a real, simpler special case of the same underlying model,
  // kept as an explicit mode so the UI can offer a much faster one-step
  // "pick your subjects, pick how many lessons/week" setup for schools in
  // this simpler, overwhelmingly common shape, rather than making every
  // school manually build each slot's subject list one at a time.
  mode String @default("MULTI_SLOT") // MULTI_SLOT | SINGLE_CHOICE

  // Real soft preference (not a hard rule — never causes unplaced lessons):
  // prefer scheduling this block's slots immediately after a real
  // break/short-break/lunch, since students are already moving between
  // rooms for this block anyway. See design doc Part 8.
  preferAfterBreak Boolean @default(false)

  // AA.10 follow-up — founder's own words: "a school can prefer split even
  // if the system advices so that they choose what they want". By default
  // (false) NEYO's exam generator auto-analyses this block and, when the
  // block genuinely is SINGLE_CHOICE-shaped (one subject per student —
  // combinable), it schedules all of the block's subjects at one shared
  // real date/period ("the system's own advice"). Setting this true is a
  // school's own explicit override that turns that auto-combine OFF for
  // THIS block only — the block's subjects are always given genuinely
  // independent exam sittings instead, even though the system would
  // otherwise recommend combining them. Chosen per-block (not one
  // school-wide switch) per the founder's own confirmed answer, since a
  // school may want Technical subjects combined but Humanities kept
  // split, or vice versa. Never affects the real lesson timetable (only
  // exam-timetable-generator.service.ts reads this flag) and never
  // affects a genuinely MULTI_SLOT block (those are already always
  // scheduled independently — this flag only ever changes behaviour for
  // SINGLE_CHOICE-shaped blocks).
  preferSplitExamSittings Boolean @default(false)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes ElectiveBlockClass[]
  slots   ElectiveBlockSlot[]

  @@index([tenantId])
}

// Which real classes/streams this block applies to — mirrors the same
// simple many-to-many shape as CombinationGroupClass. A block almost
// always spans an entire level (e.g. all of Form 3, or all of Grade 11),
// but is kept as an explicit list (not just "level") so a school can
// exclude one real stream if it genuinely doesn't offer this block.
model ElectiveBlockClass {
  id       String        @id @default(cuid())
  tenantId String
  blockId  String
  block    ElectiveBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  classId  String

  @@unique([blockId, classId])
  @@index([tenantId])
}

// One real distinct weekly timetable slot this block occupies (e.g. "Slot
// A", "Slot B" in the Humanities Pair example). A block with slotsPerWeek=2
// has exactly 2 real ElectiveBlockSlot rows. The solver places ALL of a
// block's slots as one coordinated real placement unit (see the engine
// changes below) so that, e.g., the same real History teacher's 2 weekly
// History groups (one per slot) never clash with each other or with
// anything else that teacher/room is doing.
model ElectiveBlockSlot {
  id       String        @id @default(cuid())
  tenantId String
  blockId  String
  block    ElectiveBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  label String // "Slot A", "History/CRE", freeform school-facing label
  // How many of this slot's real lessons should be a double (2 consecutive
  // periods) rather than a single — mirrors ClassSubjectNeed.doubleCount's
  // exact real meaning, applied per-slot since different slots of the same
  // block may reasonably have different lengths (e.g. a lab-heavy elective
  // slot as a double, a discussion-based one as a single).
  isDouble Boolean @default(false)

  sortOrder Int @default(0)

  subjects      ElectiveBlockSlotSubject[]
  timetableSlots TimetableSlot[]

  @@index([tenantId])
  @@index([blockId])
}

// One real subject running in this specific slot, with its own real
// teacher/venue — e.g. "History taught by Mr. Otieno" in Slot B, while
// "Geography taught by Mrs. Wanjala" also runs in Slot B, in a different
// real room, for the students who chose Geography instead of History.
// comboClassIds (JSON array of real classId strings) lets a school merge
// a small cohort's version of this subject across streams into one real
// shared lesson (e.g. only 6 students across 3 streams chose CRE — merge
// them into one real CRE lesson with one real shared teacher) — this
// reuses the exact same real "shared teacher across multiple classes"
// concept CombinationGroup already proves works in the live solver,
// applied here at the level of one block-slot-subject instead of a
// school-wide combination group.
model ElectiveBlockSlotSubject {
  id        String            @id @default(cuid())
  tenantId  String
  slotId    String
  slot      ElectiveBlockSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  subjectId String
  teacherId String?
  venueId   String?
  venue     Venue?            @relation("ElectiveBlockSlotSubjectPinnedVenue", fields: [venueId], references: [id], onDelete: SetNull)

  // BB.1 — when a school leaves `venueId` unset for a genuine "overflow"
  // subject (a slot with more parallel subjects than the block has member
  // classes to host them in their own home classrooms — e.g. 5 real
  // subjects but only 4 real streams), the solver auto-picks a real venue
  // from the tenant's own Venue pool (respecting supportsSubjectIds +
  // capacity + full clash-avoidance, exactly like an ordinary
  // ClassSubjectNeed card already does) and persists its pick HERE, once
  // per real generation run — never fabricated, always genuinely reserved
  // and conflict-checked. `venueId` (a school's own explicit pin) always
  // wins over this at render time; this field only matters when `venueId`
  // is null. Cleared/recomputed honestly on every real generation run
  // (a previously-picked venue may no longer be free, or may no longer
  // even be needed if the school later pins one explicitly).
  resolvedVenueId String?
  resolvedVenue   Venue?  @relation("ElectiveBlockSlotSubjectResolvedVenue", fields: [resolvedVenueId], references: [id], onDelete: SetNull)

  // JSON array of real classId strings genuinely offering this subject
  // inside this slot — for MULTI_SLOT mode this is normally the block's
  // full class list; for a merged small cohort it may be a subset spanning
  // several real streams sharing one real lesson.
  comboClassIdsJson String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slotId, subjectId])
  @@index([tenantId])
}

// BB.2 — a real, auditable record of one "Build from student choices" run:
// the founder's own real request to auto-derive an ElectiveBlock's subjects
// + combined rosters + suggested teachers directly from real, confirmed
// StudentSubjectSelection data for a level, rather than a school manually
// re-typing what students already told NEYO they chose. Never a silent
// background process — a school always sees a real preview (recorded here)
// and explicitly confirms before any real ElectiveBlock is created, exactly
// matching every other NEYO importer's preview-before-commit discipline.
// Also covers the real Core/Essential Mathematics SPLIT scenario (a class
// with a genuine mix of STEM/non-STEM students needs a real parallel
// Core-vs-Essential block, not one variant picked for the whole class) —
// `kind` distinguishes the two real scenarios since their real subject
// detection rules differ (general electives vs. the fixed 2-variant split).
model ElectiveBlockAutoBuildRun {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  level String // the real level this run analysed, e.g. "Grade 10"
  kind  String @default("ELECTIVES") // "ELECTIVES" | "MATH_SPLIT"

  // JSON snapshot of the real preview shown to the school: detected
  // subjects, per-subject combined roster (student ids/names), suggested
  // teacher (from the real fairness-ranked recommendation engine), and any
  // real capacity/leftover-lesson notes — frozen at preview time so the
  // school's own later decision is auditable even if source data changes.
  previewJson String @default("{}")

  status            String   @default("PREVIEWED") // "PREVIEWED" | "CONFIRMED" | "DISCARDED"
  createdElectiveBlockId String? // the real ElectiveBlock this run produced, once confirmed
  createdById       String
  createdByName     String
  createdAt         DateTime @default(now())
  confirmedAt       DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, level])
}

// BB.3 — a real, auditable record of one class-size-cap overflow decision.
// `SchoolClass.capacity` already exists but was never enforced anywhere in
// the codebase before BB.3 — this model records the REAL moment a school's
// own subject-choice-driven grouping (L.7 auto-grouping, BB.2/BB.4 auto-
// build) genuinely exceeded a real class's own configured capacity, and
// what the school explicitly chose to do about it: split the overflow into
// a genuinely NEW class/section (auto-named after the real subject that
// caused the split, e.g. "Form 3 Geo", per the founder's own exact
// request), or explicitly allow the whole group into the one class anyway,
// deliberately over capacity. Never a silent decision — always a real,
// staff-confirmed choice, exactly matching every other NEYO capacity-type
// decision (e.g. hostel bed capacity, pathway seat capacity).
model ClassCapacityOverflowRun {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // The real class whose configured capacity was genuinely exceeded, and
  // the real subject (if any) whose grouping caused the overflow — a plain
  // whole-class overflow (not tied to one particular subject group, e.g. a
  // promotion moving too many students into one destination class) leaves
  // subjectId null.
  classId   String
  subjectId String?

  overflowCount Int // how many real students exceeded the class's own real capacity
  decision      String @default("PENDING") // "PENDING" | "SPLIT_NEW_CLASS" | "ALLOW_OVER_CAPACITY"

  // The real NEW class created, if the school chose to split — auto-named
  // from the real subject/level/stream context, never a generic "Class B".
  newClassId String?

  // A real, honest record of whether the new class's own ClassSubjectNeed
  // teacher gaps were filled by the fair auto-assign engine (only run
  // AFTER a school's own manual assignment attempt, and only if a real
  // Master Button generation is actually meaningful for this tenant yet —
  // per the founder's own explicit instruction: auto-assign runs LAST, as
  // a fallback for genuinely unfilled gaps, never overriding a school's
  // own real manual choice, and timetable regeneration never fires blindly
  // when a school has no real subject groups configured yet).
  autoAssignedTeacherCount Int @default(0)

  createdById   String
  createdByName String
  createdAt     DateTime  @default(now())
  decidedAt     DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, classId])
}

// L.7 — Configurable timetable constraints a school turns on/off (and tunes).
// Deterministic rule engine, never AI. `kind` selects the rule; `configJson`
// holds rule-specific parameters (e.g. which subjects, which periods).
model TimetableConstraint {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind       String // SUBJECT_MORNING | SUBJECTS_NOT_ADJACENT | SPLIT_DOUBLE_HARD | STREAM_DISTRIBUTION | LESSON_DISTRIBUTION | TEACHER_TIMEOFF | DOUBLE_SAME_DAY | CLASS_STREAM_CONFLICT | ONE_SINGLE_PER_DAY | PE_TIMESLOT | CUSTOM
  label      String // human label, incl. school-added custom constraints
  enabled    Boolean  @default(true)
  priority   Int      @default(100) // lower = applied/respected first (hard vs soft ordering)
  isHard     Boolean  @default(false) // hard = must satisfy; soft = best-effort
  configJson String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, kind])
}

// L.7 — Teacher unavailability windows (time off) the solver must respect.
model TeacherTimeOff {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId String
  dayOfWeek Int // 1=Mon..5=Fri; or 0 = all days
  period    Int // specific period, or 0 = whole day
  note      String?

  @@index([tenantId, teacherId])
}

// AA.6 — Hard-blocked timetable slots (assembly, PPI, whole-school games
// afternoon, etc.) that the solver must treat as an absolute exclusion,
// distinct from the SOFT ClassSubjectNeed-based co-curricular approach
// (which the backtracking solver is still allowed to move/skip under
// pressure). Stackable with the soft approach; scoped exactly like
// TimetableConstraint's own conventions: SCHOOL, LEVEL, or CLASS.
model BlockedTimetableSlot {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  label String // school-facing name, e.g. "Whole-School Assembly", "Games Afternoon"

  scope   String // SCHOOL | LEVEL | CLASS
  level   String?
  classId String?

  dayOfWeek Int // 1=Mon..6=Sat
  period    Int // specific real period number this slot occupies
  isDouble  Boolean @default(false) // true = this AND period+1 are both hard-blocked

  activityName  String?
  activityColor String?

  enabled Boolean @default(true) // a school can pause a block without deleting it

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, scope])
  @@index([tenantId, classId])
}

// L.7 — Master timetable generation job (the Master Button): runs in the
// background, tracks live progress so the UI can show a bar, records the result.
model TimetableGenerationJob {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status        String    @default("QUEUED") // QUEUED | RUNNING | DONE | FAILED
  progress      Int       @default(0) // 0..100
  phase         String    @default("Queued") // human-readable current phase
  slotsPlaced   Int       @default(0)
  unplacedJson  String    @default("[]") // JSON list of loads that could not be placed
  warningsJson  String    @default("[]") // JSON list of soft-constraint warnings
  reservationSummaryJson String @default("[]") // Phase D option/math family weekday + day-half proof
  learnerProofValid   Int @default(0)
  learnerProofInvalid Int @default(0)
  qualityReportJson   String @default("{}") // Phase F deterministic balance/spacing report
  learnerProofs SeniorLearnerTimetableProof[]
  error         String?
  startedById   String
  startedByName String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?

  @@index([tenantId, status])
}

// Senior Phase E: immutable per-generation proof of what one learner can
// actually attend. It resolves ordinary class lessons, the learner's own
// Core/Essential Mathematics variant and exact A/B/C elective subjects.
model SeniorLearnerTimetableProof {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  generationJobId String
  generationJob   TimetableGenerationJob @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId         String
  level           String
  valid           Boolean
  timetableJson   String   @default("[]")
  issuesJson      String   @default("[]")
  optionAId       String?
  optionBId       String?
  optionCId       String?
  mathVariant     String?
  createdAt       DateTime @default(now())

  @@unique([generationJobId, studentId])
  @@index([tenantId, studentId, createdAt])
  @@index([tenantId, generationJobId, valid])
}

