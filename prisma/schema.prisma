  deadline         String? // YYYY-MM-DD for applications/submissions
  status           String   @default("PLANNED") // PLANNED | ASSEMBLING | READY | SUBMITTED | COLLECTED
  checklistJson    String? // JSON checklist of required papers/materials
  hardcopyLocation String // required: where physical file/materials are kept
  fileUrl          String? // optional soft copy/proof upload
  fileName         String?
  notes            String?
  createdById      String
  createdByName    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, examDate])
  @@index([tenantId, deadline])
}

model PromiseToPay {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId      String
