  // spend this period (KES) — feeds real CAC = marketingSpendKes / newSignups.
  // Zero by default (the founder currently runs zero paid marketing — an
  // honest zero, never a placeholder).
  marketingSpendKes Int @default(0)

  notes         String?
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([periodStart])
}

// Z.1 — Real Offline-First Resilience for internet shutdowns.
//
// A real, tenant-scoped idempotent-request ledger. Extends the offline
// queue's existing `Idempotency-Key` header (already sent by every real
// `queuedPost()` call, previously received but never actually checked
// server-side for anything except Attendance/Exam-marks, whose own natural
// upsert-per-day/per-student shape happened to make replay safe by
// construction). Gate Pass issuance and Visitor sign-in do NOT have that
// natural property (they mint a real new sequential passNo/badgeNo on every
// `create()` and reject a second "active pass" for the same student) — a
// real replay of the exact same offline action must return the EXACT SAME
// real result the first successful attempt produced, never mint a second
// real pass/badge and never incorrectly reject a legitimate retry as a
// duplicate. This model is the real, generic, server-side deduplication
// record any write endpoint can opt into via `withIdempotency()`.
model IdempotentRequest {
  id     String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // The real client-generated Idempotency-Key (a UUID from `queue.ts`).
  idempotencyKey String

  // Which real action this key belongs to (e.g. "security.gatePass",
  // "reception.signInVisitor") — the SAME key is only ever meaningful
  // within one real action's namespace.
  action String

  // The real JSON response the FIRST successful attempt produced — replayed
  // byte-for-byte on any subsequent request bearing the same key, so the
  // caller always sees the one real pass/badge/record that was actually
  // created, never a second one.
  responseJson String

  createdAt DateTime @default(now())

  @@unique([tenantId, action, idempotencyKey])
  @@index([tenantId, createdAt])
}

