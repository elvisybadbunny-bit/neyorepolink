// NEYO database schema — Chunk 0 Foundation
// PRODUCTION provider: postgresql (real production database — Neon).
// Switched from sqlite to postgresql for the real neyo.co.ke go-live deploy.
// Old SQLite migration history is preserved for reference in
// prisma/migrations-sqlite-archive/ (not used anymore, kept only as a record).
//   Postgres-only features flagged in code: Row-Level Security (A.2), tsvector search (A.11).
// Each feature chunk EXTENDS this schema with its own models.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // Runtime queries (the app itself, every request) go through Neon's
  // POOLED connection (pgbouncer) for real connection-limit safety at
  // scale — this is `DATABASE_URL` / Vercel's Neon integration default.
  url      = env("DATABASE_URL")
  // `prisma migrate deploy`/`migrate dev` ALWAYS use this DIRECT
  // (non-pooled) connection instead. REAL BUG FIX (2026-07-18): without
  // this line, `migrate deploy` was forced through the pooled endpoint,
  // which does not support the session-level Postgres advisory lock
  // Prisma's migration engine needs — this is the exact real cause of
  // the founder's live Vercel deploy failure (P1002: "the database
  // server ... was reached but timed out ... acquire a postgres
  // advisory lock"). Neon's own Vercel integration always provides a
  // real, separate non-pooled URL for exactly this reason — see
  // POSTGRES_URL_NON_POOLING in the Vercel/Neon integration env vars
  // (already read by scripts/auto-resolve-failed-migrations.js's own
  // fallback chain, just never wired into the schema itself until now).
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ---------------------------------------------------------------------------
// The 16 roles (Part A.3). SQLite has no native enums, so we store the role as
// a string and validate it against this list in Zod (Chunk 2 of every feature).
// Canonical role list lives in src/lib/core/roles.ts.
// ---------------------------------------------------------------------------

// A school / business / farm / creator account = one Tenant (A.2 Multi-Tenancy).
model Tenant {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique // used for subdomain + ID prefix (A.4)
  // T.4 — the real, STABLE human-readable ID prefix (e.g. "KH", "KHS2") used
  // by nextTenantId()/peekNextTenantId() for every human-facing ID (student
  // admission numbers, invoice numbers, etc). Computed ONCE at real tenant
  // creation via computeUniqueIdPrefix() (auto-disambiguated against every
  // OTHER real tenant's own idPrefix, e.g. a second "KHS"-slug school
  // becomes "KHS2") and NEVER recomputed afterward, so an existing school's
  // real IDs never silently change. Nullable only for the brief pre-backfill
  // window on old rows; a real migration backfills every existing tenant's
  // idPrefix from its current prefixFromSlug(slug) value FIRST, so no
  // already-live school's IDs are ever touched by this feature.
  idPrefix String? @unique // real DB-level guarantee: two tenants can never share one
  county   String? // Kenyan county, e.g. "Nairobi"
  phone    String? // +254 7XX XXX XXX
  email    String?
  osKey    String  @default("school") // I.50: school | business | farm | creator

  // Onboarding (G.3)
  principalSignatureUrl  String? // K.14 Digital Signature
  schoolStampUrl         String? // K.14 Digital Stamp
  curriculum             String? // "CBC" | "8-4-4" | "BOTH"
  educationLevelsOffered String? // JSON array: ECDE | PRIMARY | JUNIOR_SCHOOL | SENIOR_SCHOOL
  onboardedAt            DateTime?
  // G.14 Day-One Demo Mode: a sandboxed, time-boxed tenant that auto-expires.

  // PART M.1 — NEYO Referral Engine
  referralCode       String?  @unique
  referredByTenantId String?
  referredBy         Tenant?  @relation("TenantReferrals", fields: [referredByTenantId], references: [id], onDelete: SetNull)
  referrals          Tenant[] @relation("TenantReferrals")
  hasClaimedReferral Boolean  @default(false)

  // T.2 — real, one-time record of which discount campaign (if any) applied
  // to this school's FIRST subscription payment, and T.6 — which influencer
  // code (if any) this school used at signup. Founder-confirmed
  // (2026-07-08): a school can use ONE OR THE OTHER, never both — these two
  // fields are therefore mutually exclusive by construction (only one is
  // ever set), enforced in the real service layer, not just by convention.
  appliedCampaignId           String?
  appliedInfluencerCodeId     String?
  appliedInfluencerCode       InfluencerCode? @relation(fields: [appliedInfluencerCodeId], references: [id], onDelete: SetNull)
  firstTermDiscountKes        Int             @default(0) // T.2/T.6 — the real KES actually deducted on the first term (0 if none)
  hasClaimedFirstTermDiscount Boolean         @default(false) // real one-time guard, mirrors hasClaimedReferral's own pattern

  // Part V — Capacity-Based Pricing 2.0 real reverse relations.
  pricingSnapshots    TenantPricingSnapshot[]
  schoolQuoteRequests SchoolQuoteRequest[]

  // T.6 — real influencer commissions earned FOR this school signing up.
  influencerCommissions InfluencerCommission[]

  // T.14 — real multi-child payment split plans.
  familyPaymentSplitPlans FamilyPaymentSplitPlan[]

  // W.1 — Storage Intelligence Engine (founder-requested 2026-07-06).
  storageOptimizerRuns StorageOptimizerRun[]

  // Z.1 — real offline-safe replay ledger.
  idempotentRequests IdempotentRequest[]

  // CBE Delivery Hub — joins rich curriculum design to actual classroom
  // delivery, learner evidence and reviewed interventions.
  cbeCurriculumDesigns CbeCurriculumDesign[]
  cbeDeliverySessions  CbeDeliverySession[]
  cbeDeliveryEvidence  CbeDeliveryEvidence[]
  cbeInterventions     CbeIntervention[]
  seniorLearnerTimetableProofs SeniorLearnerTimetableProof[]

  // Z.3 — real Venue/Lab pool.
  venues Venue[]

  isDemo               Boolean   @default(false)
  demoExpiresAt        DateTime? // when the demo tenant is purged (null = not a demo / kept)
  // G.21 (founder 2026-06-12): DAY | BOARDING | DAY_AND_BOARDING — gates the
  // hostel module + boarding-fee features for day-only schools.
  schoolType           String    @default("DAY")
  // G.24 uniform supplier/tailor (orders are relayed to them).
  uniformSupplierName  String?
  uniformSupplierPhone String? // +254...

  // P.1 (2026-07-02): Kenya CBE Senior School pathway configuration. A school
  // offering Senior School (Grades 10-12) declares itself TRIPLE (all three
  // official KICD pathways: STEM, Social Sciences, Arts & Sports Science) or
  // DUAL (STEM + exactly one other, e.g. "STEAMS"/"STEMS" combinations) — a
  // real classification KICD publishes for senior schools, not a NEYO invention.
  // "NONE" (default) = school has not configured Senior School pathways yet
  // (e.g. a primary-only or junior-only school) — no behaviour change for
  // any existing tenant until they explicitly configure this.
  pathwaySchoolType    String  @default("NONE") // NONE | TRIPLE | DUAL
  // JSON array of the pathway GROUP KEYS this school actually offers, e.g.
  // ["STEM","SOCIAL_SCIENCES"] for a Dual school. Drives which official
  // KICD pathways get seeded/shown; independent of custom pathways a school
  // may still create for their own tracking.
  enabledPathwayGroups String? @default("[]")

  // Calendar preferences (A.17.3): opt-in to showing religious moments.
  showReligiousHolidays Boolean @default(true)
  libraryFinesEnabled   Boolean @default(true) // customizable switch for late book returns fines (H.3)
  libraryFinePerDayKes  Int     @default(10) // customizable late-return fine amount per chargeable day
  libraryLoanPeriodDays Int     @default(14) // school default; exact due date remains editable per issue

  // School Profile & Branding (G.9). Used across receipts/reports/ID cards and
  // (later) the public subdomain landing site (G.11).
  motto               String?
  vision              String?
  mission             String?
  about               String? // short description / "about us"
  logoUrl             String? // school badge/logo (stored via A.9)
  brandPrimary        String? // hex, e.g. "#1c2740"
  brandAccent         String? // hex, e.g. "#1f9d5f"
  addressLine         String? // postal/physical address
  socialLinks         String? // JSON: { facebook, instagram, tiktok, youtube, website }
  // Joining requirements MASTER list (G.9): JSON array of
  // { label, category, quantity?, mandatory } shown to new parents at admission.
  joiningRequirements String?
  documentDesignJson  String? // I.42 school-owned document/ID design defaults
  // G.17 geofence for GPS-verified staff clock-in (null = geofence off).
  gpsLat              Float?
  gpsLng              Float?
  gpsRadiusM          Int? // allowed distance from the gate, metres (e.g. 300)

  // B.24 Owner Dashboard: fee-collection target the owner measures against.
  collectionTargetPct         Int @default(85) // % of billed fees expected collected this term
  // B.25 Procurement: POs above this need leadership approval (KES).
  poApprovalThresholdKes      Int @default(50000)
  // B.25 Expenses: expenses above this need leadership approval (KES).
  expenseApprovalThresholdKes Int @default(20000)
  // G.12 Sibling Intelligence: default % discount applied to a sibling's fee
  // invoice when a family has 2+ children enrolled (0 = off; bursar applies it).
  siblingDiscountPct          Int @default(0)

  // T.8 (founder-requested 2026-07-06): "a school choses what they would
  // like in their system" — the real mid-term transport route/shift change
  // billing rule is explicitly NEVER a fixed platform decision. Off
  // (NEXT_TERM_ONLY, no mid-term financial adjustment at all) is the safe
  // default for every existing school. PRORATE = charge/refund only for the
  // remaining real days at the new route's rate. TOPUP = a real new
  // top-up invoice for the new route's full remaining-term fee, no refund
  // logic. NEXT_TERM_ONLY = the change only affects billing starting the
  // school's own next real term invoicing run.
  transportMidTermBillingRule  String  @default("NEXT_TERM_ONLY") // PRORATE | TOPUP | NEXT_TERM_ONLY
  // T.8 — real, explicit parent-portal opt-in gate (mirrors
  // requireBiometricForFinance's own proven on/off pattern exactly). Off by
  // default — a school must explicitly turn this on before any parent can
  // submit a real transport route-change request via their own portal.
  allowParentTransportRequests Boolean @default(false)

  // T.9 — Cafeteria: mirrors allowParentTransportRequests exactly for the
  // feeding program. Off by default — a school must explicitly turn this
  // on before a parent can submit a real mid-term enrollment/cancel
  // request for their child's meal card via the portal.
  allowParentCafeteriaRequests Boolean @default(false)

  // R.3 (2026-07-03, founder request): require a real fingerprint/Face ID/
  // passkey check (WebAuthn, works on iPhone Face ID, Android fingerprint,
  // Windows Hello — any platform authenticator, not NEYO-specific hardware)
  // before a cash payment can be RECORDED or a fee discount/waiver can be
  // APPLIED. Off by default — a school opts in once its staff have real
  // passkeys registered (Settings → Security). Server-side enforced (a real
  // short-lived signed ticket, not just a screen popup a request could skip).
  requireBiometricForFinance Boolean @default(false)

  // T.10 — real, explicit per-school opt-in gate (mirrors
  // requireBiometricForFinance's own proven on/off pattern exactly). Off by
  // default. When ON, a TEACHER/CLASS_TEACHER may submit a real PENDING
  // cash-payment entry from their own portal — it never touches the real
  // invoice ledger, never triggers a receipt, and never counts as PAID
  // until a real bursar/leadership user explicitly CONFIRMS the cash
  // genuinely reached the school office.
  allowTeacherCashPayments Boolean @default(false)

  // T.11a — real, school-configurable fee-reminder cadence, replacing the
  // previous hardcoded "3 days after due date, repeat every 3 days" rule.
  // feeReminderGraceDays = how many days after the due date the FIRST
  // reminder fires; feeReminderDedupeDays = how many days between repeat
  // reminders for the same still-overdue invoice. Both default to the
  // exact real values the fixed rule already used, so no school's real
  // reminder cadence changes unless they explicitly edit these.
  feeReminderGraceDays  Int @default(0)
  feeReminderDedupeDays Int @default(3)

  // U.1 — real, school-CHOSEN SMS spend budget alert (founder's own
  // explicit instruction: "a school can choose what they want, not a
  // threshold [we impose] — they're going to pay for their SMS costs").
  // NULL smsSpendAlertThresholdKes = the school has not set one (feature
  // is off by default, never nags a school that never asked for it). When
  // set, NEYO notifies the school's leadership once per term the moment
  // their real SmsMarginLedger spend for that term crosses this real
  // KES amount. smsSpendAlertLastNotifiedPeriodKey prevents repeat nagging
  // within the same term (reset naturally each new billing period).
  smsSpendAlertThresholdKes         Int?
  smsSpendAlertLastNotifiedPeriodKey String?

  // G.34 Security Hardening: enforce 2FA for all leadership/staff roles
  enforce2Fa Boolean @default(false)

  // H.2 Multi-Owner Support: when a school has 2+ owners and this is ON, certain
  // critical actions need a SECOND owner's approval (dual control) — every
  // decision is logged. Auto-no-ops when there's only one owner.
  requireJointOwnerApproval Boolean @default(false)

  // H.2 Customized Printing Limits: max document prints per user per day for
  // non-privileged roles (null/0 = unlimited). Privileged roles (Principal,
  // Deputy, Academics HOD, Owner) bypass the limit and set it.
  printLimitPerDay Int? @default(0)

  // H.2 Boarding Term-End Print Scheduler: "AUTO" = the print station prints
  // jobs as they queue (default); "HOLD" = boarding schools hold all jobs and
  // batch-print them only at term end. School-wide, leadership-controlled.
  printStationMode String @default("AUTO")

  // H.5 Cafeteria Table Allocation: default number of seats per dining table.
  cafeteriaTableSize Int    @default(8)
  cafeteriaMealModel String @default("HYBRID") // HYBRID | CARDS_ONLY | BOARDING_GROUPS | NO_CARDS
  cafeteriaMealScope String @default("ALL") // ALL | LUNCH | SUPPER

  // H.2 Role-Based Settings & Module Visibility Control: per-school map of which
  // nav items / settings are HIDDEN for which roles. JSON: { "<href>": ["ROLE",..] }.
  // Owner/Principal-managed; non-concerned staff can be reduced to just their
  // own Security (password) + language. Empty/null = nothing extra hidden.
  navVisibility String?

  // Per-tenant encryption key (A.2.7, DEK/KEK envelope pattern).
  // The tenant's DEK is AES-256-GCM-encrypted with the master KEK (env/KMS).
  encryptedDek String? // base64 wrapped DEK
  dekIv        String? // base64 IV used to wrap the DEK
  dekTag       String? // base64 GCM auth tag for the wrapped DEK

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

