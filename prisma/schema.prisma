model NeyoFounderOpsEntry {
  id              String    @id @default(cuid())
  kind            String // WEEKLY_METRICS | MONTHLY_ALL_HANDS | QUARTERLY_AUDIT | ANNUAL_PLANNING | DEMO_DAY | INVESTOR_UPDATE | BOARD_MEETING | IMPACT_REPORT
