  title           String
  status          String    @default("PLANNED") // PLANNED | DONE | SKIPPED
  scheduledFor    String? // YYYY-MM-DD
  completedAt     DateTime?
  summary         String?
  notes           String?
  decisionsJson   String? // JSON array of decisions made
  actionItemsJson String? // JSON array of {task, owner, dueOn, done}
  metricsJson     String? // JSON metrics snapshot relevant to this meeting/update
  audience        String? // internal, investors, board, community, public
