  title     String // e.g. "Principal"
  bio       String?
  photoUrl  String?
  email     String?
  phone     String?
  sortOrder Int     @default(0)
  published Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

